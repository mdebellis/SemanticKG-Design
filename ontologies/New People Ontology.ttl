               <http://purl.org/dc/terms/created> "2025-03-17T23:00:55Z"^^xsd:dateTime ;
               rdfs:label "has colleague" .


###  http://michaeldebellis.com/people/has_Daughter
:has_Daughter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :has_Child ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( :Girl
                                         :Woman
                                       )
                         ] ;
              rdfs:label "has daughter" .


