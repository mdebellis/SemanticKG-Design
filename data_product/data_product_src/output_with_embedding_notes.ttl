sf:Creator_Insights_Aggregation_Run_2026_02_08 a owl:NamedIndividual,
        dp:Data_Analysis_Activity ;
    rdfs:label "Creator Insights Aggregation Pipeline (2026-02-08)"@en,
        "Creator Insights Aggregation Run (2026-02-08)"@en ;
    dctm:description "A data aggregation pipeline that processes raw creator engagement and performance signals to produce the SF Creator Insights Dataset, which serves as an input to downstream analytics and executive metrics."@en,
        "Data analysis activity that used the SF Engagement Events Dataset, Creator Profile Dataset, and SF Video Metadata Dataset to generate the SF Creator Insights KPIs dataset."@en,
        "Pipeline run that aggregates raw engagement events into creator-level KPIs for dashboards and reporting. It joins engagement signals with video metadata and creator reference data, applies standard filters and normalization, and produces the SF Creator Insights Dataset."@en ;
    rdfs:comment "This activity represents the aggregation step that computed creator KPI outputs from multiple StreamForge input datasets."@en ;
    skos:definition "An aggregation activity that consolidates creator engagement data into a curated analytics dataset."@en ;
    prov:endedAtTime "2026-02-08T07:25:00-08:00"^^xsd:dateTime ;
    prov:generated sf:SF_Creator_Insights_Dataset,
        sf:SF_Creator_Insights_KPIs ;
    prov:startedAtTime "2026-02-08T07:10:00-08:00"^^xsd:dateTime ;
    prov:used sf:Creator_Profile_Dataset,
        sf:Engagement_Events_Dataset,
        sf:SF_Engagement_Events_Dataset,
        sf:SF_Video_Metadata_Dataset,
        sf:Video_Metadata_Dataset ;
    prov:wasAssociatedWith sf:Analytics_Engineering_Team ;
    dp:embedding_note "Creator Insights Aggregation Pipeline (2026-02-08) generated SF Creator Insights Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) generated SF Creator Insights KPIs."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) is an instance of Data Analysis Activity."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) used Creator Profile Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) used Engagement Signals  Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) used SF Engagement Events Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) used SF Video Metadata Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) used Video Metadata Dataset."@en,
        "Creator Insights Aggregation Pipeline (2026-02-08) was associated with Analytics Engineering Team."@en .

