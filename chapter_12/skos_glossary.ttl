@prefix : <https://www.michaeldebellis.com/glossary/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://www.michaeldebellis.com/glossary/> .

<https://www.michaeldebellis.com/glossary> rdf:type owl:Ontology ;
                                            dcterms:contributor "Dave Beckett" ,
                                                                "Nikki Rogers" ,
                                                                "Participants in W3C's Semantic Web Deployment Working Group." ;
                                            dcterms:creator "Alistair Miles" ,
                                                            "Sean Bechhofer" ;
                                            dcterms:description "An RDF vocabulary for describing the basic structure and content of concept schemes such as thesauri, classification schemes, subject heading lists, taxonomies, 'folksonomies', other types of controlled vocabulary, and also concept schemes embedded in glossaries and terminologies."@en ;
                                            dcterms:title "SKOS Vocabulary"@en ;
                                            rdfs:seeAlso <http://www.w3.org/TR/skos-reference/> ;
                                            skos:historyNote "Imported SKOS and merged it so that Internet access isn't required to use this ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:comment "The range of skos:altLabel is the class of RDF plain literals."@en ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "alternative label"@en ;
              skos:definition "An alternative lexical label for a resource."@en ;
              skos:example "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)."@en ;
              rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "change note"@en ;
                skos:definition "A note about a modification to a concept."@en ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "definition"@en ;
                skos:definition "A statement or formal explanation of the meaning of a concept."@en ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                   rdfs:label "editorial note"@en ;
                   skos:definition "A note for an editor, translator or maintainer of the vocabulary."@en ;
                   rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "example"@en ;
             skos:definition "An example of the use of a concept."@en ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#hiddenLabel
skos:hiddenLabel rdf:type owl:AnnotationProperty ;
                 rdfs:comment "The range of skos:hiddenLabel is the class of RDF plain literals."@en ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ;
                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                 rdfs:label "hidden label"@en ;
                 skos:definition "A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations."@en ;
                 rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#historyNote
skos:historyNote rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                 rdfs:label "history note"@en ;
                 skos:definition "A note about the past state/use/meaning of a concept."@en ;
                 rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
          rdfs:label "note"@en ;
          skos:definition "A general note, for any purpose."@en ;
          skos:scopeNote "This property may be used directly, or as a super-property for more specific note types."@en .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:comment "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@en ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@en ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@en ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               rdfs:label "preferred label"@en ;
               skos:definition "The preferred lexical label for a resource, in a given language."@en ;
               rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               rdfs:label "scope note"@en ;
               skos:definition "A note that helps to clarify the meaning and/or the use of a concept."@en ;
               rdfs:subPropertyOf skos:note .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#broadMatch
skos:broadMatch rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf skos:broader ,
                                   skos:mappingRelation ;
                owl:inverseOf skos:narrowMatch ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "has broader match"@en ;
                skos:definition "skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf skos:broaderTransitive ;
             owl:inverseOf skos:narrower ;
             rdfs:comment "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@en ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "has broader"@en ;
             skos:definition "Relates a concept to a concept that is more general in meaning."@en ;
             skos:scopeNote "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#broaderTransitive
skos:broaderTransitive rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf skos:semanticRelation ;
                       owl:inverseOf skos:narrowerTransitive ;
                       rdf:type owl:TransitiveProperty ;
                       rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                       rdfs:label "has broader transitive"@en ;
                       skos:definition "skos:broaderTransitive is a transitive superproperty of skos:broader." ;
                       skos:scopeNote "By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf skos:mappingRelation ;
                rdf:type owl:SymmetricProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "has close match"@en ;
                skos:definition "skos:closeMatch is used to link two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications. In order to avoid the possibility of \"compound errors\" when combining mappings across more than two concept schemes, skos:closeMatch is not declared to be a transitive property."@en .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf skos:closeMatch ;
                rdf:type owl:SymmetricProperty ,
                         owl:TransitiveProperty ;
                rdfs:comment "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@en ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "has exact match"@en ;
                skos:definition "skos:exactMatch is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. skos:exactMatch is a transitive property, and is a sub-property of skos:closeMatch."@en .


###  http://www.w3.org/2004/02/skos/core#hasTopConcept
skos:hasTopConcept rdf:type owl:ObjectProperty ;
                   owl:inverseOf skos:topConceptOf ;
                   rdfs:domain skos:ConceptScheme ;
                   rdfs:range skos:Concept ;
                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                   rdfs:label "has top concept"@en ;
                   skos:definition "Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies."@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty ;
              rdfs:range skos:ConceptScheme ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "is in scheme"@en ;
              skos:definition "Relates a resource (for example a concept) to a concept scheme in which it is included."@en ;
              skos:scopeNote "A concept may be a member of more than one concept scheme."@en .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
skos:mappingRelation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf skos:semanticRelation ;
                     rdfs:comment "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@en ;
                     rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                     rdfs:label "is in mapping relation with"@en ;
                     skos:definition "Relates two concepts coming, by convention, from different schemes, and that have comparable meanings"@en .


###  http://www.w3.org/2004/02/skos/core#member
skos:member rdf:type owl:ObjectProperty ;
            rdfs:domain skos:Collection ;
            rdfs:range [ rdf:type owl:Class ;
                         owl:unionOf ( skos:Collection
                                       skos:Concept
                                     )
                       ] ;
            rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
            rdfs:label "has member"@en ;
            skos:definition "Relates a collection to one of its members."@en .


###  http://www.w3.org/2004/02/skos/core#memberList
skos:memberList rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain skos:OrderedCollection ;
                rdfs:range rdf:List ;
                rdfs:comment """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@en ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "has member list"@en ;
                skos:definition "Relates an ordered collection to the RDF list containing its members."@en .


###  http://www.w3.org/2004/02/skos/core#narrowMatch
skos:narrowMatch rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf skos:mappingRelation ,
                                    skos:narrower ;
                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                 rdfs:label "has narrower match"@en ;
                 skos:definition "skos:narrowMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf skos:narrowerTransitive ;
              rdfs:comment "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@en ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "has narrower"@en ;
              skos:definition "Relates a concept to a concept that is more specific in meaning."@en ;
              skos:scopeNote "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#narrowerTransitive
skos:narrowerTransitive rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf skos:semanticRelation ;
                        rdf:type owl:TransitiveProperty ;
                        rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                        rdfs:label "has narrower transitive"@en ;
                        skos:definition "skos:narrowerTransitive is a transitive superproperty of skos:narrower." ;
                        skos:scopeNote "By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#related
skos:related rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf skos:semanticRelation ;
             rdf:type owl:SymmetricProperty ;
             rdfs:comment "skos:related is disjoint with skos:broaderTransitive"@en ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "has related"@en ;
             skos:definition "Relates a concept to a concept with which there is an associative semantic relationship."@en .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
skos:relatedMatch rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf skos:mappingRelation ,
                                     skos:related ;
                  rdf:type owl:SymmetricProperty ;
                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                  rdfs:label "has related match"@en ;
                  skos:definition "skos:relatedMatch is used to state an associative mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#semanticRelation
skos:semanticRelation rdf:type owl:ObjectProperty ;
                      rdfs:domain skos:Concept ;
                      rdfs:range skos:Concept ;
                      rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                      rdfs:label "is in semantic relation with"@en ;
                      skos:definition "Links a concept to a concept related by meaning."@en ;
                      skos:scopeNote "This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts."@en .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
skos:topConceptOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf skos:inScheme ;
                  rdfs:domain skos:Concept ;
                  rdfs:range skos:ConceptScheme ;
                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                  rdfs:label "is top concept in scheme"@en ;
                  skos:definition "Relates a concept to the concept scheme that it is a top level concept of."@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#notation
skos:notation rdf:type owl:DatatypeProperty ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "notation"@en ;
              skos:definition "A notation, also known as classification code, is a string of characters such as \"T58.5\" or \"303.4833\" used to uniquely identify a concept within the scope of a given concept scheme."@en ;
              skos:scopeNote "By convention, skos:notation is used with a typed literal in the object position of the triple."@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#List
rdf:List rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Collection
skos:Collection rdf:type owl:Class ;
                owl:disjointWith skos:Concept ,
                                 skos:ConceptScheme ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "Collection"@en ;
                skos:definition "A meaningful collection of concepts."@en ;
                skos:scopeNote "Labelled collections can be used where you would like a set of concepts to be displayed under a 'node label' in the hierarchy."@en .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             owl:disjointWith skos:ConceptScheme ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "Concept"@en ;
             skos:definition "An idea or notion; a unit of thought."@en .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class ;
                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                   rdfs:label "Concept Scheme"@en ;
                   skos:definition "A set of concepts, optionally including statements about semantic relationships between those concepts."@en ;
                   skos:example "Thesauri, classification schemes, subject heading lists, taxonomies, 'folksonomies', and other types of controlled vocabulary are all examples of concept schemes. Concept schemes are also embedded in glossaries and terminologies."@en ;
                   skos:scopeNote "A concept scheme may be defined to include concepts from different sources."@en .


###  http://www.w3.org/2004/02/skos/core#OrderedCollection
skos:OrderedCollection rdf:type owl:Class ;
                       rdfs:subClassOf skos:Collection ;
                       rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                       rdfs:label "Ordered Collection"@en ;
                       skos:definition "An ordered collection of concepts, where both the grouping and the ordering are meaningful."@en ;
                       skos:scopeNote "Ordered collections can be used where you would like a set of concepts to be displayed in a specific order, and optionally under a 'node label'."@en .


#################################################################
#    Individuals
#################################################################

###  https://www.michaeldebellis.com/glossary/ABox
:ABox rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      skos:related :Property ,
                   :Semantic_Knowledge_Graph ;
      rdfs:label "ABox"@en ;
      skos:definition "The individuals in a Semantic Knowledge Graph. Instances of classes with property values that point to other individuals as well as simple datatypes. Analogous to rows in a relational database and instances in Object-Oriented Programming. The A is for assertions and stands for the various specific property values for each instance."@en .


###  https://www.michaeldebellis.com/glossary/ACID
:ACID rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "ACID"@en ;
      skos:definition "ACID is an acronym that describes four key properties of reliable database transactions: Atomicity, Consistency, Isolation, and Durability. Atomicity ensures that a transaction is treated as a single unit that either fully succeeds or fully fails; Consistency guarantees that transactions move the system from one valid state to another according to defined rules; Isolation ensures that concurrent transactions do not interfere with one another; and Durability ensures that once a transaction is committed, its effects persist even in the event of system failure. ACID properties are foundational to relational database systems and transactional workloads. In the context of Semantic Knowledge Graphs and distributed data architectures, strict ACID guarantees are sometimes relaxed or complemented with other consistency models to support scalability, federation, and streaming data integration."@en .


###  https://www.michaeldebellis.com/glossary/Agile_Methods
:Agile_Methods rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:inScheme :Glossary ;
               rdfs:label "Agile Methods"@en ;
               skos:definition "Agile Methods are a family of iterative and incremental approaches to software and data-system development that emphasize collaboration, adaptability, and continuous delivery of value. Rather than relying on fixed, upfront specifications, agile methods prioritize short development cycles, frequent feedback, and the ability to respond to changing requirements. Common principles include close stakeholder involvement, working solutions over exhaustive documentation, and continuous improvement. In the context of Semantic Knowledge Graphs, agile methods support the gradual evolution of models and data—allowing ontologies, metadata, and integrations to mature incrementally as understanding of the domain improves."@en .


###  https://www.michaeldebellis.com/glossary/AllegroGraph
:AllegroGraph rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "AllegroGraph"@en ;
              skos:definition "AllegroGraph is a commercial graph database and triplestore optimized for storing, querying, and reasoning over large-scale Semantic Knowledge Graphs. Developed by Franz Inc., it provides native support for RDF, RDFS, OWL, and SPARQL, along with scalable reasoning, geospatial and temporal features, full-text search, and integration with programming languages such as Python and Java. AllegroGraph is designed to support enterprise-grade semantic applications, including data integration, governance, analytics, and knowledge-driven AI. In practice, it is often used as the core persistence and reasoning engine for production semantic systems."@en .


###  https://www.michaeldebellis.com/glossary/Amazon_Neptune
:Amazon_Neptune rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                skos:related :AllegroGraph ;
                rdfs:label "Amazon Neptune"@en ;
                skos:definition "Amazon Neptune is a fully managed cloud graph database service provided by Amazon Web Services that supports both RDF-based Semantic Knowledge Graphs and labeled property graphs. It offers native support for RDF and SPARQL, as well as property-graph models queried with Gremlin, and is designed for scalability, high availability, and integration with other AWS services. Amazon Neptune is commonly used to deploy graph applications without managing underlying infrastructure. In the context of Semantic Knowledge Graphs, Neptune can function as a hosted triplestore, though its reasoning and semantic capabilities are more limited than those of specialized semantic graph platforms."@en .


###  https://www.michaeldebellis.com/glossary/Annotation_Property
:Annotation_Property rdf:type owl:NamedIndividual ,
                              skos:Concept ;
                     skos:inScheme :Glossary ;
                     skos:related :Metadata ,
                                  :Property ;
                     rdfs:label "Annotation Property"@en ;
                     skos:definition "An annotation property is a property used to attach human-readable or descriptive metadata to ontology elements rather than to define domain semantics. Annotation properties are commonly used for labels, definitions, comments, and documentation, and they do not participate directly in logical reasoning or inference. Unlike datatype or object properties, annotation properties can be defined for entities other than Individuals which is why they are primarily used for metadata about an ontology."@en .


###  https://www.michaeldebellis.com/glossary/Apache_Hadoop
:Apache_Hadoop rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:inScheme :Glossary ;
               rdfs:label "Apache Hadoop"@en ;
               skos:definition "Hadoop is an open-source framework for distributed storage and processing of large-scale datasets across clusters of commodity hardware. It is best known for the Hadoop Distributed File System (HDFS), which provides fault-tolerant storage, and for batch-processing models such as MapReduce. Developed under the Apache Software Foundation, Hadoop was a foundational technology for early big-data architectures. In the context of Semantic Knowledge Graphs, Hadoop is often part of legacy or hybrid data platforms, where semantic models and metadata layers are introduced to impose structure, meaning, and governance over data stored and processed in large-scale distributed systems."@en .


###  https://www.michaeldebellis.com/glossary/Apache_Jena
:Apache_Jena rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             rdfs:label "Apache Jena"@en ;
             skos:definition "Apache Jena is an open-source framework for building Semantic Web and Semantic Knowledge Graph applications in Java. It provides APIs and tools for working with RDF graphs, ontologies expressed in OWL, and SPARQL queries and updates. Apache Jena includes components for in-memory and persistent storage, reasoning, inference, and dataset management, as well as the Fuseki SPARQL server for deploying RDF data as web-accessible services. Developed under the Apache Software Foundation, Apache Jena is widely used for prototyping and implementing semantic systems, particularly where tight integration with Java applications is required."@en .


###  https://www.michaeldebellis.com/glossary/Apache_Kafka
:Apache_Kafka rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "Apache Kafka"@en ;
              skos:definition "Kafka is a distributed event-streaming platform used to publish, store, and process streams of records in a scalable and fault-tolerant manner. Originally developed for high-throughput messaging, Kafka is widely used to support real-time data pipelines, event-driven architectures, and streaming analytics. Data is organized into topics, partitioned for scalability, and consumed by independent applications at their own pace. Developed under the Apache Software Foundation, Kafka plays a central role in modern data architectures. In the context of Semantic Knowledge Graphs, Kafka is often used to ingest events and operational data into semantic pipelines, where streaming data can be enriched with metadata, validated, and integrated with knowledge graphs in near real time."@en .


###  https://www.michaeldebellis.com/glossary/Axiom
:Axiom rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "Axiom"@en ;
       skos:definition "A logical expression that defines a class. We call these axioms because in logic an axiom is a logical expression asserted to be true without proof. Similarly, in OWL axioms are defined by the user and the reasoner then uses them to validate the model and to infer additional information based on the axioms."@en ;
       skos:prefLabel "Axiom"@en .


###  https://www.michaeldebellis.com/glossary/BFO_Basic_Formal_Ontology
:BFO_Basic_Formal_Ontology rdf:type owl:NamedIndividual ,
                                    skos:Concept ;
                           skos:inScheme :Glossary ;
                           rdfs:label "BFO (Basic Formal Ontology)"@en ;
                           skos:definition "BFO is a top-level ontology that provides a small, domain-independent set of categories intended to support the consistent integration of more specialized ontologies. It distinguishes fundamental types of entities—such as continuants and occurrents—and provides high-level principles for modeling objects, processes, qualities, and relations in a logically rigorous way. BFO is widely used in scientific and biomedical ontology development and is a core ontology within the OBO Foundry ecosystem. In the context of Semantic Knowledge Graphs, BFO is sometimes adopted as an upper ontology to promote interoperability and modeling discipline, though its abstract nature can make it less suitable for direct use in application-oriented or enterprise-focused semantic systems without additional adaptation."@en .


###  https://www.michaeldebellis.com/glossary/Backward_Chaining
:Backward_Chaining rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:inScheme :Glossary ;
                   skos:related :Forward_chaining ,
                                :Knowledge_Base ,
                                :Prolog ;
                   rdfs:label "Backward Chaining"@en ;
                   skos:definition "A rule-based system is 1) a collection of facts (a knowledge base) about the domain 2) a collection of rules and 3) an inference engine. The inference engine is the reasoning engine that executes the rules. There are two types of reasoning: forward chaining and backward chaining. Backward chaining starts from a goal or query and works backward, looking for rules whose consequents match the goal and then attempting to prove their antecedents. This approach is goal-driven and is commonly used when answering specific questions. Prolog is a widely used language that primarily uses backward chaining."@en .


###  https://www.michaeldebellis.com/glossary/Bounded_Context
:Bounded_Context rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:broader :Domain_Driven_Design_DDD ;
                 skos:inScheme :Glossary ;
                 rdfs:label "Bounded Context"@en ;
                 skos:definition "a concept from Domain-Driven Design (DDD) that defines a clear boundary within which a particular domain model, vocabulary, and set of assumptions are valid and consistently used. Within a bounded context, terms have precise meanings and models are internally coherent, while the same terms may have different meanings in other contexts. By explicitly defining these boundaries, bounded contexts reduce ambiguity, limit coupling between systems, and enable teams to evolve models independently while integrating with other contexts through well-defined interfaces or translation mechanisms."@en .


###  https://www.michaeldebellis.com/glossary/CAP_Theorem
:CAP_Theorem rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             rdfs:label "CAP Theorem"@en ;
             skos:definition "The CAP Theorem states that a distributed data system cannot simultaneously guarantee Consistency, Availability, and Partition Tolerance; at most, it can fully satisfy two of the three at any given time. Consistency means all clients see the same data at the same time, Availability means every request receives a response, and Partition Tolerance means the system continues to operate despite network failures between nodes. Because network partitions are unavoidable in distributed systems, real-world architectures must tradeoff between consistency and availability. In the context of modern data platforms and Semantic Knowledge Graphs, CAP informs design decisions about replication, sharding, and consistency models, particularly when deploying graph systems across distributed or cloud environments."@en .


###  https://www.michaeldebellis.com/glossary/CI-CD
:CI-CD rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       dcterms:created "2026-05-06T20:00:15Z"^^xsd:dateTime ;
       dcterms:creator "Michael DeBellis" ;
       rdfs:label "CI/CD"@en ;
       skos:definition "CI/CD (Continuous Integration / Continuous Delivery or Continuous Deployment) is a set of software engineering practices that automate the building, testing, validation, and deployment of applications and data pipelines. Continuous Integration (CI) focuses on frequently merging changes into a shared codebase and automatically running tests to detect problems early. Continuous Delivery/Deployment (CD) extends this process by automating the release of validated changes into staging or production environments. CI/CD pipelines improve reliability, repeatability, and development speed by reducing manual deployment steps and enabling rapid feedback. In the context of Semantic Knowledge Graphs, CI/CD pipelines often include ontology validation, SHACL checks, SPARQL regression tests, and automated deployment of graph schemas, ingestion workflows, and semantic services." .


###  https://www.michaeldebellis.com/glossary/CQRS
:CQRS rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "CQRS"@en ;
      skos:definition "CQRS (Command Query Responsibility Segregation) is an architectural pattern from Domain-Driven Design that separates operations that change system state (commands) from operations that read system state (queries). Commands perform actions and typically return no data other than success or failure, while queries retrieve data without causing side effects. This separation allows each side to be optimized independently—for example, enforcing strict validation and consistency on the command side while enabling flexible, read-optimized models on the query side. In data- and event-centric architectures, CQRS is often paired with event streaming and data products. In the context of Semantic Knowledge Graphs, CQRS aligns naturally with architectures where write models (ingestion, validation, governance) are distinct from read models (querying, analytics, and semantic access)."@en .


###  https://www.michaeldebellis.com/glossary/CRM
:CRM rdf:type owl:NamedIndividual ,
              skos:Concept ;
     skos:inScheme :Glossary ;
     rdfs:label "CRM"@en ;
     skos:definition "CRM (Customer Relationship Management) refers to software systems and processes used to manage an organization’s interactions with customers and prospects across sales, marketing, and customer service. CRM systems store and organize data such as customer profiles, interactions, transactions, and communication history, typically within an application-specific data model. While CRMs provide a unified operational view of customer relationships, their semantics are often implicit and tailored to the vendor’s schema. In the context of Semantic Knowledge Graphs, CRM data is commonly integrated with other enterprise sources and enriched with explicit semantic models to support cross-domain analytics, interoperability, and a more consistent understanding of customer-related concepts."@en .


###  https://www.michaeldebellis.com/glossary/CRUD
:CRUD rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "CRUD"@en ;
      skos:definition "CRUD is an acronym for Create, Read, Update, and Delete, representing the four fundamental operations performed on persistent data in most information systems. It originates from database and application design and provides a basic model for interacting with stored entities. CRUD operations are typically implemented uniformly across data structures, emphasizing simplicity and consistency. In the context of modern architectures—such as Domain-Driven Design, data products, and Semantic Knowledge Graphs—CRUD is often contrasted with more expressive patterns (such as CQRS), as CRUD-centric designs can obscure domain semantics and business intent by treating all data changes as generic operations rather than meaningful domain actions."@en .


###  https://www.michaeldebellis.com/glossary/Class
:Class rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "Class"@en ;
       skos:definition "A class in the Web Ontology Language (OWL) represents a set of individuals that share common characteristics. It's analogous to a category or a type, like Person or City, and is used to group entities with similar properties. OWL classes form the backbone of an ontology's logical structure and support reasoning about class membership and relationships. The semantics for an OWL class are the same as the semantics for a set in logic and set theory."@en .


###  https://www.michaeldebellis.com/glossary/Conceptual_Model
:Conceptual_Model rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:inScheme :Glossary ;
                  rdfs:label "Conceptual Model"@en ;
                  skos:definition "A Conceptual Model is an abstract representation of a domain that captures the key concepts, relationships, and constraints independent of any technical implementation. A conceptual model focuses on what exists in the domain and how those elements relate, rather than how they are stored, processed, or implemented in software. In semantic systems, conceptual models are often expressed using ontology constructs such as classes and relationships, and they serve as a stable foundation for downstream design, implementation, and integration activities."@en .


###  https://www.michaeldebellis.com/glossary/DCAT
:DCAT rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "DCAT"@en ;
      skos:definition "DCAT (Data Catalog Vocabulary) is a W3C standard ontology for describing datasets, data services, and data catalogs in a consistent, machine-readable way. It defines core concepts such as datasets, distributions, data services, and catalogs, along with properties for metadata including access methods, formats, publishers, and licensing. DCAT is widely used to support data discovery and interoperability across organizations and platforms. In the context of Semantic Knowledge Graphs, DCAT is commonly combined with domain ontologies and metadata standards such as DCMI Metadata Terms to provide a structured, semantically precise foundation for data catalogs and data-product descriptions."@en .


###  https://www.michaeldebellis.com/glossary/DCMI_Metadata_Terms
:DCMI_Metadata_Terms rdf:type owl:NamedIndividual ,
                              skos:Concept ;
                     skos:inScheme :Glossary ;
                     rdfs:label "DCMI Metadata Terms"@en ;
                     skos:definition "DCMI Metadata Terms (often referred to as Dublin Core Terms or DCTERMS) are a standardized set of metadata properties and classes maintained by the Dublin Core Metadata Initiative (DCMI) for describing resources such as documents, datasets, services, and digital artifacts. They extend the original Dublin Core Metadata Element Set with more precise semantics, including refinements, encoding schemes, and additional properties for provenance, rights, dates, and relationships. DCMI Metadata Terms are widely used across data catalogs, repositories, and Semantic Knowledge Graphs to provide consistent, interoperable descriptive metadata. In semantic systems, they are commonly combined with domain ontologies to supply cross-cutting metadata for identification, attribution, lifecycle management, and governance."@en .


###  https://www.michaeldebellis.com/glossary/Data_Fabric
:Data_Fabric rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             rdfs:label "Data Fabric"@en ;
             skos:definition "A Data Fabric is a data-architecture approach that emphasizes centralized integration, governance, and consistency across distributed data systems through shared services, metadata, and automation. Rather than distributing ownership of data products to domain teams, a data fabric focuses on providing common infrastructure for data discovery, integration, quality, security, and lifecycle management. It relies heavily on metadata—often active metadata—to enable orchestration, policy enforcement, and intelligent data access across heterogeneous platforms. In the context of Semantic Knowledge Graphs, a data fabric commonly uses shared semantic models and knowledge graphs to provide a unified view of enterprise data, supporting cross-domain queries, governance, and compliance while allowing underlying systems to remain operationally independent."@en .


###  https://www.michaeldebellis.com/glossary/Data_Lake
:Data_Lake rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           skos:related :Data_Warehouse ;
           rdfs:label "Data Lake"@en ;
           skos:definition "A Data Lake is a centralized repository designed to store large volumes of raw or minimally processed data in its native formats, including structured, semi-structured, and unstructured data. Data lakes prioritize scalability and flexibility, allowing data to be ingested before its exact usage is known. While this approach supports exploratory analytics and machine learning, it often leads to challenges such as inconsistent semantics, poor data quality, and limited governance if not carefully managed. In the context of Semantic Knowledge Graphs, data lakes are frequently augmented with semantic models and metadata to provide structure, meaning, and governance—sometimes evolving into more semantically enriched architectures that mitigate the risks commonly associated with unmanaged “data swamps.”"@en .


###  https://www.michaeldebellis.com/glossary/Data_Mesh
:Data_Mesh rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "Data Mesh"@en ;
           skos:definition "A Data Mesh is a decentralized data-architecture and organizational approach in which data is treated as a product and ownership is distributed to domain-aligned teams rather than centralized in a single data platform team. Each domain is responsible for producing, maintaining, and governing its own data products, including their schemas, semantics, quality, and documentation. Data Mesh emphasizes domain-driven design, federated governance, and self-serve infrastructure, allowing teams to evolve their data independently while adhering to shared standards. In the context of Semantic Knowledge Graphs, Data Mesh benefits from explicit semantic models and shared vocabularies, which enable interoperability and consistent meaning across independently developed data products without requiring central control over their implementation."@en .


###  https://www.michaeldebellis.com/glossary/Data_Port
:Data_Port rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "Data Port"@en ;
           skos:definition "A Data Port is a formally defined interface through which a data product exposes or consumes data, metadata, or services. It specifies how a data product can be accessed or integrated—such as through files, APIs, queries, or event streams—without exposing internal implementation details. Data ports provide a clear contract that includes access method, structure, semantics, and applicable governance constraints. In a data-product architecture, ports enable interoperability between products and bounded contexts while supporting independent evolution. When combined with Semantic Knowledge Graphs, data ports are often described using explicit semantic models, allowing their inputs, outputs, and constraints to be understood and validated consistently across the enterprise."@en .


###  https://www.michaeldebellis.com/glossary/Data_Product
:Data_Product rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:broader :Domain_Driven_Design_DDD ;
              skos:inScheme :Glossary ;
              rdfs:label "Data Product"@en ;
              skos:definition "A data product is an organizationally owned data artifact, produced and maintained by a domain, that is intentionally designed for consumption, governed by explicit policies, and exposed through one or more standardized interfaces."@en .


###  https://www.michaeldebellis.com/glossary/Data_Warehouse
:Data_Warehouse rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                rdfs:label "Data Warehouse"@en ;
                skos:definition "A Data Warehouse is a centralized, structured data repository optimized for reporting, analytics, and decision support. Data is typically extracted from multiple operational systems, transformed to conform to a predefined schema, and loaded into the warehouse using batch-oriented processes. Data warehouses emphasize consistency, historical tracking, and performance for analytical queries, but are relatively inflexible when requirements or data sources change. In the context of Semantic Knowledge Graphs, data warehouses represent a contrasting approach in which meaning is largely implicit in schema design, whereas semantic models make meaning explicit and extensible, enabling greater interoperability and adaptability across evolving data ecosystems."@en .


###  https://www.michaeldebellis.com/glossary/Datatype_Property
:Datatype_Property rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:inScheme :Glossary ;
                   skos:related :Literal ,
                                :Property ;
                   rdfs:label "Datatype Property"@en ;
                   skos:definition "A datatype property is a property whose values are literals, such as strings, numbers, dates, or other concrete data values defined by XML Schema datatypes. Datatype properties are typically used to represent attributes or descriptive fields of a resource, such as names, identifiers, or timestamps."@en .


###  https://www.michaeldebellis.com/glossary/Description_Logic
:Description_Logic rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:inScheme :Glossary ;
                   rdfs:label "Description Logic"@en ;
                   skos:definition "Description Logic (DL) is a family of formal knowledge-representation languages used to define and reason about the concepts, relationships, and constraints of a domain in a logically precise way. It is based on fragments of first-order logic that balance expressive power with decidable and efficient reasoning. Description logics provide constructors for defining classes (concepts), properties (roles), and individuals, along with axioms that specify subclass relationships, equivalence, disjointness, and property restrictions. In the context of Semantic Knowledge Graphs, description logic forms the formal foundation of the Web Ontology Language (OWL), enabling automated reasoning to infer implicit knowledge, check consistency, and validate models against their intended meaning."@en ;
                   skos:prefLabel "Description Logic"@en .


###  https://www.michaeldebellis.com/glossary/Design_Model
:Design_Model rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "Design Model"@en ;
              skos:definition "a more detailed and technically oriented representation derived from a conceptual model, specifying how domain concepts and relationships will be realized in a concrete system. A design model incorporates implementation-relevant details such as constraints, validation rules, data shapes, and integration considerations, while still remaining independent of specific runtime code. In semantic knowledge graph development, the design model often refines OWL-based conceptual models using technologies such as SHACL and SPARQL to support data validation, quality checks, and system interoperability."@en .


###  https://www.michaeldebellis.com/glossary/Docker
:Docker rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "Docker"@en ;
        skos:definition "Docker is a containerization platform that packages applications and their dependencies into lightweight, portable containers that can run consistently across different environments. Containers isolate software components while sharing the host operating system, enabling faster deployment, scalability, and reproducibility compared to traditional virtual machines. Developed by Docker, Docker is widely used in modern software and data architectures. In the context of Semantic Knowledge Graphs, Docker is commonly used to deploy triplestores, reasoning engines, ingestion pipelines, and supporting services as modular components that can be versioned, orchestrated, and managed consistently across development and production environments."@en .


###  https://www.michaeldebellis.com/glossary/Domain_Driven_Design_DDD
:Domain_Driven_Design_DDD rdf:type owl:NamedIndividual ,
                                   skos:Concept ;
                          skos:inScheme :Glossary ;
                          rdfs:label "Domain-Driven Design (DDD)"@en ;
                          skos:definition "Domain-Driven Design (DDD) is a software design approach that emphasizes modeling software systems around the core business domain and the concepts used by domain experts. DDD promotes the development of a shared, precise vocabulary (known as the ubiquitous language) that is consistently reflected in models, code, and documentation. By structuring systems around bounded contexts and aligning technical design with domain semantics, DDD aims to manage complexity, improve communication between technical and non-technical stakeholders, and support the long-term evolution of large, complex systems."@en .


###  https://www.michaeldebellis.com/glossary/ERP
:ERP rdf:type owl:NamedIndividual ,
              skos:Concept ;
     skos:inScheme :Glossary ;
     rdfs:label "ERP"@en ;
     skos:definition "ERP (Enterprise Resource Planning) refers to integrated software systems designed to manage and automate core business processes across an organization, such as finance, human resources, supply chain, manufacturing, and procurement. ERP systems typically rely on centralized data models and transactional databases to ensure consistency and operational efficiency across departments. While ERPs provide strong process integration, their schemas and semantics are often tightly coupled to specific applications and vendors. In the context of Semantic Knowledge Graphs, ERP systems are commonly treated as authoritative data sources whose data is semantically integrated, enriched, and contextualized to enable interoperability, analytics, and governance beyond the boundaries of the ERP itself."@en .


###  https://www.michaeldebellis.com/glossary/Enrichment
:Enrichment rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            skos:related :Metadata ;
            rdfs:label "Enrichment"@en ;
            skos:definition "the process of augmenting existing data with additional meaning, structure, or inferred knowledge beyond what was explicitly provided at ingestion time. In semantic systems, enrichment commonly includes activities such as reasoning to derive implicit facts, linking entities to external vocabularies or datasets, adding classifications, tags, or metadata, and generating embeddings or other analytical features. Enrichment increases the value, usability, and analytical power of a knowledge graph without requiring changes to the original source data."@en .


###  https://www.michaeldebellis.com/glossary/Entity
:Entity rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "Entity"@en ;
        skos:definition "Anything in the ontology. A Class, Property, or Individual. Note: not the same as in Entity/Relation modeling."@en .


###  https://www.michaeldebellis.com/glossary/FIBO
:FIBO rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "FIBO"@en ;
      skos:definition "FIBO (the Financial Industry Business Ontology) is a comprehensive, open standard ontology for the financial services industry that provides formally defined concepts, relationships, and constraints covering areas such as securities, organizations, contracts, indices, and market data. It is developed and maintained by the EDM Council and is grounded in formal semantics based on OWL. FIBO is used to promote semantic interoperability, regulatory transparency, and consistent meaning across financial systems. In the context of Semantic Knowledge Graphs, FIBO serves as a domain ontology that can be integrated with enterprise data to support governance, analytics, and compliance through shared, machine-interpretable definitions."@en .


###  https://www.michaeldebellis.com/glossary/First_Order_Logic
:First_Order_Logic rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:inScheme :Glossary ;
                   rdfs:label "First-Order Logic"@en ;
                   skos:definition "First-Order Logic (FOL). First-Order Logic is a formal logical system used to represent facts, relationships, and rules about a domain using predicates, variables, quantifiers, and logical connectives. It allows statements about individual objects (such as “for all” or “there exists”) but not about predicates or sets themselves. First-order logic provides a precise mathematical foundation for reasoning, enabling conclusions to be derived deductively from stated premises. In the context of Semantic Knowledge Graphs, FOL underpins the formal semantics of ontology languages such as OWL, although OWL deliberately restricts full first-order expressiveness to ensure decidable and computationally tractable reasoning."@en .


###  https://www.michaeldebellis.com/glossary/Folksonomy
:Folksonomy rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Folksonomy"@en ;
            skos:definition "A Folksonomy is an informal system of classification that emerges from user-generated tags rather than from a centrally defined vocabulary or hierarchy. Tags are typically applied freely by individuals to describe or organize content according to personal or local understanding, without enforced structure or semantics. Folksonomies are flexible and easy to adopt but often suffer from ambiguity, inconsistency, and synonymy. In the context of Semantic Knowledge Graphs, folksonomies are often treated as a preliminary or complementary artifact that can inform the development of more structured knowledge organization systems—such as glossaries, taxonomies, or ontologies—through analysis, normalization, and semantic refinement."@en .


###  https://www.michaeldebellis.com/glossary/Forward_chaining
:Forward_chaining rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:inScheme :Glossary ;
                  skos:related :Knowledge_Base ,
                               :OWL ,
                               :Rule ;
                  rdfs:label "Forward chaining"@en ;
                  skos:definition "Forward chaining starts from known facts in the knowledge base and repeatedly applies rules whose antecedents are satisfied, adding their consequents as new facts. This approach is data-driven and is often used when all possible inferences are to be derived from a knowledge base. The Semantic Web Rule system (SWRL) utilizes forward chaining and is part of the OWL specification."@en .


###  https://www.michaeldebellis.com/glossary/GDPR
:GDPR rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      dcterms:created "2026-05-06T19:58:56Z"^^xsd:dateTime ;
      dcterms:creator "Michael DeBellis" ;
      rdfs:label "GDPR"@en ;
      skos:definition "GDPR (General Data Protection Regulation) is a European Union regulation governing the collection, processing, storage, and sharing of personal data. It establishes strict requirements for transparency, consent, data minimization, security, and the rights of individuals—including the rights to access, correct, and delete their personal data. GDPR applies not only to organizations within the European Union but also to organizations that process the data of EU residents. In the context of Semantic Knowledge Graphs, GDPR compliance often requires explicit modeling of provenance, consent, data lineage, retention policies, and access controls so that personal data can be governed, audited, and managed consistently across distributed systems and data products."@en .


###  https://www.michaeldebellis.com/glossary/Gist
:Gist rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "Gist"@en ;
      skos:definition "Gist is a lightweight, reusable upper ontology designed to provide a small set of well-defined, domain-independent concepts for building enterprise Semantic Knowledge Graphs. Developed by Semantic Arts, Gist focuses on practical modeling needs rather than exhaustive philosophical coverage, offering core classes and properties for time, identity, agents, events, and relationships. It is intended to serve as a semantic foundation that domain ontologies can extend while remaining comprehensible and implementable in real-world systems. In the context of Semantic Knowledge Graphs, Gist is often used as a pragmatic alternative to more abstract upper ontologies, supporting interoperability and modeling consistency without imposing excessive conceptual overhead."@en .


###  https://www.michaeldebellis.com/glossary/Glossary
:Glossary rdf:type owl:NamedIndividual ,
                   skos:ConceptScheme ;
          skos:inScheme :Glossary ;
          dcterms:description "Glossary for the book."@en ;
          rdfs:label "Glossary"@en ;
          skos:definition "A Glossary is a curated collection of terms and their definitions that establishes a shared vocabulary within a specific domain or context. Its primary purpose is to reduce ambiguity by making explicit how key terms are used, particularly when words have multiple meanings across disciplines or communities. Glossaries are typically informal or semi-formal, focusing on human-readable definitions rather than formal semantics. In the context of Semantic Knowledge Graphs, a glossary often serves as an initial artifact in requirements or conceptual modeling and can be represented using standards such as SKOS, providing a foundation from which taxonomies and ontologies may later be developed."@en .


###  https://www.michaeldebellis.com/glossary/Governance
:Governance rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Governance"@en ;
            skos:definition "Governance is the set of policies, roles, processes, and technical controls that ensure data and knowledge assets are managed responsibly, consistently, and in compliance with organizational and regulatory requirements. It defines how decisions about data ownership, quality, access, security, and lifecycle are made and enforced. In the context of Semantic Knowledge Graphs, governance is not a separate, final step but a continuous, model-driven capability embedded throughout the data lifecycle. Semantic models, constraints, and provenance metadata enable governance by design, allowing rules for access control, validation, lineage, and accountability to be expressed explicitly and applied automatically across distributed systems."@en .


###  https://www.michaeldebellis.com/glossary/GraphQL
:GraphQL rdf:type owl:NamedIndividual ,
                  skos:Concept ;
         dcterms:created "2026-05-07T02:05:44Z"^^xsd:dateTime ;
         dcterms:creator "Michael DeBellis" ;
         rdfs:label "GraphQL"@en ;
         skos:definition "GraphQL is a query language and API specification for requesting and manipulating data through a flexible, strongly typed interface. Originally developed by Meta Platforms, GraphQL allows clients to specify exactly what data they need rather than relying on fixed server-defined responses, reducing over-fetching and under-fetching common in REST-based APIs. GraphQL APIs expose data through a schema that defines available object types, fields, and relationships. Despite its name, GraphQL is not inherently a graph database or semantic technology; it is an API query language that can be implemented over relational databases, property graphs, Semantic Knowledge Graphs, or other data sources. In the context of Semantic Knowledge Graphs, GraphQL is often used as an application-facing access layer that complements SPARQL by providing a developer-friendly interface for consuming semantically integrated data."@en .


###  https://www.michaeldebellis.com/glossary/Graphwise
:Graphwise rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "Graphwise"@en ;
           skos:definition "Graphwise is a commercial knowledge-graph and semantic-AI platform that provides tools for building, managing, and operationalizing Semantic Knowledge Graphs and graph-based analytics. Developed by Graphwise, the platform emphasizes enterprise use cases such as data integration, metadata management, and graph-enhanced AI, including retrieval-augmented generation (RAG). Graphwise supports ontology-driven modeling, semantic enrichment, and scalable graph querying, positioning Semantic Knowledge Graphs as a foundation for interoperable data products and intelligent applications."@en .


###  https://www.michaeldebellis.com/glossary/HIPAA
:HIPAA rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       dcterms:created "2026-05-06T19:57:42Z"^^xsd:dateTime ;
       dcterms:creator "Michael DeBellis" ;
       rdfs:label "HIPAA"@en ;
       skos:definition "HIPAA (Health Insurance Portability and Accountability Act) is a United States federal law that establishes standards for protecting sensitive health information and regulating how medical data is stored, accessed, and shared. HIPAA includes privacy, security, and breach-notification requirements for healthcare providers, insurers, and related organizations that handle protected health information (PHI). Compliance typically involves access controls, auditing, encryption, and governance policies. In the context of Semantic Knowledge Graphs, HIPAA requirements often influence ontology design, metadata governance, provenance tracking, and fine-grained access control to ensure that healthcare and patient-related data is managed securely and in accordance with regulatory obligations."@en .


###  https://www.michaeldebellis.com/glossary/HTML_Hypertext_Markup_Language
:HTML_Hypertext_Markup_Language rdf:type owl:NamedIndividual ,
                                         skos:Concept ;
                                skos:inScheme :Glossary ;
                                rdfs:label "HTML (Hypertext Markup Language)"@en ;
                                skos:definition "the standard markup language used to structure and present content on the World Wide Web. HTML represents documents as a hierarchy of elements, such as headings, paragraphs, links, images, and forms, which browsers interpret to render web pages for human users. By combining a simple, declarative syntax with hyperlinks that connect documents across the Web, HTML provides the foundational structure on which web applications and interactive behaviors implemented with scripting languages are built."@en .


###  https://www.michaeldebellis.com/glossary/Horizontal_Scaling
:Horizontal_Scaling rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:inScheme :Glossary ;
                    rdfs:label "Horizontal Scaling"@en ;
                    skos:definition "Horizontal Scaling (also called scale out) is an approach to increasing system capacity by adding more machines or nodes and distributing data and workload across them. This method supports greater scalability, fault tolerance, and availability than scaling a single machine, making it well suited to large, distributed systems. Horizontal scaling typically relies on techniques such as sharding, replication, and load balancing. In the context of Semantic Knowledge Graphs, horizontal scaling enables large graphs and high query throughput, but it also introduces challenges for global queries and reasoning that require coordination across distributed data."@en .


###  https://www.michaeldebellis.com/glossary/IRI_Internationalized_Resource_Identifier
:IRI_Internationalized_Resource_Identifier rdf:type owl:NamedIndividual ,
                                                    skos:Concept ;
                                           skos:inScheme :Glossary ;
                                           skos:related :Individual ;
                                           rdfs:label "IRI (Internationalized Resource Identifier)"@en ;
                                           skos:definition "a W3C standard identifier used to uniquely name and reference resources in semantic and web-based systems. An IRI is a generalized form of a URI that allows the full range of Unicode characters, making it possible to represent identifiers using characters from many natural languages rather than being limited to ASCII. In RDF and related Semantic Web technologies, IRIs are used to identify classes, properties, individuals, and vocabularies in a globally unambiguous way, enabling data from different sources to be linked and interpreted consistently across systems. An IRI looks similar to a URL. URLs are a type of IRI."@en .


###  https://www.michaeldebellis.com/glossary/Implementation
:Implementation rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                rdfs:label "Implementation"@en ;
                skos:definition "the concrete realization of a design model in a working system, where models are instantiated using specific technologies, tools, and configurations. In the context of semantic knowledge graphs, implementation includes activities such as loading data into a triplestore, configuring reasoning and validation engines, integrating with programming languages or APIs, and building data pipelines that populate and maintain the graph. Implementation translates abstract and design-level decisions into executable artifacts that operate within a particular technical environment."@en .


###  https://www.michaeldebellis.com/glossary/Individual
:Individual rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Individual"@en ;
            skos:definition "An instance of one or more OWL classes. Individuals are analogous to instances in Object-Oriented Programming (OOP) and rows in relational databases."@en .


###  https://www.michaeldebellis.com/glossary/Iterative_Development
:Iterative_Development rdf:type owl:NamedIndividual ,
                                skos:Concept ;
                       skos:narrower :Agile_Methods ;
                       dcterms:contributor "Michael DeBellis" ;
                       dcterms:created "2026-02-08T02:00:52Z"^^xsd:dateTime ;
                       rdfs:label "Iterative Development"@en .


###  https://www.michaeldebellis.com/glossary/Knowledge_Base
:Knowledge_Base rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                rdfs:label "Knowledge Base"@en ;
                skos:definition "A file or database storage mechanism used to store information modeled in a Very High Level Language such as OWL or Prolog."@en .


###  https://www.michaeldebellis.com/glossary/Knowledge_Graph
:Knowledge_Graph rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:inScheme :Glossary ;
                 skos:related :Semantic_Knowledge_Graph ;
                 rdfs:label "Knowledge Graph"@en ;
                 skos:definition "Data stored in a graph data format including RDF, RDF-star, property graphs and semantic knowledge graphs."@en .


###  https://www.michaeldebellis.com/glossary/Knowledge_Representation
:Knowledge_Representation rdf:type owl:NamedIndividual ,
                                   skos:Concept ;
                          skos:inScheme :Glossary ;
                          rdfs:label "Knowledge Representation"@en ;
                          skos:definition "Knowledge Representation is the area of artificial intelligence concerned with how information about a domain can be formally structured so that it can be stored, queried, and reasoned over by a computer system. It focuses on choosing representations—such as symbols, graphs, rules, or logical statements—that capture meaning in a way that supports inference and explanation. Different approaches emphasize different trade-offs between expressiveness, computational tractability, and ease of use. In the context of Semantic Knowledge Graphs, knowledge representation is realized through formal semantic models—particularly ontologies defined in OWL—that make assumptions, relationships, and constraints explicit and machine-interpretable rather than implicit in application code or data schemas."@en .


###  https://www.michaeldebellis.com/glossary/Labelled_Property_Graphs
:Labelled_Property_Graphs rdf:type owl:NamedIndividual ,
                                   skos:Concept ;
                          skos:inScheme :Glossary ;
                          rdfs:label "Labelled Property Graphs"@en ;
                          skos:definition "A type of knowledge graph that explicitly models edges in a graph rather than having implicit edges as RDF triples do."@en .


###  https://www.michaeldebellis.com/glossary/Landing_Zone
:Landing_Zone rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "Landing Zone"@en ;
              skos:definition "A Landing Zone is a preconfigured, secure cloud environment that provides the foundational infrastructure, policies, and governance needed to deploy and operate systems at scale. It typically includes standardized configurations for networking, identity and access management, security controls, monitoring, and compliance. Landing zones are designed to enforce organizational standards while enabling teams to provision resources efficiently and consistently. In the context of Semantic Knowledge Graphs and data platforms, a landing zone establishes the controlled environment in which data pipelines, triplestores, and related services are deployed, supporting governance and security from the outset rather than as an afterthought."@en .


###  https://www.michaeldebellis.com/glossary/Large_Language_Model
:Large_Language_Model rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:inScheme :Glossary ;
                      rdfs:label "Large Language Model"@en ;
                      skos:definition "Large Language Model (LLM). A Large Language Model is a machine-learning model trained on vast amounts of text data to predict and generate natural language based on statistical patterns. LLMs use deep neural network architectures—typically transformer-based—to model relationships between words, phrases, and concepts across long contexts. They are capable of tasks such as text generation, summarization, translation, and question answering, but they do not possess explicit, formal knowledge or guaranteed logical consistency. In the context of Semantic Knowledge Graphs, LLMs are often combined with structured semantic data—such as through retrieval-augmented generation—to compensate for their lack of explicit semantics, improve accuracy, and ground generated responses in authoritative knowledge."@en .


###  https://www.michaeldebellis.com/glossary/Lexical_Vocabulary
:Lexical_Vocabulary rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:inScheme :Glossary ;
                    skos:related :Vocabulary ;
                    rdfs:label "Lexical Vocabulary"@en ;
                    skos:definition "A lexical vocabulary is a curated list of approved terms used to ensure consistency in naming and categorization of a domain. It resolves synonyms, near-duplicates, and ambiguous labels, providing a shared language for both human stakeholders and downstream systems. Lexical vocabularies are typically just called vocabularies; however, vocabulary has a related but different definition in regard to Semantic Knowledge Graphs, hence in this book the term Lexical Vocabulary is used to distinguish from ontology vocabulary."@en .


###  https://www.michaeldebellis.com/glossary/Literal
:Literal rdf:type owl:NamedIndividual ,
                  skos:Concept ;
         skos:inScheme :Glossary ;
         rdfs:label "Literal"@en ;
         skos:definition "The most general kind of non-class datatype. What owl:Thing is to classes, rdfs:Literal is to datatypes such as xsd:string and xsd:integer."@en .


###  https://www.michaeldebellis.com/glossary/Machine_Learning
:Machine_Learning rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:inScheme :Glossary ;
                  rdfs:label "Machine Learning"@en ;
                  skos:definition "Machine Learning (ML) is a field of artificial intelligence concerned with building systems that learn patterns from data in order to make predictions or decisions without being explicitly programmed with task-specific rules. Machine-learning models infer statistical regularities from training data and generalize them to new inputs, supporting tasks such as classification, clustering, and regression. While machine learning excels at pattern recognition and approximation, it typically lacks explicit representations of meaning or intent. In the context of Semantic Knowledge Graphs, machine learning is often combined with semantic models to integrate statistical inference with explicit knowledge, enabling systems that are both adaptive and semantically grounded."@en .


###  https://www.michaeldebellis.com/glossary/Metadata
:Metadata rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:inScheme :Glossary ;
          rdfs:label "Metadata"@en ;
          skos:definition "data that describes, explains, or provides context about other data, making it easier to understand, manage, and use. Metadata can include information such as meaning, structure, origin, ownership, quality, access rights, and lifecycle status of data assets. In semantic systems, metadata is often modeled explicitly using standard vocabularies, enabling consistent interpretation, governance, discovery, and integration of data across tools, teams, and organizations."@en .


###  https://www.michaeldebellis.com/glossary/Microservice
:Microservice rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "Microservice"@en ;
              skos:definition "A Microservice is an independently deployable software component that implements a well-defined business capability and communicates with other components through explicit, lightweight interfaces, typically over network APIs. Microservices are designed to be loosely coupled, enabling teams to develop, deploy, and scale services independently. Each microservice encapsulates its own logic and data, aligning closely with domain-driven design and bounded contexts. In data-centric architectures, microservices often act as producers or consumers of data products, and when combined with Semantic Knowledge Graphs, their interfaces and data exchanges can be described semantically to improve interoperability, governance, and integration across distributed systems."@en ;
              skos:prefLabel "Microservice"@en .


###  https://www.michaeldebellis.com/glossary/Mono_hierarchy
:Mono_hierarchy rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                rdfs:label "Mono-hierarchy"@en ;
                skos:definition "A class model that does not use multiple inheritance, where each class has exactly one superclass."@en .


###  https://www.michaeldebellis.com/glossary/Moores_Law
:Moores_Law rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Moore’s Law"@en ;
            skos:definition "Moore’s Law is the empirical observation, originally articulated by Gordon Moore, that the number of transistors on an integrated circuit—and thus the potential computing power available at a given cost—tends to double approximately every 18 to 24 months. For several decades, this trend held remarkably well and drove exponential improvements in performance and cost efficiency across the computing industry. In recent years, however, Moore’s Law has slowed significantly as transistor miniaturization approaches fundamental physical limits related to heat dissipation, quantum effects, and manufacturing precision. Continued performance gains now come less from transistor scaling and more from architectural innovations such as parallelism, specialized accelerators, and distributed systems. In the context of modern data platforms and AI systems, this shift helps explain the growing importance of scalable architectures, software optimization, and semantic technologies rather than reliance on raw hardware improvements alone."@en .


###  https://www.michaeldebellis.com/glossary/Multiple_inheritance
:Multiple_inheritance rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:inScheme :Glossary ;
                      rdfs:label "Multiple inheritance"@en ;
                      skos:definition "A model where a class can have more than one superclass. The opposite of a mono-hierarchy."@en .


###  https://www.michaeldebellis.com/glossary/OBO_Foundry
:OBO_Foundry rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             rdfs:label "OBO Foundry"@en ;
             skos:definition "The OBO Foundry is a collaborative initiative that promotes the development of interoperable, logically well-defined ontologies for the biological and biomedical sciences. It establishes a set of shared principles—such as openness, formal semantics, reuse, and orthogonality—to ensure that participating ontologies can be combined and reasoned over consistently. The OBO Foundry ecosystem emphasizes ontology development using OWL and description logic, with strong attention to quality control and community governance. In the context of Semantic Knowledge Graphs, the OBO Foundry is often cited as a mature example of large-scale, standards-based ontology coordination, particularly in scientific domains where semantic precision and interoperability are critical."@en .


###  https://www.michaeldebellis.com/glossary/OWL
:OWL rdf:type owl:NamedIndividual ,
              skos:Concept ;
     skos:inScheme :Glossary ;
     rdfs:label "OWL"@en ;
     skos:definition "The Web Ontology Language . A W3C standard used to define Conceptual models that are intuitive to users and domain experts and can be used by systems to validate and reason about domains and data. OWL is based on a decidable subset of First Order Logic called Description Logic."@en .


###  https://www.michaeldebellis.com/glossary/Object_Property
:Object_Property rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:inScheme :Glossary ;
                 skos:related :Property ,
                              :Semantic_Knowledge_Graph ;
                 rdfs:label "Object Property"@en ;
                 skos:definition "An object property is a property whose values are other resources identified by IRIs. Object properties are used to model relationships between entities in a domain, such as organizational membership, ownership, or part–whole relationships and form the structural backbone of Semantic Knowledge Graphs."@en .


###  https://www.michaeldebellis.com/glossary/PROV_O
:PROV_O rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "PROV-O"@en ;
        skos:definition "PROV-O (the Provenance Ontology) is a W3C standard ontology that provides a formal, machine-readable model for representing provenance—that is, information about the origin, history, and derivation of data. It defines core concepts such as entities (things), activities (processes that act on things), and agents (people, organizations, or software responsible for actions), along with relationships that describe how data was generated, used, modified, or attributed. PROV-O enables consistent tracking of lineage, accountability, and reproducibility across systems. In Semantic Knowledge Graphs, PROV-O is commonly used to support data governance, auditability, and trust by explicitly modeling how data products and knowledge artifacts are created and maintained over time."@en .


###  https://www.michaeldebellis.com/glossary/Phase
:Phase rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "Phase"@en ;
       skos:definition "A significant process, such as “Design Core Ontology Structure” that will often consist of multiple sprints. Also called an Epic in Agile."@en .


###  https://www.michaeldebellis.com/glossary/Polyseme
:Polyseme rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:broader :Domain_Driven_Design_DDD ;
          skos:inScheme :Glossary ;
          dcterms:created "2026-05-07T17:42:27Z"^^xsd:dateTime ;
          dcterms:creator "Michael DeBellis" ;
          rdfs:label "Polyseme"@en ;
          skos:definition "In Data Mesh, a polyseme is a business concept that crosses domain boundaries but has domain-specific meanings, attributes, or representations in each bounded context. Examples include terms such as Customer, Account, Artist, or Product: the same word is used across the enterprise, but each domain may define it according to its own responsibilities, lifecycle, identifiers, and business rules. A polyseme should therefore not be forced into a single enterprise-wide definition; instead, its domain-specific meanings should be modeled explicitly and linked through governed mappings where interoperability is needed."@en .


###  https://www.michaeldebellis.com/glossary/Prefix
:Prefix rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "Prefix"@en ;
        skos:definition "A short (2-5 letter) indicator preceding a name with a colon (e.g., owl:Thing). A way of defining a namespace so that IRIs can have the same name but be different objects. Also, allows us to refer to IRIs with short names rather than having to enter the entire IRI."@en .


###  https://www.michaeldebellis.com/glossary/Prolog
:Prolog rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "Prolog"@en ;
        skos:definition "Prolog (Programming in Logic) is a declarative programming language based on formal logic, in which programs are expressed as facts and rules and computation is performed through logical inference. Rather than specifying control flow explicitly, Prolog answers queries by applying unification and backtracking to determine whether goals can be satisfied by the defined rules. Prolog has historically been used in artificial intelligence and expert systems. In the context of Semantic Knowledge Graphs, Prolog illustrates a rule-based reasoning approach that contrasts with ontology-based reasoning in OWL, which restricts expressiveness to ensure decidability and predictable reasoning behavior."@en .


###  https://www.michaeldebellis.com/glossary/Property
:Property rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:broader :OWL ;
          skos:inScheme :Glossary ;
          skos:narrower :Annotation_Property ,
                        :Datatype_Property ,
                        :Object_Property ;
          skos:related :SPARQL ;
          rdfs:label "Property"@en ;
          skos:definition "A property is a named relationship or attribute used to describe how resources are connected to one another or to values. In RDF, SPARQL and OWL, properties are used as predicates in triples and define the meaning of the link between a subject and an object, allowing data to express structure, relationships, and characteristics in a machine-interpretable way. In OWL there are 3 types of properties: 1) Datatype properties, 2) Object properties, and 3) Annotation properties."@en .


###  https://www.michaeldebellis.com/glossary/Property_Graph
:Property_Graph rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:broader :Knowledge_Graph ;
                skos:inScheme :Glossary ;
                rdfs:label "Property Graph"@en ;
                skos:definition "A Property Graph is a graph data model in which nodes and edges can both have associated properties expressed as key–value pairs. Nodes typically represent entities, edges represent relationships, and both may carry arbitrary attributes used for querying or computation. Property graphs are widely used in graph databases because they are flexible, intuitive, and performant for traversal-based queries. Unlike Semantic Knowledge Graphs, property graphs do not have a formal logical semantics or standardized meaning for relationships; interpretation is largely application-specific. As a result, while property graphs are well suited for operational and analytical graph workloads, they do not natively support formal reasoning or semantic interoperability in the way ontology-based models do."@en .


###  https://www.michaeldebellis.com/glossary/Protg
:Protg rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "Protégé"@en ;
       skos:definition "Protégé is an open-source ontology development environment used to create, edit, and manage ontologies expressed in OWL and related Semantic Web standards. It provides graphical and form-based interfaces for defining classes, properties, individuals, and axioms, as well as integrated support for reasoning, validation, and visualization through plugins. Protégé is widely used in both academic and industrial settings as a primary tool for ontology modeling and exploration. In the context of Semantic Knowledge Graphs, Protégé is commonly used during conceptual and design modeling to define ontologies that are later deployed to triplestores and integrated with applications."@en .


###  https://www.michaeldebellis.com/glossary/RDF_Resource_Description_Framework
:RDF_Resource_Description_Framework rdf:type owl:NamedIndividual ,
                                             skos:Concept ;
                                    skos:inScheme :Glossary ;
                                    rdfs:label "RDF (Resource Description Framework)"@en ;
                                    skos:definition "RDF (Resource Description Framework) is a W3C standard data model for representing information about resources in a machine-readable, graph-based form. RDF expresses knowledge as simple statements called triples, each consisting of a subject, a predicate, and an object, which together form a directed graph rather than a table or tree. Resources and relationships are identified using Internationalized Resource Identifiers (IRIs), which enables unambiguous identification and linking of data across systems and domains. By using this uniform graph model, RDF supports data integration, extensibility, and interoperability on the Web, allowing independently created datasets to be combined and queried consistently without requiring a shared physical schema."@en .


###  https://www.michaeldebellis.com/glossary/REST
:REST rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      dcterms:created "2026-05-07T02:02:29Z"^^xsd:dateTime ;
      dcterms:creator "Michael DeBellis" ;
      rdfs:label "REST"@en ;
      skos:definition "REST (Representational State Transfer) is an architectural style for designing networked applications and web APIs using standard HTTP operations such as GET, POST, PUT, and DELETE. REST-based systems organize functionality around resources identified by URLs, with clients interacting with those resources through stateless requests. REST emphasizes simplicity, scalability, and loose coupling between clients and servers, making it one of the most widely used approaches for web services and microservice architectures. In the context of Semantic Knowledge Graphs, REST APIs are commonly used to expose semantic services, data products, and graph operations to applications, often complementing standards such as SPARQL or GraphQL with simpler, task-oriented interfaces."@en .


###  https://www.michaeldebellis.com/glossary/Regression_Test
:Regression_Test rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:inScheme :Glossary ;
                 rdfs:label "Regression Test"@en ;
                 skos:definition "A Regression Test is a test designed to verify that existing functionality continues to behave correctly after changes are made to a system, such as bug fixes, refactoring, data updates, or the introduction of new features. Regression tests are rerun repeatedly to ensure that previously working behavior has not been inadvertently broken by recent changes. They are a critical part of continuous integration and iterative development. In the context of Semantic Knowledge Graphs, regression testing often includes rerunning SPARQL queries, reasoning tasks, or SHACL validations to confirm that ontology changes or data updates do not alter intended inferences, constraints, or query results."@en .


###  https://www.michaeldebellis.com/glossary/Regular_expression
:Regular_expression rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:inScheme :Glossary ;
                    rdfs:label "Regular expression"@en ;
                    skos:definition "A pattern matching language in most programming languages, SPARQL, and other tools that can both match patterns and transform matched data into different patterns."@en .


###  https://www.michaeldebellis.com/glossary/Retrieval_Augmented_Generation_RAG
:Retrieval_Augmented_Generation_RAG rdf:type owl:NamedIndividual ,
                                             skos:Concept ;
                                    skos:inScheme :Glossary ;
                                    rdfs:label "Retrieval-Augmented Generation (RAG)"@en ;
                                    skos:definition "Retrieval-Augmented Generation (RAG) is an AI application pattern in which a language model generates responses using both its pretrained knowledge and information retrieved dynamically from external data sources at query time. Rather than relying solely on the model’s internal parameters, RAG systems retrieve relevant documents, data fragments, or graph elements—often using search, embeddings, or graph queries—and condition the generated output on that retrieved context. This approach improves accuracy, transparency, and currency while reducing hallucinations. In the context of Semantic Knowledge Graphs, RAG commonly leverages structured, semantically modeled data and metadata to provide more precise retrieval, explainability, and governance than text-only retrieval approaches."@en .


###  https://www.michaeldebellis.com/glossary/Rule
:Rule rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      skos:related :Backward_Chaining ,
                   :Forward_chaining ;
      rdfs:label "Rule"@en ;
      skos:definition "A rule is a formal statement that specifies how new information can be derived from existing information. It is typically written in the form “if antecedent, then consequent.” The antecedent (also called the left-hand side or condition) is a set of one or more expressions that must be satisfied for the rule to apply. The consequent (also called the right-hand side or conclusion) is the expression or assertion that is inferred when the antecedent holds. A rule captures a piece of domain logic: whenever these conditions are true, this conclusion must also be true. Rules are evaluated by an automated reasoner called the inference engine. An inference engine can support forward chaining, backward chaining, or both."@en .


###  https://www.michaeldebellis.com/glossary/SAP
:SAP rdf:type owl:NamedIndividual ,
              skos:Concept ;
     skos:inScheme :Glossary ;
     rdfs:label "SAP"@en ;
     skos:definition "SAP is a multinational enterprise software company best known for its ERP (Enterprise Resource Planning) systems that support core business processes such as finance, supply chain, manufacturing, human resources, and sales. Developed by SAP, SAP platforms provide tightly integrated transactional systems with strong consistency and process control, and they are widely used in large organizations. While SAP systems offer rich operational functionality, their data models and semantics are typically application- and vendor-specific. In the context of Semantic Knowledge Graphs, SAP is commonly treated as a primary system of record whose data is extracted, semantically integrated, and enriched to enable interoperability, analytics, governance, and cross-system reasoning beyond the boundaries of the SAP ecosystem."@en .


###  https://www.michaeldebellis.com/glossary/SHACL
:SHACL rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "SHACL"@en ;
       skos:definition "Shapes Constraint Language. A W3C standard to define data integrity constraints and to analyze knowledge graphs and report where they violate integrity constraints."@en .


###  https://www.michaeldebellis.com/glossary/SNOMED_CT
:SNOMED_CT rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "SNOMED CT"@en ;
           skos:definition "SNOMED CT (Systematized Nomenclature of Medicine—Clinical Terms) is a comprehensive, standardized clinical terminology used to represent medical concepts such as diseases, procedures, findings, and medications in a consistent, machine-readable form. Maintained by SNOMED International, SNOMED CT provides unique identifiers, preferred terms, synonyms, and formally defined relationships among concepts. It is widely used in electronic health records and clinical decision-support systems to enable interoperability, precise data capture, and analytics. In the context of Semantic Knowledge Graphs, SNOMED CT is often integrated as a controlled vocabulary or terminology layer and may be aligned with ontologies to support reasoning, mapping, and cross-system semantic integration."@en .


###  https://www.michaeldebellis.com/glossary/SPARQL
:SPARQL rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        skos:related :SQL_Structured_Query_Language ;
        rdfs:label "SPARQL"@en ;
        skos:definition "SPARQL Protocol and RDF Query Language. A W3C standard graph query language to query knowledge graphs."@en ;
        skos:prefLabel "SPARQL"@en .


###  https://www.michaeldebellis.com/glossary/SQL_Structured_Query_Language
:SQL_Structured_Query_Language rdf:type owl:NamedIndividual ,
                                        skos:Concept ;
                               skos:inScheme :Glossary ;
                               rdfs:label "SQL (Structured Query Language)"@en ;
                               skos:definition "SQL (Structured Query Language) is a standardized language used to define, query, and manipulate data stored in relational database systems. It is based on a tabular data model with predefined schemas consisting of tables, rows, and columns, and supports operations such as selection, projection, joins, aggregation, and updates. SQL excels at expressing set-based queries over structured data and is widely used for transactional and analytical workloads. In contrast to Semantic Knowledge Graph approaches, SQL schemas encode meaning implicitly in table design and constraints, whereas semantic systems make meaning explicit through formal models and ontologies that support interoperability and reasoning beyond a single database schema."@en .


###  https://www.michaeldebellis.com/glossary/SWRL
:SWRL rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "SWRL"@en ;
      skos:definition "Semantic Web Rule Language. A very powerful forward chaining rule language that is an extension of OWL. Some concepts that can’t be modeled in OWL can be modeled in SWRL. The classic example is modeling the concept of an uncle or aunt."@en .


###  https://www.michaeldebellis.com/glossary/Security
:Security rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:inScheme :Glossary ;
          rdfs:label "Security"@en ;
          skos:definition "Security refers to the technical and organizational measures used to protect data and knowledge assets from unauthorized access, misuse, disclosure, or modification while ensuring appropriate availability for authorized users. It encompasses authentication, authorization, access control, encryption, and auditing, as well as policies governing how data may be used and shared. In Semantic Knowledge Graphs, security is often expressed declaratively through metadata, ontologies, and constraints that model roles, permissions, classifications, and usage restrictions. This approach enables fine-grained, context-aware access control and supports consistent enforcement of security policies across heterogeneous systems and distributed data products."@en .


###  https://www.michaeldebellis.com/glossary/Semantic_Knowledge_Graph
:Semantic_Knowledge_Graph rdf:type owl:NamedIndividual ,
                                   skos:Concept ;
                          skos:broader :Knowledge_Graph ;
                          skos:inScheme :Glossary ;
                          rdfs:label "Semantic Knowledge Graph"@en ;
                          skos:definition "A knowledge graph is a structure that represents knowledge as a graph, also known as a Semantic Network. Knowledge graphs can include RDF graphs, property graphs, and Semantic Knowledge Graphs. A Semantic Knowledge Graph is an RDF graph that utilizes OWL ontologies to define the schemas of the graph."@en .


###  https://www.michaeldebellis.com/glossary/Semantic_Web
:Semantic_Web rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:inScheme :Glossary ;
              rdfs:label "Semantic Web"@en ;
              skos:definition "The Semantic Web is a vision and set of standards for extending the Web from a collection of human-readable documents to a web of machine-interpretable data. Proposed and standardized through the World Wide Web Consortium (W3C), it is based on technologies such as IRIs, RDF, SPARQL, and OWL, which enable data to be shared, linked, and understood across systems. The Semantic Web emphasizes explicit meaning, global identifiers, and formal semantics to support interoperability and automated reasoning at web scale. In the context of Semantic Knowledge Graphs, the Semantic Web provides the foundational technologies and principles on which ontology-based graph systems are built."@en .


###  https://www.michaeldebellis.com/glossary/Semantics
:Semantics rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "Semantics"@en ;
           skos:definition "Semantics refers to the meaning of symbols, terms, and structures in a model, independent of how they are stored or processed computationally. In information systems, semantics defines what data represents and how different elements should be interpreted and related to one another. In the context of Semantic Knowledge Graphs, semantics is made explicit through formal models—such as ontologies defined in OWL—that assign precise, shared meaning to classes, properties, and relationships. This explicit semantics enables consistent interpretation across systems, supports automated reasoning, and distinguishes semantic models from approaches in which meaning is implicit or application-specific."@en .


###  https://www.michaeldebellis.com/glossary/Set_Theory
:Set_Theory rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Set Theory"@en ;
            skos:definition "Set Theory is a foundational branch of mathematics concerned with the study of collections of objects, called sets, and the relationships among them, such as membership, subset, union, and intersection. It provides a formal framework for defining classes of things and reasoning about how those classes relate to one another. In the context of Semantic Knowledge Graphs, set-theoretic ideas underpin core modeling concepts such as class membership, subclass relationships, and intersections or unions of classes. Together with logic, set theory contributes to the formal semantics of ontology languages like OWL, helping to precisely define the meaning of classes and their relationships."@en .


###  https://www.michaeldebellis.com/glossary/Sharding
:Sharding rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:inScheme :Glossary ;
          rdfs:label "Sharding"@en ;
          skos:definition "Sharding is a data-partitioning technique in which a large dataset is divided into smaller, independent subsets—called shards—that are distributed across multiple machines or storage units. Each shard contains a portion of the overall data, allowing systems to scale horizontally by spreading storage and query load. Sharding improves performance and scalability but introduces additional complexity in query processing, consistency, and transaction management. In the context of Semantic Knowledge Graphs, sharding is used to support large-scale graphs, though it can complicate reasoning and global queries that rely on relationships spanning multiple shards."@en .


###  https://www.michaeldebellis.com/glossary/Sprint
:Sprint rdf:type owl:NamedIndividual ,
                 skos:Concept ;
        skos:inScheme :Glossary ;
        rdfs:label "Sprint"@en ;
        skos:definition "Agile term for a short, time-boxed period (2–3 weeks)."@en .


###  https://www.michaeldebellis.com/glossary/Stardog
:Stardog rdf:type owl:NamedIndividual ,
                  skos:Concept ;
         skos:inScheme :Glossary ;
         skos:related :AllegroGraph ;
         rdfs:label "Stardog"@en ;
         skos:definition "Stardog is a commercial graph database and knowledge-graph platform designed for building, querying, and reasoning over Semantic Knowledge Graphs at enterprise scale. Developed by Stardog, it supports RDF, OWL, and SPARQL, and provides integrated reasoning, data validation, full-text search, and data virtualization across heterogeneous sources. Stardog is commonly used to integrate enterprise data, enforce governance policies, and support advanced analytics and AI-driven applications. In the context of Semantic Knowledge Graphs, it serves as a combined storage, reasoning, and access layer for deploying ontology-based systems in production environments."@en .


###  https://www.michaeldebellis.com/glossary/Story
:Story rdf:type owl:NamedIndividual ,
                skos:Concept ;
       skos:inScheme :Glossary ;
       rdfs:label "Story"@en ;
       skos:definition "A specific user-driven requirement. Stories have the form: “A <kind of user> needs <feature> to <achieve some goal> E.g., “A customer service representative needs to see all flights between two cities sorted by price to provide customers with options.”"@en .


###  https://www.michaeldebellis.com/glossary/Streaming_format
:Streaming_format rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:inScheme :Glossary ;
                  rdfs:label "Streaming format"@en ;
                  skos:definition "A model to map OWL entities to a text description that can be saved in a file. The most popular streaming format for OWL is Turtle. Other streaming formats include RDF/XML, JSON-LD, and OWL Functional Syntax."@en .


###  https://www.michaeldebellis.com/glossary/TBox
:TBox rdf:type owl:NamedIndividual ,
               skos:Concept ;
      skos:inScheme :Glossary ;
      rdfs:label "TBox"@en ;
      skos:definition "The conceptual level of a Semantic Knowledge Graph. The classes, properties, axioms, and rules. The T stands for Terminology because this level defines the terminology of a domain rather than the specific data in the domain."@en .


###  https://www.michaeldebellis.com/glossary/Taxonomy
:Taxonomy rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:inScheme :Glossary ;
          rdfs:label "Taxonomy"@en ;
          skos:definition "A Taxonomy is a structured classification system that organizes concepts into a hierarchy based on broader–narrower (parent–child) relationships. It provides a controlled vocabulary that supports consistent labeling, categorization, and navigation of information. Taxonomies are typically simpler than ontologies, focusing on hierarchical structure rather than rich semantics or formal logic. In the context of Semantic Knowledge Graphs, taxonomies are often implemented using standards such as SKOS and may serve as an entry point to more expressive models, evolving over time into ontologies as additional relationships, constraints, and axioms are introduced."@en .


###  https://www.michaeldebellis.com/glossary/TopQuadrant
:TopQuadrant rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             skos:related :AllegroGraph ;
             rdfs:label "TopQuadrant"@en ;
             skos:definition "TopQuadrant is a commercial provider of enterprise semantic-technology tools focused on ontology modeling, data governance, and Semantic Knowledge Graph management. The company develops platforms that support OWL- and SHACL-based modeling, metadata management, data integration, and policy-driven governance for large organizations. TopQuadrant’s tools are commonly used in regulated and data-intensive domains to establish shared semantic models and enforce standards across distributed systems. In the context of Semantic Knowledge Graphs, TopQuadrant is known for emphasizing model-driven governance and standards-based approaches to managing meaning, quality, and compliance at scale."@en .


###  https://www.michaeldebellis.com/glossary/Transformation
:Transformation rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:inScheme :Glossary ;
                rdfs:label "Transformation"@en ;
                skos:definition "A SPARQL query or other tool that matches a pattern in the knowledge graph and transforms it into another pattern. E.g., find all English labels and generate Spanish labels with the equivalent meaning."@en .


###  https://www.michaeldebellis.com/glossary/Triplestore
:Triplestore rdf:type owl:NamedIndividual ,
                      skos:Concept ;
             skos:inScheme :Glossary ;
             rdfs:label "Triplestore"@en ;
             skos:definition "A Triplestore is a specialized database designed to store, manage, and query RDF data represented as subject–predicate–object triples. It provides native support for Semantic Web standards such as RDF, RDFS, OWL, and SPARQL, enabling both data storage and semantic reasoning over graph-structured data. Triplestores are optimized for handling large, interconnected datasets and for answering complex graph queries that may involve inference based on ontological rules. In the context of Semantic Knowledge Graphs, a triplestore serves as the core persistence and query engine, supporting both explicit facts and implicit knowledge derived through reasoning."@en .


###  https://www.michaeldebellis.com/glossary/URI_Uniform_Resource_Identifier
:URI_Uniform_Resource_Identifier rdf:type owl:NamedIndividual ,
                                          skos:Concept ;
                                 skos:broadMatch :IRI_Internationalized_Resource_Identifier ;
                                 skos:inScheme :Glossary ;
                                 rdfs:label "URI (Uniform Resource Identifier)"@en ;
                                 skos:definition "a standardized identifier used to uniquely identify resources on the Web. A URI is a character string with a defined syntax that can name or locate a resource, including web pages, documents, services, or abstract concepts. URIs provide the foundational identification mechanism of the Web and Semantic Web, enabling resources to be referenced consistently and linked across systems, regardless of whether the identifier directly resolves to a network location. URIs are a type of IRI. URIs were defined before IRIs and hence it is common for documentation to refer to URIs. However, the preferred term now is IRI."@en .


###  https://www.michaeldebellis.com/glossary/URL_Uniform_Resource_Locator
:URL_Uniform_Resource_Locator rdf:type owl:NamedIndividual ,
                                       skos:Concept ;
                              skos:broader :URI_Uniform_Resource_Identifier ;
                              skos:inScheme :Glossary ;
                              rdfs:label "URL (Uniform Resource Locator)"@en ;
                              skos:definition "a specific type of IRI that identifies a resource by describing both its location and the protocol used to access it. A URL typically includes a scheme such as http, https, or ftp, followed by a network address and optional path, query, or fragment components, allowing software to retrieve the identified resource. While all URLs are IRIs, not all IRIs are URLs, since some IRIs serve only as names without implying a retrievable location."@en .


###  https://www.michaeldebellis.com/glossary/Unit_Test
:Unit_Test rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:inScheme :Glossary ;
           rdfs:label "Unit Test"@en ;
           skos:definition "A Unit Test is an automated test that verifies the correct behavior of a small, isolated piece of software—typically a single function, method, or class—under controlled conditions. Unit tests check that given inputs produce expected outputs and that edge cases and error conditions are handled correctly. They are designed to be fast, repeatable, and independent of external systems such as databases or networks, enabling frequent execution during development and continuous integration. In the context of Semantic Knowledge Graph systems, unit testing often complements semantic validation: application code is tested with unit tests, while ontologies and graph data are tested using reasoners, SHACL constraints, and SPARQL-based regression tests to ensure model and data quality as they evolve."@en .


###  https://www.michaeldebellis.com/glossary/Vertical_Scaling
:Vertical_Scaling rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:inScheme :Glossary ;
                  rdfs:label "Vertical Scaling"@en ;
                  skos:definition "Vertical Scaling (also called scale up) is an approach to increasing system capacity by adding more resources—such as CPU, memory, or storage—to a single machine rather than distributing the workload across multiple machines. This method is simple to implement and can improve performance for workloads that benefit from shared memory or tight coupling. However, vertical scaling has practical limits based on hardware constraints and can introduce single points of failure. In the context of data platforms and Semantic Knowledge Graphs, vertical scaling is often used in early stages or for reasoning-intensive workloads, but it is typically complemented or replaced by horizontal scaling as systems grow in size and complexity."@en .


###  https://www.michaeldebellis.com/glossary/Vocabulary
:Vocabulary rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "Vocabulary"@en ;
            skos:definition "An ontology designed to be reusable, ideally curated by some professional organization. E.g., Simple Knowledge Organization System (SKOS), Dublin Core, Gist, FINBO. There are three kinds of ontology vocabularies: 1) Upper Models are ontologies designed to serve as a common starting point for all ontologies in an organization or community. Example upper models are the Basic Formal Ontology (BFO) and the Simple Upper Level Ontology (SULO) 2) Technical or horizontal vocabularies define models for technical domains that span domains such as PROV for data provenance. 3) Domain or vertical ontologies define reusable models for a domain or industry. Examples are SNOMED for Healthcare and FIBO for financial services."@en .


###  https://www.michaeldebellis.com/glossary/W3C_World_Wide_Web_Consortium
:W3C_World_Wide_Web_Consortium rdf:type owl:NamedIndividual ,
                                        skos:Concept ;
                               skos:inScheme :Glossary ;
                               skos:related :SPARQL ;
                               rdfs:label "W3C (World Wide Web Consortium)"@en ;
                               skos:definition "the international standards organization responsible for developing and maintaining the core technical standards of the Web. Founded by Tim Berners-Lee, the W3C brings together industry, academic, and public-sector members to create open, consensus-based specifications such as HTML, RDF, OWL, and SPARQL. Its mission is to ensure the long-term growth and interoperability of the Web by defining standards that promote openness, accessibility, and compatibility across platforms, tools, and organizations."@en .


###  https://www.michaeldebellis.com/glossary/Waterfall_Model
:Waterfall_Model rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:inScheme :Glossary ;
                 skos:related :Agile_Methods ;
                 rdfs:label "Waterfall Model"@en ;
                 skos:definition "The Waterfall Model is a linear, sequential approach to system development in which work progresses through fixed phases—such as requirements, design, implementation, testing, and deployment—each of which must be completed before the next begins. This model emphasizes upfront specification and comprehensive documentation, with limited opportunity to revisit earlier decisions once a phase is complete. While the waterfall model can be effective in stable, well-understood domains, it is often ill-suited to complex or evolving data and semantic systems. In the context of Semantic Knowledge Graphs, the waterfall approach contrasts with iterative methods, as semantic models typically benefit from incremental refinement as domain understanding and data sources evolve."@en .


###  https://www.michaeldebellis.com/glossary/gRPC
:gRPC rdf:type owl:NamedIndividual ,
               skos:Concept ;
      dcterms:created "2026-05-07T02:04:04Z"^^xsd:dateTime ;
      dcterms:creator "Michael DeBellis" ;
      rdfs:label "gRPC"@en ;
      skos:definition "gRPC is a high-performance framework for remote procedure calls (RPC) that enables applications to communicate efficiently across distributed systems. Originally developed by Google, gRPC uses HTTP/2 for transport and Protocol Buffers (protobuf) for compact, strongly typed message serialization. Unlike REST, which is resource-oriented, gRPC is procedure-oriented: clients invoke methods on remote services as if they were local function calls. gRPC supports features such as streaming, bidirectional communication, and efficient binary encoding, making it well suited for microservices and real-time systems. In the context of Semantic Knowledge Graphs, gRPC is often used for high-throughput internal services and data pipelines, complementing more semantically oriented interfaces such as SPARQL and GraphQL."@en .


###  https://www.michaeldebellis.com/glossary/owlNothing
:owlNothing rdf:type owl:NamedIndividual ,
                     skos:Concept ;
            skos:inScheme :Glossary ;
            rdfs:label "owl:Nothing"@en ;
            skos:definition "The empty set, the set that has no instances. Every class is a superclass of owl:Nothing. No individual is an instance of owl:Nothing."@en .


###  https://www.michaeldebellis.com/glossary/owlThing
:owlThing rdf:type owl:NamedIndividual ,
                   skos:Concept ;
          skos:inScheme :Glossary ;
          rdfs:label "owl:Thing"@en ;
          skos:definition "The set that is a superset of all sets. All OWL classes are subclasses of owl:Thing. All individuals are instances of owl:Thing."@en .


###  https://www.michaeldebellis.com/glossary/owltopDataProperty
:owltopDataProperty rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:inScheme :Glossary ;
                    skos:related :Property ;
                    rdfs:label "owl:topDataProperty"@en ;
                    skos:definition "The property that all data properties are sub-properties of."@en .


###  https://www.michaeldebellis.com/glossary/owltopObjectProperty
:owltopObjectProperty rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:inScheme :Glossary ;
                      skos:related :Property ;
                      rdfs:label "owl:topObjectProperty"@en ;
                      skos:definition "The property that all object properties are sub-properties of."@en .


