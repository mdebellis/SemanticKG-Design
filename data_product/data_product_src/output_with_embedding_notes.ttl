<https://www.michaeldebellis.com/streamforge> a owl:Ontology ;
    rdfs:label "Ontology for StreamForge Data Product Catalog example."@en ;
    dcterms:description "This ontology defines the core concepts used in the StreamForge Data Product Catalog, including Data Products, bounded contexts, ports, ownership, and associated documentation. It is intended to support analytics, operational use cases, governance, and decision-making across the StreamForge organization."@en ;
    skos:definition "The StreamForge Data Catalog provides a unified view of Data Products, metadata, governance information, and documentation used across the StreamForge platform. It enables discovery, understanding, and responsible use of enterprise data assets by making their structure, purpose, ownership, and relationships explicit."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025 a owl:NamedIndividual,
        docs:Document ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025"@en ;
    dcterms:created "2025-11-20"^^xsd:date ;
    dcterms:creator "Monetization"@en ;
    dcterms:publisher "StreamForge Finance Engineering"@en ;
    dcterms:title "Ads Revenue Reconciliation Notes (Nov 2025)"@en ;
    docs:uses_data_product sf:SF_Ads_Performance_Data_Product ;
    docs:uses_dataset sf:SF_Ads_Performance_Dataset ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 uses data product: SF Ads Performance Data Product."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_01 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01"@en ;
    docs:chunk_index 1 ;
    docs:chunk_text "This note documents how daily ad revenue is reconciled between delivery logs and finance reporting. The goal is consistent numbers across dashboards and the general ledger."@en ;
    docs:chunk_title "Context"@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_02 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02"@en ;
    docs:chunk_index 2 ;
    docs:chunk_text "We used the StreamForge Ads Performance data product. It provides daily aggregates by video and channel, sourced from ad server logs and summarized into BigQuery tables."@en ;
    docs:chunk_title "Data sources"@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_03 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03"@en ;
    docs:chunk_index 3 ;
    docs:chunk_text "Late-arriving events and currency conversion updates can shift revenue totals. A 'finalized_date' convention is recommended so stakeholders know when a day’s revenue is stable."@en ;
    docs:chunk_title "Known pitfalls"@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_04 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04"@en ;
    docs:chunk_index 4 ;
    docs:chunk_text "The dataset is at daily grain. Video_id and channel_id are stable join keys. Avoid joining to event-level engagement without first aggregating engagement to daily grain."@en ;
    docs:chunk_title "Join keys and grain"@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_05 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05"@en ;
    docs:chunk_index 5 ;
    docs:chunk_text "We validate that delivered impressions reconcile to billed impressions within 0.5%. Outliers are investigated by country, device, and ad format."@en ;
    docs:chunk_title "Validation checks"@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_06 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 06"@en ;
    docs:chunk_index 6 ;
    docs:chunk_text "Publish a documented 'ads_revenue_daily' view as the canonical table for reporting. Deprecate ad-hoc spreadsheets and require dashboard owners to reference the canonical view."@en ;
    docs:chunk_title "Governance recommendation"@en .

sf:Creator_Data_Product a owl:NamedIndividual,
        dp:Data_Product ;
    rdfs:label "Creator Data Product"@en ;
    dp:about_domain_concept sf:Creator ;
    dp:embedding_note "Creator Data Product about domain concept Creator."@en,
        "Creator Data Product has analytic port Creator History Query."@en,
        "Creator Data Product has bounded context StreamForge Bounded Context."@en,
        "Creator Data Product has policy Creator history access policy."@en,
        "Creator Data Product has policy Creator history external access prohibition policy."@en,
        "Creator Data Product is about domain concept Creator."@en ;
    dp:has_analytic_port sf:Get_Creator_History ;
    dp:has_bounded_context sf:StreamForge_Bounded_Context ;
    dp:has_policy dp:Creator_History_Access_Policy,
        dp:Creator_History_External_Access_Prohibition_Policy .

sf:Creator_Lina_Learns a owl:NamedIndividual,
        dp:Creator ;
    rdfs:label "Lina Learns (Creator)"@en ;
    dcterms:description """Lina Learns is a synthetic educational creator whose content has strong long-term value and search-driven discovery. This creator appears in examples explaining how different discovery channels can create different engagement signatures and therefore different analytics interpretations.

Including Lina Learns improves RAG answers that compare creators across categories and that need to relate documentation (metric caveats, cohort definitions) to graph lineage (datasets and computation activities)."""@en ;
    skos:definition "A synthetic educational creator used to illustrate content category effects on growth and engagement."@en ;
    skos:note "Synthetic example creator for StreamForge."@en .

sf:Creator_Nova_Gaming a owl:NamedIndividual,
        dp:Creator ;
    rdfs:label "Nova Gaming (Creator)"@en ;
    dcterms:description """Nova Gaming is a synthetic creator whose audience shows strong session depth and repeat viewing, making the channel a useful example for creator growth and monetization narratives. The creator is included to support questions about how engagement events aggregate into creator KPIs and how those KPIs influence executive-level metrics.

Nova Gaming is also useful in documentation examples where analysts compare creators with similar engagement but different monetization outcomes, highlighting the importance of clear metric definitions and provenance."""@en ;
    skos:definition "A synthetic gaming creator used to illustrate creator-level engagement patterns and monetization analysis."@en ;
    skos:note "Synthetic example creator for StreamForge."@en .

sf:Creator_Solstice_Music a owl:NamedIndividual,
        dp:Creator ;
    rdfs:label "Solstice Music (Creator)"@en ;
    dcterms:description """Solstice Music is a synthetic music creator used in examples where engagement spikes dramatically during trend events. This makes the creator useful for illustrating why data validation, late-arriving events, and backfills matter: the difference between a real spike and a pipeline artifact can change business decisions.

Solstice Music strengthens RAG responses that need to connect operational issues to business interpretation and that must explain how provenance and documentation support trust in analytics outputs."""@en ;
    skos:definition "A synthetic music creator used for examples involving spikes, trend events, and revenue sensitivity."@en ;
    skos:note "Synthetic example creator for StreamForge."@en .

sf:Describe_User_Data_Product_SPARQL_Implementation a owl:NamedIndividual,
        dp:Port_Implementation ;
    rdfs:label "Describe User Data Product SPARQL Implementation"@en ;
    dcterms:contributor "Michael DeBellis" ;
    dcterms:created "2026-02-05T21:27:55+00:00"^^xsd:dateTime ;
    dp:embedding_note "Describe User Data Product SPARQL Implementation is implementation for Describe User Data Product."@en,
        "Describe User Data Product SPARQL Implementation uses technology SPARQL."@en ;
    dp:has_sparql_query_text """PREFIX dp:   <https://www.michaeldebellis.com/dp/>
CONSTRUCT {
  dp:User_Data_Product ?p1 ?o .
  ?s ?p2 dp:User_Data_Product .}
WHERE {
  { dp:User_Data_Product ?p1 ?o }
  UNION
  { ?s ?p2 dp:User_Data_Product }}""" ;
    dp:is_implementation_for sf:Describe_User_Data_Product ;
    dp:uses_technology dp:SPARQL .

sf:Describe_Video_Data_Product a owl:NamedIndividual,
        dp:Describe_Data_Product_Port ;
    rdfs:label "Describe Video Data Product"@en ;
    dcterms:contributor "Michael DeBellis" ;
    dcterms:created "2026-02-05T21:43:54+00:00"^^xsd:dateTime ;
    dp:embedding_note "Describe Video Data Product is port of Video Data Product."@en ;
    dp:is_port_of sf:Video_Data_Product .

sf:Discover_Data_Products_SPARQL_Implementation_Using_CONSTRUCT a owl:NamedIndividual,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using CONSTRUCT"@en ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using CONSTRUCT is implementation for Discover Data Products."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT uses technology SPARQL."@en ;
    dp:has_sparql_query_text """PREFIX dp:   <https://www.michaeldebellis.com/dp/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
CONSTRUCT {
  ?bc  dp:has_data_product ?dp .
  ?dp  dp:has_port ?port .
  ?port dp:has_access_type ?access .}
WHERE {
  ?dp rdf:type dp:Data_Product .
  OPTIONAL { ?dp dp:has_bounded_context ?bc . }
  OPTIONAL { ?dp dp:has_port ?port . }
  OPTIONAL { ?port dp:has_access_type ?access . }
  # Keep the graph tight: only show products that actually have at least one port.
  FILTER(BOUND(?port))}""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

sf:Discover_Data_Products_SPARQL_Implementation_Using_CONSTRUCT_Catalog_Slice a owl:NamedIndividual,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice"@en ;
    dcterms:contributor "Michael DeBellis" ;
    dcterms:created "2026-02-05T01:36:18+00:00"^^xsd:dateTime ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice is implementation for Discover Data Products."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice uses technology SPARQL."@en ;
    dp:has_sparql_query_text """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dp:   <https://www.michaeldebellis.com/dp/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?catalog rdf:type dcat:Catalog .
  ?catalog dp:has_port ?catalog_port .

  ?catalog_port rdf:type dp:Data_Product_Port .
  ?catalog_port dp:discovers_data_product ?dp .   
  
  ?dp rdf:type dp:Data_Product .
  ?dp dp:has_port ?port .

  ?port rdf:type dp:Data_Product_Port .
  ?port dp:has_access_type ?access_type .

  ?access_type rdf:type dp:Access_Type .
}
WHERE {
  VALUES ?catalog { dp:StreamForge_Catalog }      # adjust IRI

  OPTIONAL { ?catalog dp:has_port ?catalog_port . }
  OPTIONAL { ?catalog_port dp:discovers_data_product ?dp . }

  OPTIONAL { ?dp dp:has_port ?port . }
  OPTIONAL { ?port dp:has_access_type ?access_type . }
}""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

sf:Discover_Data_Products_SPARQL_Implementation_Using_SELECT a owl:NamedIndividual,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using SELECT"@en ;
    dcterms:contributor "Michael DeBellis" ;
    dcterms:created "2026-02-04T23:07:15+00:00"^^xsd:dateTime ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using SELECT is implementation for Discover Data Products."@en,
        "Discover Data Products SPARQL Implementation Using SELECT uses technology SPARQL."@en ;
    dp:has_sparql_query_text """# Query 2B — Interactive SELECT (good for a “Data Catalog Port” UI)
# This returns the key facts a reader expects when “discovering” a product: 
PREFIX dp:    <https://www.michaeldebellis.com/dp/>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX terms: <http://purl.org/dc/terms/>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT ?dp ?dpLabel ?bc ?bcLabel ?port ?portLabel ?access ?accessLabel
WHERE {
  ?dp rdf:type dp:Data_Product .
  OPTIONAL { ?dp rdfs:label ?dpLabel . }
  OPTIONAL {
    ?dp dp:has_bounded_context ?bc .
    OPTIONAL { ?bc rdfs:label ?bcLabel . }}
  OPTIONAL {
    ?dp dp:has_port ?port .
    OPTIONAL { ?port rdfs:label ?portLabel . }
    OPTIONAL {
      ?port dp:has_access_type ?access .
      OPTIONAL { ?access rdfs:label ?accessLabel . }}}}
ORDER BY ?dpLabel ?portLabel""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

sf:Elena_Garcia a owl:NamedIndividual,
        prov:Person ;
    rdfs:label "Elena Garcia"@en ;
    dcterms:description """Elena Garcia uses curated creator insights datasets to analyze growth drivers and propose product experiments. She often needs to understand what a metric truly means, how it is computed, and what caveats apply during data incidents or backfills.

Elena is included to improve RAG answers that must translate between technical lineage and business interpretation. Her presence makes it easier for the assistant to explain why documentation and provenance matter for decision-making."""@en ;
    skos:definition "A product analyst who interprets creator performance metrics and supports growth decisions."@en ;
    skos:note "Synthetic example person for StreamForge."@en .

