###  http://michaeldebellis.com/people/Parent
:Parent rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Adult
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :has_Child ;
                                                     owl:someValuesFrom :Person
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:label "Parent" .


###  http://michaeldebellis.com/people/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent ,
                        :Human ;
        rdfs:label "Person" .


###  http://michaeldebellis.com/people/Pet
:Pet rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( :Living_Thing
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :is_Pet_Of ;
                                                  owl:someValuesFrom :Human
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
     rdfs:subClassOf :Living_Thing ;
     <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
     <http://purl.org/dc/terms/created> "2025-03-08T03:37:56Z"^^xsd:dateTime ;
     rdfs:label "Pet" .


