            <owl:Restriction>
                <owl:onProperty rdf:resource="https://michaeldebellis.com/people/has_gender"/>
                <owl:hasValue rdf:resource="https://michaeldebellis.com/people/Female"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label>has sister</rdfs:label>
    </owl:ObjectProperty>
    


