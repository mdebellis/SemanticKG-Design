PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX :  <https://michaeldebellis.com/people/>

#Important: First paste the PREFIX statements at the very top at the top of your
#SPARQL query. Then reove any existing query and paste each of the following
#Remember to always leave the PREFIX statements in place
#Note: these queries should all work in Snap SPARQL, but many SPARQL queries won't

# Listing 3-7. SPARQL Query to Retrieve all Classes
SELECT *
WHERE {?class rdf:type owl:Class}

# Listing 3-8. SPARQL Query to Retrieve Classes and Labels
SELECT ?label  
WHERE {?class rdfs:subClassOf owl:Thing;
			  rdfs:label ?label} ORDER BY ?label

# Listing 3-9. SPARQL Query to Retrieve Object Properties and Labels			
SELECT ?label  
WHERE {?object_property rdf:type owl:ObjectProperty;
				        rdfs:label ?label} ORDER BY ?label

# Listing 3-10. SPARQL Query to Retrieve People Who Have Age Values Defined
SELECT ?person_label ?age
WHERE {?person :has_age ?age.} ORDER BY ?age
	
# Listing 3-11. SPARQL Query to Retrieve All People With Ages When Available 	
SELECT ?person_label ?age
WHERE {?person rdf:type :Person;
               rdfs:label ?person_label.
	OPTIONAL {?person :has_age ?age}} ORDER BY ?person_label
	
# Listing 3-12. SPARQL Query to Retrieve People With Known Birthdays (exclude people with no birthdate)
SELECT *
WHERE {?person :birth_Date ?birth_day} ORDER BY ?birth_day

# Listing 3-13. SPARQL Query to Retrieve All People And Birthdays and Age When Known	
SELECT ?person_label ?birth_day
WHERE {?person rdf:type :Person;
               rdfs:label ?person_label.
OPTIONAL {?person :birth_Date ?birth_day}} ORDER BY ?person_label

# List all the instances of Person. Include their age and birth day if available. 
SELECT ?person_label ?age ?birth_day
WHERE {?person rdf:type :Person;
               rdfs:label ?person_label.
OPTIONAL {?person :has_age ?age}
OPTIONAL {?person :birth_Date ?birth_day}} ORDER BY ?person_label




