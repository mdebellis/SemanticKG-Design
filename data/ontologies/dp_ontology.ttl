                                    dct:relation .


###  http://purl.org/dc/terms/isVersionOf
dct:isVersionOf rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> ,
                                   dct:relation .


###  http://purl.org/dc/terms/issued
dct:issued rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/language
dct:language rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/language> .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/rights> ,
                               dct:rights .


###  http://purl.org/dc/terms/mediator
dct:mediator rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf dct:audience .


###  http://purl.org/dc/terms/medium
dct:medium rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/format> ,
                              dct:format .


###  http://purl.org/dc/terms/modified
dct:modified rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/publisher
dct:publisher rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/publisher> .


###  http://purl.org/dc/terms/references
dct:references rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> ,
                                  dct:relation .


###  http://purl.org/dc/terms/relation
dct:relation rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> .


###  http://purl.org/dc/terms/replaces
dct:replaces rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> ,
                                dct:relation .


###  http://purl.org/dc/terms/requires
dct:requires rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> ,
                                dct:relation .


###  http://purl.org/dc/terms/rights
dct:rights rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/rights> .


###  http://purl.org/dc/terms/source
dct:source rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/source> ,
                              dct:relation .


###  http://purl.org/dc/terms/spatial
dct:spatial rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/coverage> ,
                               dct:coverage .


###  http://purl.org/dc/terms/subject
dct:subject rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/subject> .


###  http://purl.org/dc/terms/tableOfContents
dct:tableOfContents rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/description> ,
                                       dct:description .


###  http://purl.org/dc/terms/temporal
dct:temporal rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/coverage> ,
                                dct:coverage .


###  http://purl.org/dc/terms/title
dct:title rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/title> .


###  http://purl.org/dc/terms/type
dct:type rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/type> .


###  http://purl.org/dc/terms/valid
dct:valid rdf:type owl:AnnotationProperty ;
          rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


