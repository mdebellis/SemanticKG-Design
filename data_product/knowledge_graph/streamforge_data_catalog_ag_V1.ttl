odrl:assigneeOf a owl:ObjectProperty ;
    rdfs:label "Assignee Of"@en ;
    rdfs:domain owl:Thing,
        odrl:Party,
        prov:Agent,
        prov:Entity ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range _:nc0b2aa5d5f8947168b4edb4c3a148918b2,
        _:nc0b2aa5d5f8947168b4edb4c3a148918b3,
        _:nc0b2aa5d5f8947168b4edb4c3a148918b4,
        _:nc0b2aa5d5f8947168b4edb4c3a148918b5,
        _:nc0b2aa5d5f8947168b4edb4c3a148918b6,
        owl:Thing,
        odrl:Policy ;
    skos:definition "Identifies an ODRL Policy for which the identified Party undertakes the assignee functional role."@en ;
    skos:note "Identifies an ODRL Policy for which the identified Party undertakes the assignee functional role."@en,
        "When assigneeOf has been asserted between a metadata expression and an ODRL Policy, the Party being identified MUST be inferred to undertake the assignee functional role of all the Rules of that Policy."@en ;
    dp:embedding_note "Assignee Of has definition Identifies an ODRL Policy for which the identified Party undertakes the assignee functional role."@en .

