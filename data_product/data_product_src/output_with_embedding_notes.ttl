    rdfs:label "elements/1.1/coverage"@en .

dc:date a owl:AnnotationProperty ;
    rdfs:label "elements/1.1/date"@en .

dc:identifier a owl:AnnotationProperty ;
    rdfs:label "elements/1.1/identifier"@en .

