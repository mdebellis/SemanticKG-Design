###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/description> ,
                                dct:description .


###  http://purl.org/dc/terms/accessRights
dct:accessRights rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/rights> ,
                                    dct:rights .


###  http://purl.org/dc/terms/accrualMethod
dct:accrualMethod rdf:type owl:AnnotationProperty ;
                  rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/accrualPeriodicity
dct:accrualPeriodicity rdf:type owl:AnnotationProperty ;
                       rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/accrualPolicy
dct:accrualPolicy rdf:type owl:AnnotationProperty ;
                  rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/alternative
dct:alternative rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/title> .


###  http://purl.org/dc/terms/audience
dct:audience rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/available
dct:available rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/bibliographicCitation
dct:bibliographicCitation rdf:type owl:AnnotationProperty ;
                          rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/identifier> .


###  http://purl.org/dc/terms/conformsTo
dct:conformsTo rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/relation> ,
                                  dct:relation .


###  http://purl.org/dc/terms/contributor
dct:contributor rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/contributor> .


###  http://purl.org/dc/terms/coverage
dct:coverage rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/coverage> .


###  http://purl.org/dc/terms/created
dct:created rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/creator
dct:creator rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/creator> ,
                               dct:contributor .


###  http://purl.org/dc/terms/date
dct:date rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/dateAccepted
dct:dateAccepted rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/dateCopyrighted
dct:dateCopyrighted rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/dateSubmitted
dct:dateSubmitted rdf:type owl:AnnotationProperty ;
                  rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> .


###  http://purl.org/dc/terms/description
dct:description rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/description> .


###  http://purl.org/dc/terms/educationLevel
dct:educationLevel rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf dct:audience .


###  http://purl.org/dc/terms/extent
dct:extent rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/format> ,
                              dct:format .


###  http://purl.org/dc/terms/format
dct:format rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/format> .


