#################################################################
#    Classes
#################################################################

###  http://michaeldebellis.com/people/AI_Agent
:AI_Agent rdf:type owl:Class ;
          rdfs:subClassOf :Agent ;
          dct:contributor "Michael DeBellis" ;
          dct:created "2025-09-23T00:48:27Z"^^xsd:dateTime ;
          rdfs:label "AI Agent" ;
          skos:definition "An automated software Agent." ;
          skos:example "ChatGPT in Agent mode." .


###  http://michaeldebellis.com/people/Address
:Address rdf:type owl:Class ;
         rdfs:subClassOf :Place ;
         rdfs:label "Address" .


###  http://michaeldebellis.com/people/Adult
:Adult rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Person
