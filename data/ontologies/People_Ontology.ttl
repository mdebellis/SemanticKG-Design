           rdf:type owl:IrreflexiveProperty ;
           rdfs:label "has uncle" .


###  http://michaeldebellis.com/people/has_Wife
:has_Wife rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_Spouse ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:range :Woman ;
          rdfs:label "has wife" .


###  http://michaeldebellis.com/people/has_brother
:has_brother rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Sibling ;
