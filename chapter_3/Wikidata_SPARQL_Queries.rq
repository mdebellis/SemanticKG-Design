# Copy this URL and paste into your browser to go to the Wikidata SPARQL engine: https://query.wikidata.org/
# Paste the following prefixes and leave them as you paste the various queries

PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX schema: <http://schema.org/>

# Listing 3-15. SPARQL Query to Find People in Wikidata Who Were Born in NY City
#Humans born in New York City
SELECT DISTINCT ?item ?itemLabel ?itemDescription ?sitelinks
WHERE {?item wdt:P31 wd:Q5;            # Any instance of a human
             wdt:P19/wdt:P131* wd:Q60; # Who was born in any value (eg. a hospital)
# that has the property of 'administrative area of' New York City or New York City itself.
# Note that using wdt:P19 wd:Q60; Who was born in New York City
# Doesn't include humans with the birth place listed as a hospital
# or an administrative area or other location of New York City.
          wikibase:sitelinks ?sitelinks.
    SERVICE wikibase:label { bd:serviceParam wikibase:language "[AUTO_LANGUAGE],mul,en" }}
ORDER BY DESC(?sitelinks)

# Listing 3-16. SPARQL Query to Find Nobel Prize Winners in Physics
# Nobel Prize winners in Physics
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX schema: <http://schema.org/>
SELECT ?winner ?winnerLabel ?birthPlace ?birthPlaceLabel ?wikiPage
WHERE {
  ?winner wdt:P166 wd:Q38104 ;  # Won the Nobel Prize in Physics
          wdt:P19 ?birthPlace . # Birthplace
  # Retrieve Wikipedia page link
  OPTIONAL { ?wikiPage schema:about ?winner ; schema:inLanguage "en" ; schema:isPartOf <https://en.wikipedia.org/>. }
  # Retrieve labels
  SERVICE wikibase:label {bd:serviceParam wikibase:language "en". }}
ORDER BY ?winnerLabel
LIMIT 50

# Listing 3-19. SPARQL Query that Finds All Hospitals in the World and Display on World Map
#Map of hospitals across the world using the Map View
#Note: the next line is not a normal comment, it tells Wikidata what kind of UI to use
#defaultView:Map
SELECT DISTINCT * 
WHERE {?item wdt:P31/wdt:P279* wd:Q16917;
        wdt:P625 ?geo .}

# Listing 3-20. SPARQL Query to Find Connections to Ada Lovelace and Display as Graph
#Use the graph view to view people and concepts related to Ada Lovelace, the first programmer
#Note: the next line is not a normal comment, it tells Wikidata what kind of UI to use
#defaultView:Graph
SELECT ?item ?itemLabel ?itemImage ?value ?valueLabel ?valueImage ?edgeLabel WHERE {
  BIND(wd:Q7259 AS ?item)  # Ada Lovelace
  ?item ?wdt ?value.
  ?edge a wikibase:Property;
        wikibase:propertyType wikibase:WikibaseItem;
        wikibase:directClaim ?wdt.
  OPTIONAL { ?item wdt:P18 ?itemImage. }
  OPTIONAL { ?value wdt:P18 ?valueImage. }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "[AUTO_LANGUAGE],mul,en". }}

#If you’d like to try this Graph View query with a different person or concept, it’s easy to do. 
#All you need is the Wikidata identifier (also called a Q-ID) for the entity you’re interested in. Here’s how to find it:
#1.	Go to Wikidata: https://www.wikidata.org/
#2.	In the search bar, type the name of the person or concept you want to explore (e.g., Alan Turing, Taylor Swift, quantum computing,…).
#3.	Click on the correct result. The URL will look something like: https://www.wikidata.org/wiki/Q7251. The Q-number at the end (Q7251) is the identifier you need.
#4.	Once you have the identifier, go to the Wikidata Query Service with the Ada Lovelace query above, and replace the line: 
#   BIND(wd:Q7259 AS ?item)  # Ada Lovelace with: BIND(wd:QXXXXXX AS ?item)  # Your new item here
#5.	Substitute your chosen Q-ID for QXXXXXX, run the query, and view the graph.
