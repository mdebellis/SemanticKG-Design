###  http://michaeldebellis.com/people/age
:age rdf:type owl:DatatypeProperty ,
              owl:FunctionalProperty ;
     rdfs:domain :Person ;
     rdfs:range xsd:integer ;
     rdfs:label "age" ;
     skos:example 12 ,
                  32 ;
     skos:prefLabel "has age" .


