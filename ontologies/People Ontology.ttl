@prefix : <http://michaeldebellis.com/people/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@base <http://michaeldebellis.com/people/> .

<http://michaeldebellis.com/people> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
swrla:isRuleEnabled rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://michaeldebellis.com/people/contains
:contains rdf:type owl:ObjectProperty ;
          owl:inverseOf :is_Contained_In ;
          rdf:type owl:TransitiveProperty ;
          rdfs:domain :Place ;
          rdfs:range :Place ;
          <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
          <http://purl.org/dc/terms/created> "2025-03-08T04:29:54Z"^^xsd:dateTime ;
          rdfs:label "contains" .


###  http://michaeldebellis.com/people/has_Address
:has_Address rdf:type owl:ObjectProperty ;
             owl:inverseOf :is_Address_For ;
             rdfs:domain :Agent ;
             rdfs:range :Address ;
             <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
             <http://purl.org/dc/terms/created> "2025-03-07T04:50:12Z"^^xsd:dateTime ,
                                                "2025-03-08T04:36:18Z"^^xsd:dateTime ;
             rdfs:label "has address" .


###  http://michaeldebellis.com/people/has_Aunt
:has_Aunt rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_Social_Relation_With ;
          rdfs:label "has aunt" .


###  http://michaeldebellis.com/people/has_Brother
:has_Brother rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Sibling ;
             rdfs:range [ rdf:type owl:Restriction ;
                          owl:onProperty :has_Gender ;
                          owl:hasValue :Male
                        ] ;
             rdfs:label "has brother" .


###  http://michaeldebellis.com/people/has_Child
:has_Child rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :has_Social_Relation_With ;
           owl:inverseOf :has_Parent ;
           rdfs:label "has child" .


###  http://michaeldebellis.com/people/has_City
:has_City rdf:type owl:ObjectProperty ;
          rdfs:domain :Address ;
          rdfs:range :City ;
          <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
          <http://purl.org/dc/terms/created> "2025-03-08T04:35:10Z"^^xsd:dateTime ;
          rdfs:label "has city" .


###  http://michaeldebellis.com/people/has_Daughter
:has_Daughter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :has_Child ;
              rdfs:range [ rdf:type owl:Restriction ;
                           owl:onProperty :has_Gender ;
                           owl:hasValue :Female
                         ] ;
              rdfs:label "has daughter" .


###  http://michaeldebellis.com/people/has_Employer
:has_Employer rdf:type owl:ObjectProperty ;
              owl:inverseOf :is_Employer_Of ;
              rdfs:domain :Person ;
              rdfs:range :Agent ;
              <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
              <http://purl.org/dc/terms/created> "2025-03-08T05:00:04Z"^^xsd:dateTime ;
              rdfs:label "has employer" .


###  http://michaeldebellis.com/people/has_Father
:has_Father rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Parent ;
            rdfs:range :Man ;
            rdfs:label "has father" .


###  http://michaeldebellis.com/people/has_Friend
:has_Friend rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Social_Relation_With ;
            rdf:type owl:SymmetricProperty ;
            rdfs:label "has friend" .


###  http://michaeldebellis.com/people/has_Gender
:has_Gender rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Animal ;
            rdfs:range :Gender ;
            rdfs:label "has gender" .


###  http://michaeldebellis.com/people/has_Husband
:has_Husband rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Spouse ;
             owl:inverseOf :has_Wife ;
             rdfs:range [ rdf:type owl:Restriction ;
                          owl:onProperty :has_Gender ;
                          owl:hasValue :Male
                        ] ;
             rdfs:label "has husband" .


###  http://michaeldebellis.com/people/has_Member
:has_Member rdf:type owl:ObjectProperty ;
            owl:inverseOf :is_Member_Of ;
            rdfs:domain :University ;
            rdfs:range :Agent ;
            <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
            <http://purl.org/dc/terms/created> "2025-03-07T05:00:29Z"^^xsd:dateTime ;
            rdfs:label "has member" .


###  http://michaeldebellis.com/people/has_Mother
:has_Mother rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Parent ;
            rdfs:range :Woman ;
            rdfs:label "has mother" .


###  http://michaeldebellis.com/people/has_Movement_Speed
:has_Movement_Speed rdf:type owl:ObjectProperty ;
                    rdfs:domain :Living_Thing ;
                    rdfs:range :Movement_Speed ;
                    <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                    <http://purl.org/dc/terms/created> "2025-03-08T03:29:45Z"^^xsd:dateTime ;
                    rdfs:label "has movement speed" .


###  http://michaeldebellis.com/people/has_Parent
:has_Parent rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Social_Relation_With ;
            rdfs:label "has parent" .


###  http://michaeldebellis.com/people/has_Pet
:has_Pet rdf:type owl:ObjectProperty ;
         owl:inverseOf :is_Pet_Of ;
         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
         <http://purl.org/dc/terms/created> "2025-03-08T03:38:48Z"^^xsd:dateTime ;
         rdfs:label "has pet" .


###  http://michaeldebellis.com/people/has_Sibling
:has_Sibling rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Social_Relation_With ;
             rdf:type owl:SymmetricProperty ;
             rdfs:label "has sibling" .


###  http://michaeldebellis.com/people/has_Sister
:has_Sister rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Sibling ;
            rdfs:range [ rdf:type owl:Restriction ;
                         owl:onProperty :has_Gender ;
                         owl:hasValue :Female
                       ] ;
            rdfs:label "has sister" .


###  http://michaeldebellis.com/people/has_Social_Relation_With
:has_Social_Relation_With rdf:type owl:ObjectProperty ,
                                   owl:SymmetricProperty ;
                          rdfs:domain :Person ;
                          rdfs:range :Person ;
                          rdfs:label "has social relation with" .


###  http://michaeldebellis.com/people/has_Son
:has_Son rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :has_Child ;
         rdfs:range [ rdf:type owl:Restriction ;
                      owl:onProperty :has_Gender ;
                      owl:hasValue :Male
                    ] ;
         rdfs:label "has son" .


###  http://michaeldebellis.com/people/has_Spouse
:has_Spouse rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Social_Relation_With ;
            rdf:type owl:FunctionalProperty ,
                     owl:SymmetricProperty ;
            rdfs:domain :Adult ;
            rdfs:range :Adult ;
            rdfs:label "has spouse" .


###  http://michaeldebellis.com/people/has_State
:has_State rdf:type owl:ObjectProperty ;
           rdfs:domain :Address ;
           rdfs:range :State ;
           <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
           <http://purl.org/dc/terms/created> "2025-03-08T04:35:00Z"^^xsd:dateTime ;
           rdfs:label "has state" .


###  http://michaeldebellis.com/people/has_Uncle
:has_Uncle rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :has_Social_Relation_With ;
           rdfs:label "has uncle" .


###  http://michaeldebellis.com/people/has_Wife
:has_Wife rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_Spouse ;
          rdfs:range [ rdf:type owl:Restriction ;
                       owl:onProperty :has_Gender ;
                       owl:hasValue :Female
                     ] ;
          rdfs:label "has wife" .


###  http://michaeldebellis.com/people/is_Address_For
:is_Address_For rdf:type owl:ObjectProperty ;
                <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                <http://purl.org/dc/terms/created> "2025-03-07T04:52:50Z"^^xsd:dateTime ;
                rdfs:label "is address for" .


###  http://michaeldebellis.com/people/is_Contained_In
:is_Contained_In rdf:type owl:ObjectProperty ,
                          owl:TransitiveProperty ;
                 <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                 <http://purl.org/dc/terms/created> "2025-03-08T04:30:05Z"^^xsd:dateTime ;
                 rdfs:label "is contained in" .


###  http://michaeldebellis.com/people/is_Employer_Of
:is_Employer_Of rdf:type owl:ObjectProperty ;
                <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                <http://purl.org/dc/terms/created> "2025-03-08T05:00:15Z"^^xsd:dateTime ;
                rdfs:label "is employer of" .


###  http://michaeldebellis.com/people/is_Faster_Than
:is_Faster_Than rdf:type owl:ObjectProperty ;
                owl:inverseOf :is_Slower_Than ;
                rdf:type owl:TransitiveProperty ;
                <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                <http://purl.org/dc/terms/created> "2025-03-08T03:30:10Z"^^xsd:dateTime ;
                rdfs:label "is faster than" .


###  http://michaeldebellis.com/people/is_Member_Of
:is_Member_Of rdf:type owl:ObjectProperty ;
              <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
              <http://purl.org/dc/terms/created> "2025-03-07T05:01:03Z"^^xsd:dateTime ;
              rdfs:label "is member of" .


###  http://michaeldebellis.com/people/is_Pet_Of
:is_Pet_Of rdf:type owl:ObjectProperty ;
           rdfs:domain :Pet ;
           rdfs:range :Human ;
           <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
           <http://purl.org/dc/terms/created> "2025-03-08T03:38:40Z"^^xsd:dateTime ;
           rdfs:label "is pet of" .


###  http://michaeldebellis.com/people/is_Slower_Than
:is_Slower_Than rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                rdfs:domain :Movement_Speed ;
                rdfs:range :Movement_Speed ;
                <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                <http://purl.org/dc/terms/created> "2025-03-08T03:30:19Z"^^xsd:dateTime ;
                rdfs:label "is slower than" .


#################################################################
#    Data properties
#################################################################

###  http://michaeldebellis.com/people/age
:age rdf:type owl:DatatypeProperty ,
              owl:FunctionalProperty ;
     rdfs:domain :Person ;
     rdfs:range xsd:integer ;
     rdfs:label "age" ;
     skos:example 12 ,
                  32 .


###  http://michaeldebellis.com/people/nobel_Prize_Winner
:nobel_Prize_Winner rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Person ;
                    rdfs:range xsd:boolean ;
                    <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                    <http://purl.org/dc/terms/created> "2025-03-11T15:44:10Z"^^xsd:dateTime ;
                    rdfs:label "nobel prize winner" .


###  http://michaeldebellis.com/people/number_Of_Social_Relations
:number_Of_Social_Relations rdf:type owl:DatatypeProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain :Person ;
                            rdfs:range xsd:integer ;
                            rdfs:label "number of social relations" .


###  http://michaeldebellis.com/people/street
:street rdf:type owl:DatatypeProperty ;
        rdfs:domain :Address ;
        <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
        <http://purl.org/dc/terms/created> "2025-03-07T04:54:14Z"^^xsd:dateTime ;
        rdfs:label "street" .


###  http://michaeldebellis.com/people/unit
:unit rdf:type owl:DatatypeProperty ;
      rdfs:domain :Address ;
      <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
      <http://purl.org/dc/terms/created> "2025-03-07T04:56:27Z"^^xsd:dateTime ;
      rdfs:label "unit" ;
      skos:altLabel "apartment" ,
                    "suite" .


###  http://michaeldebellis.com/people/zip
:zip rdf:type owl:DatatypeProperty ;
     rdfs:domain :Address ;
     <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
     <http://purl.org/dc/terms/created> "2025-03-07T04:54:29Z"^^xsd:dateTime ;
     rdfs:label "zip" .


#################################################################
#    Classes
#################################################################

###  http://michaeldebellis.com/people/Address
:Address rdf:type owl:Class ;
         rdfs:subClassOf :Place ;
         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
         <http://purl.org/dc/terms/created> "2025-03-07T04:49:53Z"^^xsd:dateTime ;
         rdfs:label "Address" .


###  http://michaeldebellis.com/people/Adult
:Adult rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Person
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :age ;
                                                    owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                         owl:onDatatype xsd:integer ;
                                                                         owl:withRestrictions ( [ xsd:minExclusive 18
                                                                                                ]
                                                                                              )
                                                                       ]
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :Person ;
       rdfs:label "Adult" .


###  http://michaeldebellis.com/people/Agent
:Agent rdf:type owl:Class ;
       <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
       <http://purl.org/dc/terms/created> "2025-03-07T04:49:12Z"^^xsd:dateTime ;
       rdfs:label "Agent" .


###  http://michaeldebellis.com/people/Animal
:Animal rdf:type owl:Class ;
        rdfs:subClassOf :Living_Thing ;
        owl:disjointWith :Plant ;
        <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
        <http://purl.org/dc/terms/created> "2025-03-08T03:19:49Z"^^xsd:dateTime ;
        rdfs:label "Animal" .


###  http://michaeldebellis.com/people/Bird
:Bird rdf:type owl:Class ;
      rdfs:subClassOf :Vertebrate ;
      <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
      <http://purl.org/dc/terms/created> "2025-03-08T03:19:49Z"^^xsd:dateTime ;
      rdfs:label "Bird" .


###  http://michaeldebellis.com/people/Boy
:Boy rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( :Child
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :has_Gender ;
                                                  owl:hasValue :Male
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
     rdfs:subClassOf :Child ;
     owl:disjointWith :Girl ;
     rdfs:label "Boy" .


###  http://michaeldebellis.com/people/Cat
:Cat rdf:type owl:Class ;
     rdfs:subClassOf :Mammal ;
     owl:disjointWith :Hedgehog ;
     <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
     <http://purl.org/dc/terms/created> "2025-03-08T03:21:56Z"^^xsd:dateTime ;
     rdfs:label "Cat" .


###  http://michaeldebellis.com/people/Child
:Child rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Person
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :age ;
                                                    owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                         owl:onDatatype xsd:integer ;
                                                                         owl:withRestrictions ( [ xsd:maxExclusive 18
                                                                                                ]
                                                                                              )
                                                                       ]
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :Person ;
       rdfs:label "Child" .


###  http://michaeldebellis.com/people/City
:City rdf:type owl:Class ;
      rdfs:subClassOf :Place ;
      <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
      <http://purl.org/dc/terms/created> "2025-03-08T04:29:31Z"^^xsd:dateTime ;
      rdfs:label "City" .


###  http://michaeldebellis.com/people/Corporation
:Corporation rdf:type owl:Class ;
             rdfs:subClassOf :Organization ;
             <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
             <http://purl.org/dc/terms/created> "2025-03-11T15:20:49Z"^^xsd:dateTime ;
             rdfs:label "Corporation" .


###  http://michaeldebellis.com/people/Daisys_Husband
:Daisys_Husband rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Man
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :has_Wife ;
                                                             owl:hasValue :Daisy_Buchanan
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Man ;
                rdfs:label "Daisys Husband" .


###  http://michaeldebellis.com/people/Dog
:Dog rdf:type owl:Class ;
     rdfs:subClassOf :Mammal ;
     owl:disjointWith :Fish ,
                      :Hedgehog ;
     <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
     <http://purl.org/dc/terms/created> "2025-03-08T03:21:56Z"^^xsd:dateTime ;
     rdfs:label "Dog" .


###  http://michaeldebellis.com/people/Fish
:Fish rdf:type owl:Class ;
      rdfs:subClassOf :Vertebrate ;
      <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
      <http://purl.org/dc/terms/created> "2025-03-08T03:46:44Z"^^xsd:dateTime ;
      rdfs:label "Fish" .


###  http://michaeldebellis.com/people/Flower
:Flower rdf:type owl:Class ;
        rdfs:subClassOf :Plant ;
        owl:disjointWith :Tree ;
        <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
        <http://purl.org/dc/terms/created> "2025-03-08T03:19:49Z"^^xsd:dateTime ;
        rdfs:label "Flower" .


###  http://michaeldebellis.com/people/Gender
:Gender rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :Female
                                          :Male
                                          :Non_Binary
                                        )
                            ] ;
        rdfs:label "Gender" .


###  http://michaeldebellis.com/people/Girl
:Girl rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Child
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :has_Gender ;
                                                   owl:hasValue :Female
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :Child ;
      rdfs:label "Girl" .


###  http://michaeldebellis.com/people/Gold_Fish
:Gold_Fish rdf:type owl:Class ;
           rdfs:subClassOf :Fish ;
           <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
           <http://purl.org/dc/terms/created> "2025-03-08T03:46:53Z"^^xsd:dateTime ;
           rdfs:label "Gold Fish" .


###  http://michaeldebellis.com/people/Haddock
:Haddock rdf:type owl:Class ;
         rdfs:subClassOf :Fish ;
         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
         <http://purl.org/dc/terms/created> "2025-03-11T13:45:26Z"^^xsd:dateTime ;
         rdfs:label "Haddock" .


###  http://michaeldebellis.com/people/Halibut
:Halibut rdf:type owl:Class ;
         rdfs:subClassOf :Fish ;
         <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
         <http://purl.org/dc/terms/created> "2025-03-08T03:49:36Z"^^xsd:dateTime ;
         rdfs:label "Halibut" .


###  http://michaeldebellis.com/people/Hedgehog
:Hedgehog rdf:type owl:Class ;
          rdfs:subClassOf :Mammal ;
          <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
          <http://purl.org/dc/terms/created> "2025-03-08T03:39:41Z"^^xsd:dateTime ;
          rdfs:label "Hedgehog" .


###  http://michaeldebellis.com/people/Hermit
:Hermit rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Person
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :has_Social_Relation_With ;
                                                     owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                     owl:onClass :Person
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:label "Hermit" .


###  http://michaeldebellis.com/people/Human
:Human rdf:type owl:Class ;
