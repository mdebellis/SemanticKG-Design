        prov:Entity ;
    rdfs:label "SF Creator Insights Dataset"@en ;
    dctm:description "Aggregated creator KPIs used by StreamForge teams for executive dashboards, creator growth analysis, and reporting on engagement and performance trends."@en,
        "Aggregated creator KPIs used for executive dashboards, growth analysis, and weekly reporting on creator engagement and performance trends."@en,
        "Daily aggregated creator analytics dataset for operational dashboards and reporting"@en,
        "Weekly aggregated creator KPIs for executive dashboards and reporting."@en ;
    dctm:publisher dp:StreamForge_Organization ;
    dctm:title "StreamForge Creator Insights Dataset"@en ;
    dcat:distribution sf:SF_Creator_Insights_Distribution ;
    prov:wasDerivedFrom sf:Creator_Profile_Dataset,
        sf:Engagement_Events_Dataset,
        sf:Video_Metadata_Dataset ;
    prov:wasGeneratedBy sf:Creator_Insights_Aggregation_Run_2026_02_08 ;
    dp:embedding_note "SF Creator Insights Dataset has distribution SF Creator Insights Distribution."@en,
        "SF Creator Insights Dataset has publisher StreamForge Organization."@en,
        "SF Creator Insights Dataset is an instance of Dataset."@en,
        "SF Creator Insights Dataset was derived from Creator Profile Dataset."@en,
        "SF Creator Insights Dataset was derived from Engagement Signals  Dataset."@en,
        "SF Creator Insights Dataset was derived from Video Metadata Dataset."@en,
        "SF Creator Insights Dataset was generated by Creator Insights Aggregation Pipeline (2026-02-08)."@en .

sf:SF_Engagement_Events_Dataset a owl:NamedIndividual,
        dcat:Dataset ;
    rdfs:label "SF Engagement Events Dataset"@en ;
    dctm:description "Event-level engagement telemetry used to compute creator analytics, KPI aggregates, and downstream reporting."@en ;
    dcat:keyword "creator analytics"@en,
        "engagement"@en,
        "telemetry"@en ;
    dp:embedding_note "SF Engagement Events Dataset has keyword creator analytics."@en,
        "SF Engagement Events Dataset has keyword engagement."@en,
        "SF Engagement Events Dataset has keyword telemetry."@en,
        "SF Engagement Events Dataset is an instance of Dataset."@en .

dp:Bounded_Context a owl:Class ;
    rdfs:label "Bounded Context"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2025-12-12T04:24:48+00:00"^^xsd:dateTime ;
    rdfs:comment "A coherent domain model boundary in the sense of Domain-Driven Design."@en,
        "Data Product usage: Bounded contexts scope the semantics and meaning of Data Products and help manage dependencies between products owned by different domains."@en ;
    skos:definition "A bounded context defines the boundary within which a particular domain model and vocabulary apply."@en,
        "enenenBounded Context is a concept from Domain-Driven Design (DDD) that defines a clear boundary within which a particular domain model, vocabulary, and set of assumptions are valid and consistently used. Within a bounded context, terms have precise meanings and models are internally coherent, while the same terms may have different meanings in other contexts. By explicitly defining these boundaries, bounded contexts reduce ambiguity, limit coupling between systems, and enable teams to evolve models independently while integrating with other contexts through well-defined interfaces or translation mechanisms."@en ;
    dp:embedding_note "Bounded Context has contributor Michael DeBellis."@en .

dp:Contract a owl:Class ;
    rdfs:label "Contract"@en ;
    rdfs:comment "A contract describing the agreed behavior, interfaces, or constraints of a Data Product."@en,
        "Data Product usage: Contracts capture expectations such as availability, quality, and permitted use of a Data Product."@en ;
    skos:definition "A formal agreement defining obligations, expectations, and responsibilities associated with a Data Product."@en ;
    dp:embedding_note "Data Contract is a kind of Contract."@en,
        "Service Level Agreement is a kind of Contract."@en .

dp:Interface a owl:Class ;
    rdfs:label "Interface"@en ;
    rdfs:comment "A data product exposes ports; ports implement interfaces; contracts reference interfaces." ;
    rdfs:subClassOf dp:Catalog_Asset ;
    dp:embedding_note "Interface is a kind of Catalog Asset."@en .

dp:Programming_Language a owl:Class ;
    rdfs:label "Programming language"@en ;
    rdfs:subClassOf dp:Implementation_Technology ;
    dp:embedding_note "Programming language is a kind of Implementation Technology."@en .

dp:Quality_Metric a owl:Class ;
    rdfs:label "Quality Metric"@en ;
    rdfs:comment "A metric describing some aspect of data quality such as completeness, accuracy, or timeliness for a Data Product version."@en,
        "Data Product usage: Quality metrics support governance and consumer trust by making data quality explicit and monitorable."@en ;
    rdfs:subClassOf dp:Reference_Value ;
    skos:definition "A measurable indicator used to assess the quality of a Data Product."@en ;
    dp:embedding_note "Quality Metric is a kind of Reference Value."@en .

dp:SF_Engagement_Events_Dataset a owl:NamedIndividual,
        dcat:Dataset ;
    rdfs:label "Engagement Events Dataset"@en ;
    dctm:description "StreamForge engagement events (e.g., play_video, like, share, subscribe) captured from the event stream and curated for analytics consumption."@en ;
    dp:embedding_note "Engagement Events Dataset is an instance of Dataset."@en .

sf:Creator_Profile_Dataset a owl:NamedIndividual,
        dcat:Dataset,
        prov:Entity ;
    rdfs:label "Creator Profile Dataset"@en ;
    dctm:description "Creator reference data used for analytics joins (e.g., creator tier, region, account status, and eligibility flags)."@en,
        "Creator-level reference data (creator identifiers, account status, and other profile attributes) used to group, filter, and interpret engagement signals for reporting and governance."@en,
        "Reference dataset used to group and interpret creator engagement metrics, including creator attributes used in analytics joins."@en ;
    dcat:keyword "analytics join"@en,
        "creator profile"@en,
        "reference data"@en ;
    dp:embedding_note "Creator Profile Dataset has keyword analytics join."@en,
        "Creator Profile Dataset has keyword creator profile."@en,
        "Creator Profile Dataset has keyword reference data."@en,
        "Creator Profile Dataset is an instance of Dataset."@en .

sf:Ingestion_And_Metadata_Bounded_Context a owl:NamedIndividual ;
    rdfs:label "Ingestion And Metadata Bounded Context"@en ;
    dctm:description "Context for ingesting video assets and maintaining their metadata and lineage."@en .

odrl:Rule a owl:Class ;
    rdfs:label "Rule"@en ;
    rdfs:isDefinedBy odrl: ;
    skos:definition "An abstract concept that represents the common characteristics of Permissions, Prohibitions, and Duties."@en .

dp:Access_Type a owl:Class ;
    rdfs:label "Access Type"@en ;
    rdfs:subClassOf dp:Reference_Value ;
    skos:definition "A controlled value indicating the access mechanism by which consumers retrieve or interact with a Data Product, such as SQL access or API access."@en ;
    dp:embedding_note "Access Type is a kind of Reference Value."@en .

dp:Account a owl:Class ;
    rdfs:label "Account"@en ;
    rdfs:comment "In StreamForge, accounts are associated only with individual people. Extending this to organizational or brand accounts would require widening the domain to prov:Agent or introducing channels."@en ;
    rdfs:subClassOf prov:Entity .

docs:Document a owl:Class ;
    rdfs:label "Document"@en ;
    dctm:description "A narrative information artifact intended for human consumption (e.g., report, memo, incident write-up) and used as retrievable context in RAG."@en ;
    rdfs:subClassOf dp:Catalog_Asset ;
    dp:embedding_note "Document is a kind of Catalog Asset."@en,
        "Report is a kind of Document."@en,
        "Strategy Memo is a kind of Document."@en .

dp:API_Access a owl:NamedIndividual,
        dp:Access_Type ;
    rdfs:label "API Access"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-16T01:24:47+00:00"^^xsd:dateTime ;
    dp:embedding_note "API Access has contributor Michael DeBellis."@en,
        "API Access is an instance of Access Type."@en .

dp:Analytic_Data_Port a owl:Class ;
    rdfs:label "Query Port"@en ;
    rdfs:subClassOf dp:Data_Product_Port ;
    dp:embedding_note "Query Port is a kind of Data Product Port."@en .

dcat:Catalog a owl:Class ;
    rdfs:label "Catalog"@en ;
    skos:definition "A catalog is a curated collection of metadata describing data products, datasets, and services, intended to support discovery, understanding, and governance. In a data mesh architecture, the catalog acts as the primary entry point for consumers to find and evaluate data products across bounded contexts."@en,
        "A curated collection of metadata about resources."@en ;
    skos:scopeNote "Use dcat:Catalog for the thing that *lists* datasets/services (often one per org/system). Members can be linked via dcat:resource and its subproperties (dcat:dataset, dcat:service, dcat:catalog)."@en .

dcat:Distribution a owl:Class ;
    rdfs:label "Distribution"@en ;
    rdfs:subClassOf dp:Catalog_Asset ;
    skos:definition "A specific representation of a dataset. A dataset might be available in multiple serializations that may differ in various ways, including natural language, media-type or format, schematic organization, temporal and spatial resolution, level of detail or profiles."@en ;
    skos:scopeNote "Use distributions for concrete downloadable artifacts or access endpoints. A distribution does not *by itself* imply the access mechanism; properties like dcat:downloadURL and dcat:accessURL clarify how it is accessed."@en ;
    dp:embedding_note "Distribution is a kind of Catalog Asset."@en .

dcat:Role a owl:Class ;
    rdfs:label "Role"@en ;
    skos:definition "A role is the function of a resource or agent with respect to another resource, in the context of resource attribution or resource relationships."@en ;
    skos:scopeNote "Use dcat:Role as a controlled-vocabulary concept (typically via qualified attribution) to state how an agent relates to a resource (e.g., publisher, custodian, author, maintainer)."@en .

prov:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:subClassOf prov:Agent ;
    dp:embedding_note "Person is a kind of Agent."@en,
        "User is a kind of Person."@en .

dp:Context_Map_Relationship a owl:Class ;
    rdfs:label "Context Map Relationship"@en ;
    skos:definition "A context map relationship represents an explicit, reified relationship between two bounded contexts, capturing how they interact, depend on each other, or exchange data. Unlike a simple link, a context map relationship can carry additional semantics such as relationship type, contracts, and interfaces."@en .

dp:Nation a owl:Class ;
    rdfs:label "Nation"@en ;
    rdfs:subClassOf dp:Place .

dp:SQL_Access a owl:NamedIndividual,
        dp:Access_Type ;
    rdfs:label "SQL Access"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-16T01:24:31+00:00"^^xsd:dateTime ;
    dp:embedding_note "SQL Access has contributor Michael DeBellis."@en,
        "SQL Access is an instance of Access Type."@en .

skos:Concept a owl:Class ;
    rdfs:label "Concept"@en ;
    rdfs:comment "The class skos:Concept is the class of SKOS concepts. A SKOS concept can be viewed as an idea or notion; a unit of thought. However, what constitutes a unit of thought is subjective, and this definition is meant to be suggestive, rather than restrictive. The notion of a SKOS concept is useful when describing the conceptual or intellectual structure of a knowledge organization system, and when referring to specific ideas or meanings established within a KOS. Note that, because SKOS is designed to be a vehicle for representing semi-formal KOS, such as thesauri and classification schemes, a certain amount of flexibility has been built in to the formal definition of this class."@en .

prov:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    dctm:description "In PROV-O, an Agent represents an accountable actor such as a person, organization, or software service. Agents are typically connected to Activities via prov:wasAssociatedWith and can be connected to Entities via attribution relations such as prov:wasAttributedTo."@en ;
    dctm:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:comment "Use prov:Agent for accountable actors: people, teams, organizations, services, or system accounts that participate in or are responsible for activities and outputs."@en ;
    rdfs:isDefinedBy prov: ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "An agent is something that bears some form of responsibility for an activity taking place, for the existence of an entity, or for another agent’s activity."@en ;
    skos:editorialNote "If you already use other vocabularies (e.g., FOAF/ORG), you can map those classes to prov:Agent via rdfs:subClassOf or owl:equivalentClass, but it’s also fine to keep it lightweight."@en ;
    skos:example "Example: :Data_Curation_Team a prov:Agent .  :Validator_Service_Account a prov:Agent .  :Validation_Run_42 a prov:Activity ; prov:wasAssociatedWith :Validator_Service_Account ."@en ;
    skos:note "PROV treats responsibility broadly; an Agent can be human or non-human (e.g., a scheduled service). For delegated responsibility, see properties such as prov:actedOnBehalfOf."@en ;
    skos:prefLabel "Agent"@en ;
    skos:scopeNote "If you need finer distinctions, introduce subclasses (e.g., :Person, :Organization, :Software_Agent) and keep them aligned under prov:Agent."@en ;
    dp:embedding_note "Agent has example Example: :Data_Curation_Team a prov:Agent .  :Validator_Service_Account a prov:Agent .  :Validation_Run_42 a prov:Activity ; prov:wasAssociatedWith :Validator_Service_Account ."@en,
        "Agent has source https://www.w3.org/TR/prov-o/."@en .

dp:Data_Product_Port a owl:Class ;
    rdfs:label "Data Product Port"@en ;
    rdfs:comment "A data product exposes ports; ports implement interfaces; contracts reference interfaces." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass dp:Data_Product ;
            owl:onProperty dp:is_port_of ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        dp:Catalog_Asset ;
    skos:definition "A Data Port is a formally defined interface through which a data product exposes or consumes data, metadata, or services. It specifies how a data product can be accessed or integrated—such as through files, APIs, queries, or event streams—without exposing internal implementation details. Data ports provide a clear contract that includes access method, structure, semantics, and applicable governance constraints. In a data-product architecture, ports enable interoperability between products and bounded contexts while supporting independent evolution. When combined with Semantic Knowledge Graphs, data ports are often described using explicit semantic models, allowing their inputs, outputs, and constraints to be understood and validated consistently across the enterprise." ;
    dp:embedding_note "Data Product Port is a kind of Catalog Asset."@en,
        "Input Port is a kind of Data Product Port."@en,
        "Operational Port is a kind of Data Product Port."@en,
        "Output Port is a kind of Data Product Port."@en,
        "Platform Port is a kind of Data Product Port."@en,
        "Query Port is a kind of Data Product Port."@en .

dp:Port_Implementation a owl:Class ;
    rdfs:label "Port Implementation"@en ;
    rdfs:comment "An implementation artifact (code, service, or configuration) that realizes a data product port."@en ;
    rdfs:subClassOf dp:Catalog_Asset ;
    skos:definition "A Port  Implementation is the concrete realization of a Data Port in a working system, where models are instantiated using specific technologies, tools, and configurations." ;
    dp:embedding_note "Port Implementation is a kind of Catalog Asset."@en .

prov:Entity a owl:Class ;
    rdfs:label "Entity"@en ;
    dctm:description "In PROV-O, an Entity represents things such as datasets, documents, records, graphs, configurations, or conceptual artifacts. Entities are commonly related to Activities through prov:wasGeneratedBy (generation) and prov:used (usage), and to other Entities through derivation relations such as prov:wasDerivedFrom."@en ;
    dctm:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:comment "Use prov:Entity for the things that Activities act upon, produce, or transform—files, datasets, graph snapshots, reports, models, etc."@en ;
    rdfs:isDefinedBy prov: ;
    skos:definition "An entity is a physical, digital, conceptual, or other kind of thing with some fixed aspects; entities may be real or imaginary."@en ;
    skos:editorialNote "Try not to overload prov:Entity with process semantics—keep transformation/process semantics on prov:Activity."@en ;
    skos:example "Example: :Customer_Master_Snapshot_2026_01_15 a prov:Entity ; prov:wasGeneratedBy :Nightly_Build_Run_2026_01_15 ; prov:wasDerivedFrom :Customer_Master_Snapshot_2026_01_14 ."@en ;
    skos:note "If you track versions, you can represent each version as a distinct prov:Entity and relate them with prov:wasDerivedFrom and/or specialization (prov:specializationOf)."@en ;
    skos:prefLabel "Entity"@en ;
    skos:scopeNote "Model an Entity when you want to track provenance of an artifact or thing (inputs/outputs, derivations, versions). Pair with prov:Activity to explain how it was produced or changed."@en ;
    dp:embedding_note "Entity has example Example: :Customer_Master_Snapshot_2026_01_15 a prov:Entity ; prov:wasGeneratedBy :Nightly_Build_Run_2026_01_15 ; prov:wasDerivedFrom :Customer_Master_Snapshot_2026_01_14 ."@en,
        "Entity has source https://www.w3.org/TR/prov-o/."@en .

dp:Data_Product_Team a owl:Class ;
    rdfs:label "Data Product Team"@en ;
    rdfs:comment "A team or group of people responsible for owning and operating a Data Product."@en,
        "Data Product usage: Data Product Teams are the accountable owners of Data Products, aligning with domain-oriented ownership models such as Domain-Driven Design and Data Mesh."@en ;
    rdfs:subClassOf prov:Organization ;
    skos:definition "A team responsible for the development, operation, and lifecycle management of one or more Data Products."@en ;
    dp:embedding_note "Data Product Team is a kind of Organization."@en .

sf:SF_Video_Metadata_Dataset a owl:NamedIndividual,
        dcat:Dataset ;
    rdfs:label "SF Video Metadata Dataset"@en ;
    dctm:description "Canonical dataset describing videos and their metadata, used by multiple StreamForge products."@en,
        "Canonical video metadata replicated for analytics and downstream services."@en,
        "Curated video metadata including creator, upload time, category, language, region, and moderation flags used by downstream analytics."@en ;
    dctm:publisher dp:StreamForge_Organization ;
    dctm:title "StreamForge Video Metadata Dataset"@en ;
    dcat:distribution sf:SF_Video_Metadata_Distribution ;
    dcat:keyword "content attributes"@en,
        "downstream analytics"@en,
        "video metadata"@en ;
    dp:embedding_note "SF Video Metadata Dataset has distribution SF Video Metadata Distribution."@en,
        "SF Video Metadata Dataset has keyword content attributes."@en,
        "SF Video Metadata Dataset has keyword downstream analytics."@en,
        "SF Video Metadata Dataset has keyword video metadata."@en,
        "SF Video Metadata Dataset has publisher StreamForge Organization."@en,
        "SF Video Metadata Dataset is an instance of Dataset."@en .

odrl:Policy a owl:Class ;
    rdfs:label "Policy"@en ;
    rdfs:isDefinedBy odrl: ;
    skos:definition "A non-empty group of Permissions and/or Prohibitions." ;
    skos:note "A Policy may contain multiple Rules." ;
    dp:embedding_note "Computational Policy is a kind of Policy."@en,
        "Privacy Policy is a kind of Policy."@en .

dp:Catalog_Asset a owl:Class ;
    rdfs:label "Catalog Asset"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-10T05:01:45+00:00"^^xsd:dateTime ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "An asset is a managed artifact of value within a data platform, such as a data product, dataset, interface, port, implementation, or contract. Assets are identifiable, governable, and traceable entities that can participate in provenance, ownership, and lifecycle management."@en,
        """An entity represented in the Data Catalog, such as a Data Product,
Container, Interface, or other catalog-managed resource."""@en ;
    dp:embedding_note "Catalog Asset has contributor Michael DeBellis."@en,
        "Catalog Asset is a kind of Entity."@en,
        "Component is a kind of Catalog Asset."@en,
        "Container is a kind of Catalog Asset."@en,
        "Context Map is a kind of Catalog Asset."@en,
        "Data Product Port is a kind of Catalog Asset."@en,
        "Data Product is a kind of Catalog Asset."@en,
        "Dataset is a kind of Catalog Asset."@en,
        "Distribution is a kind of Catalog Asset."@en,
        "Document Chunk is a kind of Catalog Asset."@en,
        "Document is a kind of Catalog Asset."@en,
        "Implementation Artifact is a kind of Catalog Asset."@en,
        "Interface is a kind of Catalog Asset."@en,
        "Port Implementation is a kind of Catalog Asset."@en,
        "Service is a kind of Catalog Asset."@en,
        "Video is a kind of Catalog Asset."@en .

dp:City a owl:Class ;
    rdfs:label "City"@en ;
    rdfs:subClassOf dp:Place .

dp:Place a owl:Class ;
    rdfs:label "Place"@en .

sf:Video a owl:Class,
        owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "Video"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-20T23:32:35+00:00"^^xsd:dateTime,
        "2026-01-20T23:55:29+00:00"^^xsd:dateTime ;
    rdfs:subClassOf dp:Catalog_Asset ;
    dp:embedding_note "Video has contributor Michael DeBellis."@en,
        "Video is a kind of Catalog Asset."@en .

dcat:Dataset a owl:Class ;
    rdfs:label "Dataset"@en ;
    rdfs:subClassOf dcat:Resource,
        dp:Catalog_Asset ;
    skos:definition "A collection of data, published or curated by a single agent, and available for access or download in one or more serializations or formats."@en ;
    skos:scopeNote "Treat a dataset as the conceptual thing; use one or more dcat:Distribution individuals to represent concrete serializations (CSV, Parquet, Turtle, API-accessible form, etc.)."@en ;
    dp:embedding_note "Dataset is a kind of Catalog Asset."@en,
        "Dataset is a kind of Resource."@en .

dp:Data_Product a owl:Class ;
    rdfs:label "Data Product"@en ;
    rdfs:comment "A domain-owned, versioned data microservice that exposes datasets and services together with contracts and quality guarantees."@en,
        "Data Product usage: A Data Product represents the unit of ownership, governance, and consumption. It is not equivalent to a dataset or service, but is realized through them."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dp:has_bounded_context ;
            owl:someValuesFrom dp:Bounded_Context ],
        dp:Catalog_Asset ;
    skos:definition "enenenenenenenA data product is an organizationally owned data artifact, produced and maintained by a domain, that is intentionally designed for consumption, governed by explicit policies, and exposed through one or more standardized interfaces.",
        "An organizationally owned data artifact designed for consumption, governed by explicit policies, versioned over time, and realized through one or more datasets or services."@en ;
    dp:embedding_note "Data Product is a kind of Catalog Asset."@en .

docs:Document_Chunk a owl:Class ;
    rdfs:label "Document Chunk"@en ;
    rdfs:subClassOf dp:Catalog_Asset ;
    dp:embedding_note "Document Chunk is a kind of Catalog Asset."@en .

[] a owl:AllDisjointClasses ;
    owl:members ( dp:Analytic_Data_Port dp:Operational_Data_Port dp:Platform_Port ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dp:Control_Port dp:Discover-Observe_Port dp:Input_Port dp:Output_Port ) .

