    skos:definition "An available distribution of the dataset."@en ;
    skos:note "An available distribution of the dataset."@en ;
    skos:scopeNote "Use dcat:distribution to link a dataset to concrete representations (files, dumps, endpoints) modeled as dcat:Distribution. Put format and access info on the Distribution."@en ;
    dp:embedding_label "has distribution"@en ;
    dp:embedding_note "distribution has definition An available distribution of the dataset."@en,
        "distribution has scope note Use dcat:distribution to link a dataset to concrete representations (files, dumps, endpoints) modeled as dcat:Distribution. Put format and access info on the Distribution."@en .

dcat:downloadURL a owl:AnnotationProperty ;
