sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_01 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 01"@en ;
    docs:chunk_index 1 ;
    docs:chunk_text "This audit summarizes moderation actions and evaluates whether policy enforcement is consistent, timely, and auditable. It focuses on takedowns and reinstatements."@en ;
    docs:chunk_title "Purpose"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 01 has title Purpose."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 01 is an instance of Document Chunk."@en .

sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_02 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 02"@en ;
    docs:chunk_index 2 ;
    docs:chunk_text "We used the Moderation Actions data product (event-level) and joined to the Video Metadata data product for canonical content attributes such as category and privacy state."@en ;
    docs:chunk_title "Data products used"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 02 has title Data products used."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 02 is an instance of Document Chunk."@en .

sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_03 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 03"@en ;
    docs:chunk_index 3 ;
    docs:chunk_text "Median time from flag to decision improved from 18 hours to 11 hours. However, a long tail of cases exceeded 7 days, often due to missing metadata needed for review."@en ;
    docs:chunk_title "Findings on timeliness"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 03 has title Findings on timeliness."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 03 is an instance of Document Chunk."@en .

sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_04 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 04"@en ;
    docs:chunk_index 4 ;
    docs:chunk_text "Some actions were missing reviewer identifiers, making post-hoc audits difficult. We recommend enforcing required fields at ingestion and generating operational alerts when fields are null."@en ;
    docs:chunk_title "Auditability gaps"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 04 has title Auditability gaps."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 04 is an instance of Document Chunk."@en .

sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_05 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 05"@en ;
    docs:chunk_index 5 ;
    docs:chunk_text "Add lineage records linking moderation events to the policy version used at decision time. Maintain a documented retention policy for moderation logs and related evidence."@en ;
    docs:chunk_title "Recommended controls"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 05 has title Recommended controls."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 05 is an instance of Document Chunk."@en .

sf:Trust_And_Safety_Moderation_Audit_Summary_2025_Chunk_06 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Trust And Safety Moderation Audit Summary 2025 Chunk 06"@en ;
    docs:chunk_index 6 ;
    docs:chunk_text "Publish a canonical moderation audit view and provide a standard dashboard for compliance stakeholders. Track policy drift via quarterly sampling and review."@en ;
    docs:chunk_title "Next steps"@en ;
    dp:embedding_note "Trust And Safety Moderation Audit Summary 2025 Chunk 06 has title Next steps."@en,
        "Trust And Safety Moderation Audit Summary 2025 Chunk 06 is an instance of Document Chunk."@en .

sf:User_Alex_Thompson a owl:NamedIndividual,
        dp:User ;
    rdfs:label "Alex Thompson (User)"@en ;
    dctm:description """Alex Thompson is a synthetic example user representing a high-engagement viewer who watches across multiple categories and frequently interacts with recommended content. This user is used in examples where engagement events influence downstream metrics and personalization features.

Alex is intentionally modeled to help RAG responses explain how user-level events roll up into creator KPIs and executive dashboards, and how operational issues in event pipelines can distort business interpretation."""@en ;
    skos:definition "A high-engagement StreamForge user used as an example for analytics and segmentation narratives."@en ;
    skos:note "Synthetic example user for StreamForge."@en ;
    dp:embedding_note "Alex Thompson (User) is an instance of User."@en .

sf:User_Samara_Kim a owl:NamedIndividual,
        dp:User ;
    rdfs:label "Samara Kim (User)"@en ;
    dctm:description """Samara Kim is a synthetic example user representing a new viewer whose engagement is concentrated in onboarding flows and early discovery experiences. This user is used to illustrate how growth metrics and retention definitions can be sensitive to cohort selection, reporting windows, and data freshness.

Samara helps RAG answers that need to clarify metric semantics, especially when a business stakeholder asks why onboarding KPIs changed after a pipeline update or a definition change."""@en ;
    skos:definition "A synthetic example representing a new StreamForge user in early onboarding."@en ;
    skos:note "Synthetic example user for StreamForge."@en ;
    dp:embedding_note "Samara Kim (User) is an instance of User."@en .

