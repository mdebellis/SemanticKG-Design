<https://www.michaeldebellis.com/stream_forge_example/graphs/Meta> {

  ### Ingestion run + pipeline agent + input batch
  <https://www.michaeldebellis.com/stream_forge_example/ingestion_run_20251212T220058Z>
    a sfg:Ingestion_Run, prov:Activity ;
    rdfs:label "20251212T220058Z"@en ;
    prov:wasAssociatedWith sfg:StreamForge_Example_Pipeline_Prefect ;
    prov:used <https://www.michaeldebellis.com/stream_forge_example/input_batch_stream_forge_example_trending_snapshot_csv_20251212T220000Z> ;
    prov:startedAtTime "2025-12-12T22:00:58Z"^^xsd:dateTime ;
    prov:endedAtTime "2025-12-12T22:01:10Z"^^xsd:dateTime .

  sfg:StreamForge_Example_Pipeline_Prefect
    a sfg:Ingestion_Pipeline, prov:SoftwareAgent ;
    rdfs:label "StreamForge Example Pipeline (Prefect)"@en .

  <https://www.michaeldebellis.com/stream_forge_example/input_batch_stream_forge_example_trending_snapshot_csv_20251212T220000Z>
    a sfg:Input_Batch, prov:Entity ;
    rdfs:label "stream_forge_example_trending_snapshot.csv"@en ;
    dcterms:format "text/csv" ;
    prov:atLocation "input_data/stream_forge_example_trending_snapshot.csv" .

