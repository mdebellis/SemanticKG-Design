###  http://michaeldebellis.com/people/Man
:Man rdf:type owl:Class ;
     owl:equivalentClass [ owl:intersectionOf ( :Adult
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty :has_Gender ;
                                                  owl:hasValue :Male
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
     rdfs:label "Man" .


###  http://michaeldebellis.com/people/Movement_Speed
:Movement_Speed rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :Fast
                                                  :Medium_Speed
                                                  :Slow
                                                  :Stationary
                                                )
                                    ] ;
                <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0002-8824-9577> ;
                <http://purl.org/dc/terms/created> "2025-03-08T03:27:17Z"^^xsd:dateTime ;
                rdfs:label "Movement Speed" .


