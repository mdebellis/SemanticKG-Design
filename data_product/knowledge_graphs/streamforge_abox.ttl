<https://www.michaeldebellis.com/dp/StreamForge_Organization> rdf:type foaf:Organization ; 
  rdfs:label "StreamForge, Inc."@en ; 
  dcterms:description "Fictional organization used as a pedagogical example for Data Products, Data Catalogs, and RAG over a Semantic Knowledge Graph."@en . 
<https://www.michaeldebellis.com/dp/StreamForge_Catalog> rdf:type <http://www.w3.org/ns/dcat#Catalog> ; 
  rdfs:label "StreamForge Data Catalog"@en ; 
  dcterms:publisher <https://www.michaeldebellis.com/dp/StreamForge_Organization> ; 
  dcterms:description "A small demo catalog containing a few StreamForge datasets and services that are produced by Data Products."@en . 
<https://www.michaeldebellis.com/dp/StreamForge_Domain> rdf:type <https://www.michaeldebellis.com/dp/Domain> ; 
  rdfs:label "StreamForge Domain"@en ; 
  dcterms:description "The bounded business domain for a fictional video platform, used for examples."@en . 
<https://www.michaeldebellis.com/dp/Creator_Analytics_Bounded_Context> rdf:type <https://www.michaeldebellis.com/dp/Bounded_Context> ; 
  rdfs:label "Creator Analytics"@en ; 
  dcterms:description "Context for creator dashboards, monetization, and audience analytics."@en . 
<https://www.michaeldebellis.com/dp/Content_Discovery_Bounded_Context> rdf:type <https://www.michaeldebellis.com/dp/Bounded_Context> ; 
  rdfs:label "Content Discovery"@en ; 
  dcterms:description "Context for search, ranking, and recommendation features."@en . 
<https://www.michaeldebellis.com/dp/Ingestion_And_Metadata_Bounded_Context> rdf:type <https://www.michaeldebellis.com/dp/Bounded_Context> ; 
  rdfs:label "Ingestion and Metadata"@en ; 
  dcterms:description "Context for ingesting video assets and maintaining their metadata and lineage."@en . 
<https://www.michaeldebellis.com/dp/StreamForge_Data_Platform_Team> rdf:type <https://www.michaeldebellis.com/dp/Data_Product_Team> ; 
  rdfs:label "StreamForge Data Platform Team"@en ; 
  dcterms:description "Owns the shared data platform and core data products in this demo."@en . 
<https://www.michaeldebellis.com/dp/StreamForge_Personalization_Team> rdf:type <https://www.michaeldebellis.com/dp/Data_Product_Team> ; 
  rdfs:label "StreamForge Personalization Team"@en ; 
  dcterms:description "Owns ranking and recommendation data products in this demo."@en . 
<https://www.michaeldebellis.com/dp/Analytical_Data_Product_Type> rdf:type <https://www.michaeldebellis.com/dp/Data_Product_Type> ; 
  rdfs:label "Analytical Data Product"@en ; 
  dcterms:description "A data product primarily used for analytics, reporting, and dashboards."@en . 
<https://www.michaeldebellis.com/dp/Operational_Data_Product_Type> rdf:type <https://www.michaeldebellis.com/dp/Data_Product_Type> ; 
  rdfs:label "Operational Data Product"@en ; 
  dcterms:description "A data product used directly by operational systems (e.g., services supporting application features)."@en . 
<https://www.michaeldebellis.com/dp/SF_Video_Metadata_Key> rdf:type <https://www.michaeldebellis.com/dp/Product_Key> ; 
  rdfs:label "SF Video Metadata Key"@en ; 
  dcterms:description "Business key identifying the video metadata product."@en . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_Key> rdf:type <https://www.michaeldebellis.com/dp/Product_Key> ; 
  rdfs:label "SF Creator Insights Key"@en ; 
  dcterms:description "Business key identifying the creator insights product."@en . 
<https://www.michaeldebellis.com/dp/SF_Recommendations_Features_Key> rdf:type <https://www.michaeldebellis.com/dp/Product_Key> ; 
  rdfs:label "SF Recommendations Features Key"@en ; 
  dcterms:description "Business key identifying the recommendation features product."@en . 
<https://www.michaeldebellis.com/dp/SF_Metadata_Contract> rdf:type <https://www.michaeldebellis.com/dp/Contract> ; 
  rdfs:label "StreamForge Video Metadata Contract"@en ; 
  dcterms:description "Defines the semantics, ownership, and expected quality for video metadata. Intended users: ingestion pipeline, discovery services, analytics consumers."@en ; 
  rdfs:comment "Story: As a discovery engineer, I need consistent video_id, creator_id, upload time, and duration so search and ranking can join metadata reliably without brittle ad-hoc mappings."@en, "Key entities: Video, Channel, Creator, Tag, Category. Required fields: video_id, creator_id, upload_timestamp, duration_seconds. Recommended: language, topic_tags. Change policy: breaking changes only on major version increments."@en . 
<https://www.michaeldebellis.com/dp/SF_Metadata_SLA> rdf:type <https://www.michaeldebellis.com/dp/SLA> ; 
  rdfs:label "Video Metadata SLA"@en ; 
  dcterms:description "Availability target: 99.9% monthly for metadata query service. Freshness target: new uploads reflected within 15 minutes at P95."@en ; 
  rdfs:comment "Support: 24x7. Incident response: P1 acknowledged within 15 minutes; mitigation within 2 hours."@en . 
<https://www.michaeldebellis.com/dp/SF_Metadata_Quality> rdf:type <https://www.michaeldebellis.com/dp/Quality_Metric> ; 
  rdfs:label "Video Metadata Quality Metrics"@en ; 
  dcterms:description "Completeness, consistency, and timeliness metrics for core video metadata fields."@en ; 
  rdfs:comment "Completeness: required fields present for >= 99.5% of records daily. Consistency: video_id↔creator_id alignment >= 99.9%. Timeliness: ingest-to-availability median < 5 min, P95 < 15 min."@en . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_Contract> rdf:type <https://www.michaeldebellis.com/dp/Contract> ; 
  rdfs:label "Creator Insights Contract"@en ; 
  dcterms:description "Defines measures and dimensions for creator analytics: views, watch time, subscribers, revenue proxies. Consumers: dashboards and internal analytics."@en ; 
  rdfs:comment "Story: As a creator success analyst, I need daily aggregates by creator_id so I can explain growth trends without reconstructing metrics from raw events."@en, "Definitions: watch_time_minutes = total minutes watched across all plays. unique_viewers = approximate distinct viewers per day. Grain: creator_id by day."@en . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_SLA> rdf:type <https://www.michaeldebellis.com/dp/SLA> ; 
  rdfs:label "Creator Insights SLA"@en ; 
  dcterms:description "Freshness target: daily aggregates available by 06:00 UTC. Availability: 99.5% monthly for the analytics dataset."@en ; 
  rdfs:comment "Backfill policy: late events corrected for prior 7 days; beyond 7 days by request."@en . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_Quality> rdf:type <https://www.michaeldebellis.com/dp/Quality_Metric> ; 
  rdfs:label "Creator Insights Quality Metrics"@en ; 
  dcterms:description "Accuracy and coverage metrics for aggregated creator analytics."@en ; 
  rdfs:comment "Coverage: >= 99% of active creators have daily rows. Accuracy: revenue proxy within +/- 3% of monthly finance reconciliation (where applicable)."@en . 
<https://www.michaeldebellis.com/dp/SF_Recs_Features_Contract> rdf:type <https://www.michaeldebellis.com/dp/Contract> ; 
  rdfs:label "Recommendations Features Contract"@en ; 
  dcterms:description "Defines the features used by ranking/recommendation models, their refresh cycles, and intended uses."@en ; 
  rdfs:comment "Story: As a personalization engineer, I need stable feature definitions so models can be retrained and served without silent meaning changes that degrade ranking quality."@en, "Feature sets: creator_popularity_score, video_engagement_score, topic_affinity_vector (opaque). Refresh: hourly for engagement, daily for topic affinity."@en . 
<https://www.michaeldebellis.com/dp/SF_Recs_Features_SLA> rdf:type <https://www.michaeldebellis.com/dp/SLA> ; 
  rdfs:label "Recommendations Features SLA"@en ; 
  dcterms:description "Freshness target: hourly refresh completes within 20 minutes of the hour. Availability: 99.9% monthly for the online feature service endpoint."@en ; 
  rdfs:comment "Fallback: if endpoint degrades, serve cached features up to 6 hours old."@en . 
<https://www.michaeldebellis.com/dp/SF_Recs_Features_Quality> rdf:type <https://www.michaeldebellis.com/dp/Quality_Metric> ; 
  rdfs:label "Recommendations Features Quality Metrics"@en ; 
  dcterms:description "Stability and timeliness metrics for feature production."@en ; 
  rdfs:comment "Timeliness: hourly refresh success >= 99% daily. Drift: alert if engagement_score shifts > 2σ vs prior 7-day baseline."@en . 
<https://www.michaeldebellis.com/dp/SF_Video_Metadata_Dataset> rdf:type <http://www.w3.org/ns/dcat#Dataset> ; 
  rdfs:label "StreamForge Video Metadata Dataset"@en ; 
  dcterms:description "Canonical dataset describing videos and their metadata, used by multiple StreamForge products."@en ; 
  dcterms:publisher <https://www.michaeldebellis.com/dp/StreamForge_Organization> . 
<https://www.michaeldebellis.com/dp/SF_Video_Metadata_Distribution> rdf:type <http://www.w3.org/ns/dcat#Distribution> ; 
  rdfs:label "Video Metadata Parquet Distribution"@en ; 
  dcterms:description "Partitioned Parquet distribution for batch analytics access."@en ; 
  <http://www.w3.org/ns/dcat#accessURL> "https://data.streamforge.example/datasets/video_metadata/"^^xs:anyURI . 
<https://www.michaeldebellis.com/dp/SF_Video_Metadata_Service> rdf:type <http://www.w3.org/ns/dcat#DataService> ; 
  rdfs:label "Video Metadata Query Service"@en ; 
  dcterms:description "Operational query service for video metadata lookups."@en ; 
  <http://www.w3.org/ns/dcat#endpointURL> "https://api.streamforge.example/metadata/v1"^^xs:anyURI . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_Dataset> rdf:type <http://www.w3.org/ns/dcat#Dataset> ; 
  rdfs:label "StreamForge Creator Insights Dataset"@en ; 
  dcterms:description "Daily aggregated creator analytics dataset for dashboards and reporting."@en ; 
  dcterms:publisher <https://www.michaeldebellis.com/dp/StreamForge_Organization> . 
<https://www.michaeldebellis.com/dp/SF_Creator_Insights_Distribution> rdf:type <http://www.w3.org/ns/dcat#Distribution> ; 
  rdfs:label "Creator Insights Warehouse Distribution"@en ; 
  dcterms:description "Warehouse-accessible distribution of creator daily aggregates."@en ; 
  <http://www.w3.org/ns/dcat#accessURL> "https://data.streamforge.example/datasets/creator_insights/"^^xs:anyURI . 
<https://www.michaeldebellis.com/dp/SF_Recs_Features_Dataset> rdf:type <http://www.w3.org/ns/dcat#Dataset> ; 
  rdfs:label "StreamForge Recommendations Features Dataset"@en ; 
  dcterms:description "Offline feature set used for training and evaluation of recommendation models."@en ; 
  dcterms:publisher <https://www.michaeldebellis.com/dp/StreamForge_Organization> . 
<https://www.michaeldebellis.com/dp/SF_Recs_Features_Service> rdf:type <http://www.w3.org/ns/dcat#DataService> ; 
  rdfs:label "Online Feature Service"@en ; 
  dcterms:description "Low-latency endpoint serving recommendation features for online ranking."@en ; 
  <http://www.w3.org/ns/dcat#endpointURL> "https://api.streamforge.example/features/v1"^^xs:anyURI . 
