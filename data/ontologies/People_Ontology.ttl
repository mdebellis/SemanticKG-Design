#################################################################
#    Rules
#################################################################

:m1 rdf:type swrl:Variable .

:m2 rdf:type swrl:Variable .

:v1 rdf:type swrl:Variable .

:v2 rdf:type swrl:Variable .

:cv rdf:type swrl:Variable .

<http://www.semanticweb.org/mdebe/ontologies/example#p> rdf:type swrl:Variable .

<http://www.semanticweb.org/mdebe/ontologies/example#b> rdf:type swrl:Variable .

<http://www.semanticweb.org/mdebe/ontologies/example#c> rdf:type swrl:Variable .

:p rdf:type swrl:Variable .

:s rdf:type swrl:Variable .

:c rdf:type swrl:Variable .

:address rdf:type swrl:Variable .

:city rdf:type swrl:Variable .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Distance Equal Rule" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :Distance_Measurement ;
                           swrl:argument1 :m1
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate :Distance_Measurement ;
                                      swrl:argument1 :m2
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                 swrl:propertyPredicate :canonical_value ;
                                                 swrl:argument1 :m1 ;
                                                 swrl:argument2 :v1
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                            swrl:propertyPredicate :canonical_value ;
                                                            swrl:argument1 :m2 ;
                                                            swrl:argument2 :v2
                                                          ] ;
                                                rdf:rest [ rdf:type swrl:AtomList ;
                                                           rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                                       swrl:builtin swrlb:equal ;
                                                                       swrl:arguments ( :v1
                                                                                        :v2
                                                                                      )
                                                                     ] ;
                                                           rdf:rest rdf:nil
                                                         ]
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate :equal_to ;
                           swrl:argument1 :m1 ;
                           swrl:argument2 :m2
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Distance Ordering Rule" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :Distance_Measurement ;
                           swrl:argument1 :m1
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate :Distance_Measurement ;
                                      swrl:argument1 :m2
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                 swrl:propertyPredicate :canonical_value ;
                                                 swrl:argument1 :m1 ;
                                                 swrl:argument2 :v1
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                            swrl:propertyPredicate :canonical_value ;
                                                            swrl:argument1 :m2 ;
                                                            swrl:argument2 :v2
                                                          ] ;
                                                rdf:rest [ rdf:type swrl:AtomList ;
                                                           rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                                       swrl:builtin swrlb:greaterThan ;
                                                                       swrl:arguments ( :v1
                                                                                        :v2
                                                                                      )
                                                                     ] ;
                                                           rdf:rest rdf:nil
                                                         ]
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate :greater_than ;
                           swrl:argument1 :m1 ;
                           swrl:argument2 :m2
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Canonical Distance Centimeter Conversion" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :Distance_Measurement ;
                           swrl:argument1 :m1
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate :has_unit ;
                                      swrl:argument1 :m1 ;
                                      swrl:argument2 :Centimeter
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                 swrl:propertyPredicate :value ;
                                                 swrl:argument1 :m1 ;
                                                 swrl:argument2 :v1
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                            swrl:builtin swrlb:divide ;
                                                            swrl:arguments [ rdf:type rdf:List ;
                                                                             rdf:first :cv ;
                                                                             rdf:rest [ rdf:type rdf:List ;
                                                                                        rdf:first :v1 ;
