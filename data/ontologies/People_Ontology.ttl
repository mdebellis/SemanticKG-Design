             rdfs:range [ rdf:type owl:Class ;
                          owl:unionOf ( :Boy
                                        :Man
                                      )
                        ] ;
             rdfs:label "has brother" .


###  http://michaeldebellis.com/people/has_child
:has_child rdf:type owl:ObjectProperty ;
