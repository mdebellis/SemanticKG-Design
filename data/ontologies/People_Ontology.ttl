#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Bird
                :Fish
                :Mammal
                :Reptile
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Bus
                :CPU
                :Keyboard
                :Monitor
                :Motherboard
                :RAM
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Cat
                :Dog
                :Hedgehog
                :Human
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Corporation
                :Division
                :Region
                :Research_Institute
                :Sales_Office
                :University
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Albert_Einstein
                        :Elsa_Einstein
                        :Emmy_Noether
                        :Kurt_Godel
                        :Lise_Meitner
                        :Michele_Besso
                      )
] .


[ rdf:type owl:AllDifferent ;
