dp:workload_ratio a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "workload ratio"@en ;
    rdfs:domain owl:Thing,
        prov:Agent,
        prov:Entity ;
    rdfs:range xsd:decimal ;
    skos:definition "The approximate current work allocation of an agent, expressed as a decimal ratio where 1.0 represents a full standard workload, values below 1.0 indicate available capacity, and values above 1.0 indicate over-allocation."@en ;
