                                                               "Creator Growth Metric Computation Run (2026-03-03)"@en ;
                                                    skos:definition "An analytics computation activity that transforms aggregated creator performance indicators into the executive-level Creator Growth metric."@en ,
                                                                    "An analytics computation activity that transforms creator performance indicators into the executive-level Creator Growth metric and produces a metric snapshot for dashboards."@en ;
                                                    <http://www.w3.org/ns/prov#endedAtTime> "2026-02-08T07:27:00-08:00"^^xsd:dateTime ,
