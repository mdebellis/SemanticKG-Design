@prefix : <https://www.michaeldebellis.com/dp/> .
@prefix dp: <https://www.michaeldebellis.com/dp/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://www.michaeldebellis.com/dp/> .

<https://www.michaeldebellis.com/dp/> rdf:type owl:Ontology ;
                                       owl:imports <http://www.w3.org/2004/02/skos/core> ,
                                                   dcat: ,
                                                   <http://www.w3.org/ns/prov-o#> ;
                                       dcterms:description "An ontology for modeling Data Products, their ownership, datasets, services, contracts, and quality attributes, aligned with DCAT and PROV."@en ;
                                       rdfs:label "Data Product Ontology"@en ;
                                       owl:versionInfo "0.1.0 draft – 2025-12-11"@en .

#################################################################
#    Object Properties
#################################################################

###  https://www.michaeldebellis.com/dp/consumes_dataset
dp:consumes_dataset rdf:type owl:ObjectProperty ;
                    rdfs:domain dp:Data_Product_Version ;
                    rdfs:range dcat:Dataset ;
                    rdfs:comment "Relates a Data Product Version to a dataset that it consumes as an input or dependency."@en ;
                    rdfs:label "consumes dataset"@en .


###  https://www.michaeldebellis.com/dp/exposes_service
dp:exposes_service rdf:type owl:ObjectProperty ;
                   rdfs:domain dp:Data_Product_Version ;
                   rdfs:range dcat:DataService ;
                   rdfs:comment "Relates a Data Product Version to a data service that exposes its data via an API or endpoint."@en ;
                   rdfs:label "exposes service"@en .


###  https://www.michaeldebellis.com/dp/has_api_type
dp:has_api_type rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:DataService ;
                rdfs:range dp:API_Type ;
                rdfs:comment "Relates a data service to the type of API or interface that it provides (e.g., REST, GraphQL, SPARQL)."@en ;
                rdfs:label "has API type"@en .


###  https://www.michaeldebellis.com/dp/has_bounded_context
dp:has_bounded_context rdf:type owl:ObjectProperty ;
                       rdfs:domain dp:Data_Product ;
                       rdfs:range dp:Bounded_Context ;
                       dcterms:contributor "Michael DeBellis" ;
                       dcterms:created "2025-12-12T04:27:40Z"^^xsd:dateTime ;
                       rdfs:comment "Relates a Data Product to the bounded context whose model and language it implements."@en ;
                       rdfs:label "has bounded context"@en .


###  https://www.michaeldebellis.com/dp/has_contract
dp:has_contract rdf:type owl:ObjectProperty ;
                rdfs:domain dp:Data_Product ;
                rdfs:range dp:Contract ;
                rdfs:comment "Relates a Data Product to a contract describing its expected behavior and constraints."@en ;
                rdfs:label "has contract"@en .


###  https://www.michaeldebellis.com/dp/has_domain
dp:has_domain rdf:type owl:ObjectProperty ;
              rdfs:domain dp:Data_Product ;
              rdfs:range dp:Domain ;
              rdfs:comment "Relates a Data Product to the domain that owns and governs it."@en ;
              rdfs:label "has domain"@en .


###  https://www.michaeldebellis.com/dp/has_product_key
dp:has_product_key rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain dp:Data_Product ;
                   rdfs:range dp:Product_Key ;
                   rdfs:comment "Relates a Data Product to a controlled Product Key individual used as its canonical identifier instead of a free-text string."@en ;
                   rdfs:label "has product key"@en .


###  https://www.michaeldebellis.com/dp/has_product_type
dp:has_product_type rdf:type owl:ObjectProperty ;
                    rdfs:domain dp:Data_Product ;
                    rdfs:range dp:Data_Product_Type ;
                    rdfs:comment "Relates a Data Product to a classification of its type (e.g., source-aligned, aggregate, feature-store)."@en ;
                    rdfs:label "has product type"@en .


###  https://www.michaeldebellis.com/dp/has_quality_metric
dp:has_quality_metric rdf:type owl:ObjectProperty ;
                      rdfs:domain dp:Data_Product_Version ;
                      rdfs:range dp:Quality_Metric ;
                      rdfs:comment "Relates a Data Product Version to a quality metric describing some property of its data."@en ;
                      rdfs:label "has quality metric"@en .


###  https://www.michaeldebellis.com/dp/has_sla
dp:has_sla rdf:type owl:ObjectProperty ;
           rdfs:domain dp:Data_Product_Version ;
           rdfs:range dp:SLA ;
           rdfs:comment "Relates a Data Product Version (or in some cases the abstract Data Product) to an associated service level agreement."@en ;
           rdfs:label "has SLA"@en .


###  https://www.michaeldebellis.com/dp/has_version
dp:has_version rdf:type owl:ObjectProperty ;
               rdfs:domain dp:Data_Product ;
               rdfs:range dp:Data_Product_Version ;
               rdfs:comment "Relates a Data Product to one of its concrete versions."@en ;
               rdfs:label "has version"@en .


###  https://www.michaeldebellis.com/dp/implemented_by_activity
dp:implemented_by_activity rdf:type owl:ObjectProperty ;
                           rdfs:domain dp:Data_Product_Version ;
                           rdfs:range prov:Activity ;
                           rdfs:comment "Relates a Data Product Version to the PROV activity (e.g., pipeline, job, process) that produces or maintains it."@en ;
                           rdfs:label "implemented by activity"@en .


###  https://www.michaeldebellis.com/dp/owned_by
dp:owned_by rdf:type owl:ObjectProperty ;
            rdfs:domain dp:Data_Product ;
            rdfs:range dp:Data_Product_Team ;
            rdfs:comment "Relates a Data Product to the team that owns and operates it."@en ;
            rdfs:label "owned by"@en .


###  https://www.michaeldebellis.com/dp/previous_version
dp:previous_version rdf:type owl:ObjectProperty ;
                    rdfs:domain dp:Data_Product_Version ;
                    rdfs:range dp:Data_Product_Version ;
                    rdfs:comment "Relates a Data Product Version to the previous version of the same Data Product."@en ;
                    rdfs:label "previous version"@en .


###  https://www.michaeldebellis.com/dp/produces_dataset
dp:produces_dataset rdf:type owl:ObjectProperty ;
                    rdfs:domain dp:Data_Product_Version ;
                    rdfs:range dcat:Dataset ;
                    rdfs:comment "Relates a Data Product Version to a dataset that it publishes as part of its output."@en ;
                    rdfs:label "produces dataset"@en .


###  https://www.michaeldebellis.com/dp/upstream_of
dp:upstream_of rdf:type owl:ObjectProperty ;
               rdfs:domain dp:Bounded_Context ;
               rdfs:range dp:Bounded_Context ;
               dcterms:contributor "Michael DeBellis" ;
               dcterms:created "2025-12-12T04:30:40Z"^^xsd:dateTime ;
               rdfs:comment "Indicates that one bounded context provides data or behavior that another depends on."@en ;
               rdfs:label "upstream of"@en .


#################################################################
#    Classes
#################################################################

###  https://www.michaeldebellis.com/dp/API_Type
dp:API_Type rdf:type owl:Class ;
            rdfs:comment "A controlled vocabulary class describing what kind of API or interface a data service provides (e.g., REST, GraphQL, SPARQL)."@en ;
            rdfs:label "API Type"@en .


###  https://www.michaeldebellis.com/dp/Bounded_Context
dp:Bounded_Context rdf:type owl:Class ;
                   dcterms:contributor "Michael DeBellis" ;
                   dcterms:created "2025-12-12T04:24:48Z"^^xsd:dateTime ;
                   rdfs:comment "A coherent domain model boundary in the sense of Domain-Driven Design."@en ;
                   rdfs:label "Bounded Context"@en .


###  https://www.michaeldebellis.com/dp/Contract
dp:Contract rdf:type owl:Class ;
            rdfs:comment "A contract describing the agreed behavior, interfaces, or constraints of a Data Product."@en ;
            rdfs:label "Contract"@en .


###  https://www.michaeldebellis.com/dp/Data_Product
dp:Data_Product rdf:type owl:Class ;
                rdfs:comment "A domain-owned, versioned data microservice that exposes datasets and services together with contracts and quality guarantees."@en ;
                rdfs:label "Data Product"@en .


###  https://www.michaeldebellis.com/dp/Data_Product_Team
dp:Data_Product_Team rdf:type owl:Class ;
                     rdfs:subClassOf prov:Agent ;
                     rdfs:comment "A team or group of people responsible for owning and operating a Data Product."@en ;
                     rdfs:label "Data Product Team"@en .


###  https://www.michaeldebellis.com/dp/Data_Product_Type
dp:Data_Product_Type rdf:type owl:Class ;
                     rdfs:comment "A classification of Data Products, such as source-aligned, aggregate, or feature-store products."@en ;
                     rdfs:label "Data Product Type"@en .


###  https://www.michaeldebellis.com/dp/Data_Product_Version
dp:Data_Product_Version rdf:type owl:Class ;
                        rdfs:comment "A specific deployed version of a Data Product, with its own datasets, services, lineage, and guarantees."@en ;
                        rdfs:label "Data Product Version"@en .


###  https://www.michaeldebellis.com/dp/Domain
dp:Domain rdf:type owl:Class ;
          rdfs:comment "A business or problem domain that owns and governs one or more Data Products."@en ;
          rdfs:label "Domain"@en .


###  https://www.michaeldebellis.com/dp/Product_Key
dp:Product_Key rdf:type owl:Class ;
               rdfs:comment "A controlled vocabulary of identifiers for Data Products, used instead of free-text strings to avoid typos and inconsistency."@en ;
               rdfs:label "Product Key"@en .


###  https://www.michaeldebellis.com/dp/Quality_Metric
dp:Quality_Metric rdf:type owl:Class ;
                  rdfs:comment "A metric describing some aspect of data quality such as completeness, accuracy, or timeliness for a Data Product version."@en ;
                  rdfs:label "Quality Metric"@en .


###  https://www.michaeldebellis.com/dp/SLA
dp:SLA rdf:type owl:Class ;
       rdfs:comment "A service level agreement specifying performance, availability, freshness, or other guarantees for a Data Product or a version of it."@en ;
       rdfs:label "Service Level Agreement"@en .


#################################################################
#    Individuals
#################################################################

###  https://www.michaeldebellis.com/dp/GraphQL_API
dp:GraphQL_API rdf:type owl:NamedIndividual ,
                        dp:API_Type ;
               rdfs:comment "An API exposed using a GraphQL interface."@en ;
               rdfs:label "GraphQL API"@en .


###  https://www.michaeldebellis.com/dp/REST_API
dp:REST_API rdf:type owl:NamedIndividual ,
                     dp:API_Type ;
            rdfs:comment "An API exposed using a REST-style interface."@en ;
            rdfs:label "REST API"@en .


###  https://www.michaeldebellis.com/dp/SPARQL_Endpoint
dp:SPARQL_Endpoint rdf:type owl:NamedIndividual ,
                            dp:API_Type ;
                   rdfs:comment "A SPARQL endpoint that exposes query access to data, typically over HTTP."@en ;
                   rdfs:label "SPARQL endpoint"@en .


