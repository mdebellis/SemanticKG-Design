#################################################################
# Ontology header for Data Product SHACL Shapes
#################################################################

<https://www.michaeldebellis.com/dp/shapes/>
    a owl:Ontology , sh:ShapesGraph ;
    dct:title "Data Product SHACL Shapes"@en ;
    dct:creator "Michael DeBellis"@en ;
    dct:description "SHACL constraints for the Data Product Ontology (https://www.michaeldebellis.com/dp/), enforcing cardinalities, controlled vocabularies, and annotation language standards."@en ;
    owl:imports <https://www.michaeldebellis.com/dp/> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "1.0.0" .


@prefix ex:    <https://www.michaeldebellis.com/dp/> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix skos:  <https://www.w3.org/2004/02/skos/core#> .
@prefix prov:  <https://www.w3.org/ns/prov#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# Helper: Language policy for human-facing annotations (@en)
#################################################################

ex:LangEn_AnnotationShape
  a sh:NodeShape ;
  sh:targetObjectsOf skos:prefLabel, skos:altLabel, skos:definition, dct:title, dct:description ;
  sh:property [
    sh:path [ sh:inversePath rdf:value ] ; # dummy to attach constraints below to each targeted literal
    sh:languageIn ( "en" ) ;
    sh:message "Human-readable annotations should use an English language tag (@en)."@en ;
  ] .

#################################################################
# Data Product
#################################################################

ex:Data_Product_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Data_Product ;
  sh:property
    # Basic annotations
    [
      sh:path dct:title ;
      sh:minCount 1 ;
      sh:datatype rdf:langString ;
      sh:languageIn ( "en" ) ;
      sh:message "Provide at least one dct:title with @en."@en
    ] ,
    [
      sh:path skos:prefLabel ;
      sh:minCount 1 ;
      sh:datatype rdf:langString ;
      sh:languageIn ( "en" ) ;
      sh:message "Provide at least one skos:prefLabel with @en."@en
    ] ,

    # Core required links
    [
      sh:path ex:has_contract ;
      sh:class ex:Data_Contract ;
      sh:minCount 1 ;
      sh:message "A Data Product must have at least one Data_Contract."@en
    ] ,
    [
      sh:path ex:exposes_interface ;
      sh:class ex:Data_Interface ;
      sh:minCount 1 ;
      sh:message "A Data Product must expose at least one Data_Interface."@en
    ] ,
    [
      sh:path ex:has_semantic_model ;
      sh:class ex:Semantic_Model ;
      sh:minCount 1 ;
      sh:message "A Data Product must declare a Semantic_Model."@en
    ] ,
    [
      sh:path ex:includes_asset ;
      sh:class ex:Dataset ;
      sh:minCount 1 ;
      sh:message "A Data Product should include at least one Dataset asset."@en
    ] ,
    [
      sh:path ex:has_quality_slo ;
      sh:class ex:Data_Quality_SLO ;
      sh:minCount 1 ;
      sh:message "A Data Product must have Data_Quality_SLO thresholds."@en
    ] ,
    [
      sh:path ex:data_product_owner ;
      sh:class prov:Agent ;
      sh:minCount 1 ;
      sh:message "A Data Product must have an accountable owner (prov:Agent)."@en
    ] ,

    # Lifecycle: exactly one, from controlled set
    [
      sh:path ex:has_lifecycle_state ;
      sh:minCount 1 ; sh:maxCount 1 ;
      sh:in ( ex:Proposed ex:Active ex:Deprecated ex:Retired ) ;
      sh:message "Lifecycle state must be exactly one of {Proposed, Active, Deprecated, Retired}."@en
    ] ,

    # Product type: at least one from controlled set
    [
      sh:path ex:has_product_type ;
      sh:minCount 1 ;
      sh:in ( ex:Analytical_Product ex:Operational_Product ex:MDM_Reference_Product ex:Event_Stream_Product ) ;
      sh:message "Provide at least one product type from the controlled set."@en
    ] ,

    # Sensitivity level: one from controlled set
    [
      sh:path ex:has_sensitivity_level ;
      sh:minCount 1 ; sh:maxCount 1 ;
      sh:in ( ex:Public ex:Internal ex:Restricted ) ;
      sh:message "Sensitivity level must be one of {Public, Internal, Restricted}."@en
    ] ,

    # Optional use cases
    [
      sh:path ex:serves_use_case ;
      sh:class ex:Use_Case ;
      sh:minCount 0 ;
      sh:message "If present, serves_use_case must point to a Use_Case."@en
    ] ,

    # Version and PII flag
    [
      sh:path ex:version_identifier ;
      sh:datatype xsd:string ;
      sh:pattern "^v?\\d+(\\.\\d+)*$" ;
      sh:flags "i" ;
      sh:message "version_identifier should look like v1, 1.2, v2.3.4, etc."@en
    ] ,
    [
      sh:path ex:contains_personal_data ;
      sh:datatype xsd:boolean ;
      sh:message "contains_personal_data must be a boolean."@en
    ]
  ;

  # Business rule: If contains_personal_data = true, must have an Access_Policy
  sh:sparql [
    sh:message "Products containing personal data must declare an Access_Policy via ex:has_access_policy."@en ;
    sh:select """
      PREFIX ex: <https://www.michaeldebellis.com/dp/>
      SELECT $this WHERE {
        $this ex:contains_personal_data true .
        FILTER NOT EXISTS { $this ex:has_access_policy ?p . }
      }
    """ ;
  ] .

#################################################################
# Data Interface
#################################################################

ex:Data_Interface_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Data_Interface ;
  sh:property
    [
      sh:path skos:prefLabel ;
      sh:minCount 1 ;
      sh:datatype rdf:langString ;
      sh:languageIn ( "en" ) ;
      sh:message "Provide a skos:prefLabel (@en) for each interface."@en
    ] ,
    [
      sh:path ex:has_access_mode ;
      sh:minCount 1 ; sh:maxCount 1 ;
      sh:in ( ex:Batch_Access ex:Stream_Access ex:Query_Access ) ;
      sh:message "Access mode must be exactly one of {Batch_Access, Stream_Access, Query_Access}."@en
    ] .

#################################################################
# Data Quality SLO
#################################################################

ex:Data_Quality_SLO_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Data_Quality_SLO ;
  sh:property
    [
      sh:path ex:availability_slo_pct ;
      sh:datatype xsd:decimal ;
      sh:minInclusive 0 ; sh:maxInclusive 100 ;
      sh:message "availability_slo_pct must be a percentage between 0 and 100."@en
    ] ,
    [
      sh:path ex:freshness_slo_hours ;
      sh:datatype xsd:decimal ;
      sh:minInclusive 0 ;
      sh:message "freshness_slo_hours must be ≥ 0."@en
    ] ,
    [
      sh:path ex:latency_slo_seconds ;
      sh:datatype xsd:decimal ;
      sh:minInclusive 0 ;
      sh:message "latency_slo_seconds must be ≥ 0."@en
    ] .

#################################################################
# Data Contract
#################################################################

ex:Data_Contract_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Data_Contract ;
  sh:property
    [
      sh:path dct:title ;
      sh:minCount 1 ;
      sh:datatype rdf:langString ;
      sh:languageIn ( "en" ) ;
      sh:message "Contracts need a dct:title (@en)."@en
    ] ,
    [
      sh:path ex:valid_from ;
      sh:datatype xsd:date ;
      sh:minCount 1 ;
      sh:message "valid_from is required (xsd:date)."@en
    ] ,
    [
      sh:path ex:valid_to ;
      sh:datatype xsd:date ;
      sh:minCount 0 ;
      sh:message "valid_to, if present, must be xsd:date."@en
    ] ;
  # valid_to ≥ valid_from when both present
  sh:sparql [
    sh:message "If valid_to is provided, it must be on or after valid_from."@en ;
    sh:select """
      PREFIX ex: <https://www.michaeldebellis.com/dp/>
      PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
      SELECT $this WHERE {
        $this ex:valid_from ?from .
        $this ex:valid_to ?to .
        FILTER ( xsd:date(?to) < xsd:date(?from) )
      }
    """ ;
  ] .

#################################################################
# Dataset
#################################################################

ex:Dataset_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Dataset ;
  sh:property
    [
      sh:path prov:wasGeneratedBy ;
      sh:class ex:Data_Pipeline ;
      sh:minCount 1 ;
      sh:message "Each Dataset should declare the generating Data_Pipeline (prov:wasGeneratedBy)."@en
    ] ,
    [
      sh:path dct:identifier ;
      sh:datatype xsd:string ;
      sh:minCount 1 ;
      sh:message "Datasets should carry a stable dct:identifier."@en
    ] .

#################################################################
# Data Pipeline
#################################################################

ex:Data_Pipeline_Shape
  a sh:NodeShape ;
  sh:targetClass ex:Data_Pipeline ;
  sh:property
    [
      sh:path dct:description ;
      sh:datatype rdf:langString ;
      sh:minCount 0 ;
      sh:languageIn ( "en" ) ;
      sh:message "If provided, dct:description should use @en."@en
    ] ,
    [
      sh:path prov:startedAtTime ;
      sh:datatype xsd:dateTime ;
      sh:minCount 0 ;
      sh:message "If present, startedAtTime must be xsd:dateTime."@en
    ] ,
    [
      sh:path prov:endedAtTime ;
      sh:datatype xsd:dateTime ;
      sh:minCount 0 ;
      sh:message "If present, endedAtTime must be xsd:dateTime."@en
    ] ;
  # If both times provided, endedAtTime ≥ startedAtTime
  sh:sparql [
    sh:message "If both times are present, prov:endedAtTime must be ≥ prov:startedAtTime."@en ;
    sh:select """
      PREFIX prov: <https://www.w3.org/ns/prov#>
      PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
      SELECT $this WHERE {
        $this prov:startedAtTime ?s ;
              prov:endedAtTime ?e .
        FILTER ( xsd:dateTime(?e) < xsd:dateTime(?s) )
      }
    """ ;
  ] .
