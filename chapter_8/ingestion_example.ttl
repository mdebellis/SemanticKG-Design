@prefix sfg:  <https://www.michaeldebellis.com/stream_forge_example/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://www.michaeldebellis.com/stream_forge_example/graphs/TBox> {

  sfg: a owl:Ontology ;
    rdfs:label "StreamForge Example (minimal) ontology"@en .

  ### Classes (minimal)
  sfg:Trending_Snapshot_Record a owl:Class ;
    rdfs:label "Trending snapshot record"@en ;
    rdfs:comment "A record representing that a video appeared in the trending list at a particular snapshot time."@en .

  sfg:Video a owl:Class ;
    rdfs:label "Video"@en ;
    rdfs:comment "A video in the StreamForge platform."@en .

  sfg:Channel a owl:Class ;
    rdfs:label "Channel"@en ;
    rdfs:comment "A channel (publisher) in the StreamForge platform."@en .

  sfg:Category a owl:Class ;
    rdfs:label "Category"@en ;
    rdfs:comment "A content category used to classify videos."@en .

  sfg:Region a owl:Class ;
    rdfs:label "Region"@en ;
    rdfs:comment "A geographic or market region in which a snapshot is observed."@en .

  sfg:Ingestion_Run a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Ingestion run"@en ;
    rdfs:comment "A concrete execution of the ingestion pipeline."@en .

  sfg:Ingestion_Pipeline a owl:Class ;
    rdfs:subClassOf prov:SoftwareAgent ;
    rdfs:label "Ingestion pipeline"@en ;
    rdfs:comment "The software agent that performs ingestion."@en .

  sfg:Input_Batch a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Input batch"@en ;
    rdfs:comment "An input dataset (e.g., a CSV file) processed by an ingestion run."@en .

  ### Object properties
  sfg:has_video a owl:ObjectProperty ;
    rdfs:label "has video"@en ;
    rdfs:comment "Links a snapshot record to the video it refers to."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range sfg:Video .

  sfg:has_channel a owl:ObjectProperty ;
    rdfs:label "has channel"@en ;
    rdfs:comment "Links a snapshot record to the channel associated with the video."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range sfg:Channel .

  sfg:has_category a owl:ObjectProperty ;
    rdfs:label "has category"@en ;
    rdfs:comment "Links a snapshot record to its category."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range sfg:Category .

  sfg:has_region a owl:ObjectProperty ;
    rdfs:label "has region"@en ;
    rdfs:comment "Links a snapshot record to the region in which it was observed."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range sfg:Region .

  ### Datatype properties
  sfg:has_rank a owl:DatatypeProperty ;
    rdfs:label "has rank"@en ;
    rdfs:comment "The rank of the video within the trending list at the snapshot time."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range xsd:integer .

  sfg:has_view_count a owl:DatatypeProperty ;
    rdfs:label "has view count"@en ;
    rdfs:comment "The view count observed at snapshot time."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range xsd:integer .

  sfg:has_like_count a owl:DatatypeProperty ;
    rdfs:label "has like count"@en ;
    rdfs:comment "The like count observed at snapshot time."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range xsd:integer .

  sfg:has_comment_count a owl:DatatypeProperty ;
    rdfs:label "has comment count"@en ;
    rdfs:comment "The comment count observed at snapshot time."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range xsd:integer .

  sfg:has_snapshot_time a owl:DatatypeProperty ;
    rdfs:label "has snapshot time"@en ;
    rdfs:comment "The timestamp at which the snapshot was captured."@en ;
    rdfs:domain sfg:Trending_Snapshot_Record ;
    rdfs:range xsd:dateTime .
}

<https://www.michaeldebellis.com/stream_forge_example/graphs/ABox> {

  ### Region + Categories
  sfg:US a sfg:Region ; rdfs:label "US"@en .

  sfg:Education a sfg:Category, skos:Concept ; rdfs:label "Education"@en .
