@prefix : <https://michaeldebellis.com/pattern_examples/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://michaeldebellis.com/pattern_examples/> .

<https://michaeldebellis.com/pattern_examples> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  https://michaeldebellis.com/pattern_examples/example1
:example1 rdf:type owl:AnnotationProperty ;
          <http://purl.org/dc/terms/contributor> "Michael DeBellis" ;
          <http://purl.org/dc/terms/created> "2025-12-19T20:49:11Z"^^xsd:dateTime .


###  https://michaeldebellis.com/pattern_examples/new_example
:new_example rdf:type owl:AnnotationProperty ;
             <http://purl.org/dc/terms/contributor> "Michael DeBellis" ;
             <http://purl.org/dc/terms/created> "2025-12-19T20:49:20Z"^^xsd:dateTime .


#################################################################
#    Object Properties
#################################################################

###  https://michaeldebellis.com/pattern_examples/birth_Place
:birth_Place rdf:type owl:ObjectProperty ;
             rdfs:domain :Person ;
             rdfs:range :Place .


###  https://michaeldebellis.com/pattern_examples/contains
:contains rdf:type owl:ObjectProperty ;
          owl:inverseOf :is_Contained_In ;
          rdf:type owl:TransitiveProperty ;
          rdfs:domain :Place ;
          rdfs:range :Place .


###  https://michaeldebellis.com/pattern_examples/has_Address
:has_Address rdf:type owl:ObjectProperty ;
             owl:inverseOf :is_Address_For ;
             rdfs:domain :Agent ;
             rdfs:range :Address .


###  https://michaeldebellis.com/pattern_examples/has_City
:has_City rdf:type owl:ObjectProperty ;
          rdfs:domain :Address ;
          rdfs:range :City .


###  https://michaeldebellis.com/pattern_examples/has_Location
:has_Location rdf:type owl:ObjectProperty ;
              rdfs:range :Place .


###  https://michaeldebellis.com/pattern_examples/has_Parent
:has_Parent rdf:type owl:ObjectProperty ;
            owl:inverseOf :has_Subsidiary ;
            rdfs:domain :Organization ;
            rdfs:range :Organization .


###  https://michaeldebellis.com/pattern_examples/has_State
:has_State rdf:type owl:ObjectProperty ;
           rdfs:domain :Address ;
           rdfs:range :State .


###  https://michaeldebellis.com/pattern_examples/has_Subsidiary
:has_Subsidiary rdf:type owl:ObjectProperty .


###  https://michaeldebellis.com/pattern_examples/is_Address_For
:is_Address_For rdf:type owl:ObjectProperty .


###  https://michaeldebellis.com/pattern_examples/is_Contained_In
:is_Contained_In rdf:type owl:ObjectProperty ,
                          owl:TransitiveProperty .


#################################################################
#    Data properties
#################################################################

###  https://michaeldebellis.com/pattern_examples/email
:email rdf:type owl:DatatypeProperty ;
       rdfs:domain :Agent .


###  https://michaeldebellis.com/pattern_examples/first_Name
:first_Name rdf:type owl:DatatypeProperty ;
            rdfs:domain :Person .


###  https://michaeldebellis.com/pattern_examples/last_Name
:last_Name rdf:type owl:DatatypeProperty ;
           rdfs:domain :Person .


###  https://michaeldebellis.com/pattern_examples/phone_Number
:phone_Number rdf:type owl:DatatypeProperty ;
              rdfs:domain :Agent .


###  https://michaeldebellis.com/pattern_examples/street
:street rdf:type owl:DatatypeProperty ;
        rdfs:domain :Address .


###  https://michaeldebellis.com/pattern_examples/zip_Code
:zip_Code rdf:type owl:DatatypeProperty ;
          rdfs:domain :Address .


#################################################################
#    Classes
#################################################################

###  https://michaeldebellis.com/pattern_examples/Address
:Address rdf:type owl:Class ;
         rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Agent
:Agent rdf:type owl:Class .


###  https://michaeldebellis.com/pattern_examples/City
:City rdf:type owl:Class ;
      rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Continent
:Continent rdf:type owl:Class ;
           rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/County
:County rdf:type owl:Class ;
        rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/District
:District rdf:type owl:Class ;
          rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Division
:Division rdf:type owl:Class ;
          rdfs:subClassOf :Organization ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :has_Parent ;
                            owl:allValuesFrom :Region
                          ] .


###  https://michaeldebellis.com/pattern_examples/Municipality
:Municipality rdf:type owl:Class ;
              rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Nation
:Nation rdf:type owl:Class ;
        rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Operating_Unit
:Operating_Unit rdf:type owl:Class ;
                rdfs:subClassOf :Organization .


###  https://michaeldebellis.com/pattern_examples/Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf :Agent .


###  https://michaeldebellis.com/pattern_examples/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent .


###  https://michaeldebellis.com/pattern_examples/Place
:Place rdf:type owl:Class .


###  https://michaeldebellis.com/pattern_examples/Province
:Province rdf:type owl:Class ;
          rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :Organization ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :has_Parent ;
                          owl:allValuesFrom :Operating_Unit
                        ] .


###  https://michaeldebellis.com/pattern_examples/Sales_Office
:Sales_Office rdf:type owl:Class ;
              rdfs:subClassOf :Organization ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :has_Parent ;
                                owl:allValuesFrom :Division
                              ] .


###  https://michaeldebellis.com/pattern_examples/State
:State rdf:type owl:Class ;
       rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Town
:Town rdf:type owl:Class ;
      rdfs:subClassOf :Place .


###  https://michaeldebellis.com/pattern_examples/Village
:Village rdf:type owl:Class ;
         rdfs:subClassOf :Place .


#################################################################
#    Individuals
#################################################################

###  https://michaeldebellis.com/pattern_examples/Acme
:Acme rdf:type owl:NamedIndividual ,
               :Organization ;
      :has_Subsidiary :Acme_Widgets .


###  https://michaeldebellis.com/pattern_examples/Acme_American_Widgets
:Acme_American_Widgets rdf:type owl:NamedIndividual ,
                                :Region ;
                       :has_Subsidiary :Acme_Widgets_NY_Sales .


###  https://michaeldebellis.com/pattern_examples/Acme_Widgets
:Acme_Widgets rdf:type owl:NamedIndividual ,
                       :Operating_Unit ;
              :has_Subsidiary :Acme_American_Widgets .


###  https://michaeldebellis.com/pattern_examples/Acme_Widgets_NY_Sales
:Acme_Widgets_NY_Sales rdf:type owl:NamedIndividual ,
                                :Sales_Office ;
                       :has_Location :New_York_City .


###  https://michaeldebellis.com/pattern_examples/Africa
:Africa rdf:type owl:NamedIndividual ,
                 :Continent ;
        :contains :South_Africa .


###  https://michaeldebellis.com/pattern_examples/Antarctica
:Antarctica rdf:type owl:NamedIndividual ,
                     :Continent .


###  https://michaeldebellis.com/pattern_examples/Asia
:Asia rdf:type owl:NamedIndividual ,
               :Continent .


###  https://michaeldebellis.com/pattern_examples/Australia
:Australia rdf:type owl:NamedIndividual ,
                    :Continent .


###  https://michaeldebellis.com/pattern_examples/British_Columbia
:British_Columbia rdf:type owl:NamedIndividual ,
                           :Province ;
                  :contains :Vancouver .


###  https://michaeldebellis.com/pattern_examples/California
:California rdf:type owl:NamedIndividual ,
                     :State ;
            :contains :Los_Angeles ,
                      :San_Francisco .


###  https://michaeldebellis.com/pattern_examples/Canada
:Canada rdf:type owl:NamedIndividual ,
                 :Nation ;
        :contains :British_Columbia .


###  https://michaeldebellis.com/pattern_examples/Eastern_Cape
:Eastern_Cape rdf:type owl:NamedIndividual ,
                       :Province ;
              :contains :Mthatha .


###  https://michaeldebellis.com/pattern_examples/Europe
:Europe rdf:type owl:NamedIndividual ,
                 :Continent .


###  https://michaeldebellis.com/pattern_examples/King_Sabata_Dalindyebo_Local_Municipality
:King_Sabata_Dalindyebo_Local_Municipality rdf:type owl:NamedIndividual ,
                                                    :Municipality .


###  https://michaeldebellis.com/pattern_examples/Los_Angeles
:Los_Angeles rdf:type owl:NamedIndividual ,
                      :City .


###  https://michaeldebellis.com/pattern_examples/Mthatha
:Mthatha rdf:type owl:NamedIndividual ,
                  :City .


###  https://michaeldebellis.com/pattern_examples/Nelson_Mandela
:Nelson_Mandela rdf:type owl:NamedIndividual ,
                         :Person ;
                :birth_Place :Mthatha .


###  https://michaeldebellis.com/pattern_examples/New_York_City
:New_York_City rdf:type owl:NamedIndividual ,
                        :City .


###  https://michaeldebellis.com/pattern_examples/New_York_State
:New_York_State rdf:type owl:NamedIndividual ,
                         :State .


###  https://michaeldebellis.com/pattern_examples/North_America
:North_America rdf:type owl:NamedIndividual ,
                        :Continent ;
               :contains :Canada ,
                         :United_States .


###  https://michaeldebellis.com/pattern_examples/San_Francisco
:San_Francisco rdf:type owl:NamedIndividual ,
                        :City .


###  https://michaeldebellis.com/pattern_examples/South_Africa
:South_Africa rdf:type owl:NamedIndividual ,
                       :Nation ;
              :contains :Eastern_Cape .


###  https://michaeldebellis.com/pattern_examples/South_America
:South_America rdf:type owl:NamedIndividual ,
                        :Continent .


###  https://michaeldebellis.com/pattern_examples/United_States
:United_States rdf:type owl:NamedIndividual ,
                        :Nation ;
               :contains :California ,
                         :New_York_State .


###  https://michaeldebellis.com/pattern_examples/Vancouver
:Vancouver rdf:type owl:NamedIndividual ,
                    :City .


