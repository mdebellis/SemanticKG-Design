@prefix : <https://www.michaeldebellis.com/dp/> .
@prefix ex: <https://www.michaeldebellis.com/dp/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <https://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <https://www.w3.org/2004/02/skos/core#> .
@base <https://www.michaeldebellis.com/dp/> .

<https://www.michaeldebellis.com/dp/> rdf:type owl:Ontology ;
                                       owl:imports <https://www.w3.org/2004/02/skos/core> ,
                                                   <https://www.w3.org/ns/prov-o#> ;
                                       dct:creator "Michael DeBellis"@en ;
                                       dct:description "An OWL module for modeling Data Products, their contracts, interfaces, datasets, pipelines, SLOs, and governance, aligned with PROV-O, DCT, and SKOS."@en ;
                                       dct:license <https://creativecommons.org/licenses/by/4.0/> ;
                                       dct:title "Data Product Ontology"@en ;
                                       owl:versionInfo "1.0.0" .

