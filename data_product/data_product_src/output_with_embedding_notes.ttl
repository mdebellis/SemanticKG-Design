    skos:definition "Data with no recorded validation checks beyond basic ingestion and syntactic well-formedness."@en ;
    skos:inScheme dp:Data_Quality_Level_Scheme ;
    dp:embedding_note "Raw data has validation rank 10."@en ;
    dp:validation_rank 10 .

dp:S3 a owl:NamedIndividual,
        dp:Platform ;
    rdfs:label "S3"@en ;
    dp:embedding_note "S3 is an instance of Platform."@en .

dp:SPARQL_Endpoint a owl:NamedIndividual,
        dp:API_Type ;
    rdfs:label "SPARQL Endpoint"@en ;
    rdfs:comment "A SPARQL endpoint that exposes query access to data, typically over HTTP."@en,
        "Data Product usage: Indicates that a Data Product is exposed through a SPARQL endpoint, typically for RDF-based Data Products."@en ;
    dp:embedding_note "SPARQL Endpoint is an instance of API Type."@en .

dp:Smalltalk a owl:NamedIndividual,
        dp:Programming_Language ;
    rdfs:label "Smalltalk"@en ;
    dp:embedding_note "Smalltalk is an instance of Programming language."@en .

dp:SnowFlake a owl:NamedIndividual,
        dp:Platform ;
    rdfs:label "SnowFlake"@en ;
    dp:embedding_note "SnowFlake is an instance of Platform."@en .

dp:South_America a owl:NamedIndividual,
        dp:Continent ;
    rdfs:label "South America"@en ;
    dp:embedding_note "South America contains Brazil."@en ;
    dp:geo_contains_direct dp:Brazil .

dp:Town a owl:Class ;
    rdfs:label "Town"@en ;
    rdfs:subClassOf dp:Place .

