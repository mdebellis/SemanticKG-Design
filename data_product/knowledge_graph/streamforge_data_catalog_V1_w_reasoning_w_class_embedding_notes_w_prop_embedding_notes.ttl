dp:may_affect_data_product a owl:ObjectProperty ;
    rdfs:label "may affect data product"@en ;
    rdfs:domain owl:Thing,
        prov:Activity,
        dp:Domain_Concept_Change ;
    rdfs:range _:n08db96af954a45a8876dae1bff971940b1,
        _:n08db96af954a45a8876dae1bff971940b7,
        owl:Thing,
        dp:Data_Product ;
    owl:inverseOf dp:may_be_data_product_affected_by ;
    skos:definition "Relates a domain concept change activity to a data product that may need review because it produces, consumes, exposes, or depends on the changed concept."@en ;
    skos:note "Relates a domain concept change activity to a data product that may need review because it produces, consumes, exposes, or depends on the changed concept."@en ;
    dp:embedding_note "may affect data product has definition Relates a domain concept change activity to a data product that may need review because it produces, consumes, exposes, or depends on the changed concept."@en .

dp:may_affect_domain_concept a owl:ObjectProperty ;
