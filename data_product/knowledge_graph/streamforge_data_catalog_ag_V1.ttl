docs:Advertising_Revenue_By_Age_Segment_Report_2025 a owl:NamedIndividual,
        prov:Entity,
        docs:Document,
        docs:Document_Chunk,
        docs:Report,
        dp:Catalog_Asset ;
    rdfs:label "Advertising Revenue By Age Segment Report 2025"@en ;
    docs:chunk_text """Advertising Revenue by Age Segment (Last 12 Months 2025)

| Age Segment | Ad Revenue (USD) | % of Total |
|------------|------------------:|-----------:|
| Under_18   |      8,000,000    |       4%   |
| 18_34      |     92,000,000    |      46%   |
| 35_54      |     76,000,000    |      38%   |
| 55_plus    |     24,000,000    |      12%   |

Notes:
- 18–34 is the largest revenue contributor.
- 35–54 is a close second and may have higher revenue per user.
"""@en ;
    dp:embedding_note "Advertising Revenue By Age Segment Report 2025 is an instance of Catalog Asset."@en,
        "Advertising Revenue By Age Segment Report 2025 is an instance of Document Chunk."@en,
        "Advertising Revenue By Age Segment Report 2025 is an instance of Document."@en,
        "Advertising Revenue By Age Segment Report 2025 is an instance of Report."@en .

