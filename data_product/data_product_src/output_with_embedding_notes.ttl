        sf:Video_Metadata_Current .

docs:Personalization_Performance_Review_Q3_2025_Chunk_01 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 01"@en ;
    docs:chunk_index 1 ;
    docs:chunk_text "This Q3 2025 review assesses StreamForge personalization performance across home feed ranking, Up Next, and notification targeting. It summarizes model metrics, user outcomes, and known risks to establish a stable baseline for Q4 experiments and to identify data product priorities affecting model quality."@en ;
    docs:chunk_title "Summary"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 01 has title Summary."@en,
        "Personalization Performance Review Q3 2025 Chunk 01 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_02 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 02"@en ;
    docs:chunk_index 2 ;
    docs:chunk_text "Reporting period: Q3 2025 (2025-07-01 to 2025-09-30). Surfaces: Home feed, Up Next, Notifications. Regions: global, with separate monitoring for India and Brazil."@en ;
    docs:chunk_title "Scope and time window"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 02 has title Scope and time window."@en,
        "Personalization Performance Review Q3 2025 Chunk 02 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_03 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 03"@en ;
    docs:chunk_index 3 ;
    docs:chunk_text "Watch time per daily active user: +2.0%. Session starts per user: +1.1%. Not interested feedback rate: +0.4 pp (worse). Complaint rate (recommendation relevance): +0.2 pp (worse). Creator distribution: more concentrated in top 1% channels (+0.6 pp share)."@en ;
    docs:chunk_title "User outcome summary (Q3 vs Q2)"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 03 has title User outcome summary (Q3 vs Q2)."@en,
        "Personalization Performance Review Q3 2025 Chunk 03 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_04 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 04"@en ;
    docs:chunk_index 4 ;
    docs:chunk_text "Offline AUC improved modestly for home feed ranking (+0.3%), but calibration drift increased in August. User embeddings refreshed less frequently than expected for a subset of users due to a pipeline backlog."@en ;
    docs:chunk_title "Model and data signals (performance and drift)"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 04 has title Model and data signals (performance and drift)."@en,
        "Personalization Performance Review Q3 2025 Chunk 04 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_05 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 05"@en ;
    docs:chunk_index 5 ;
    docs:chunk_text "Video metadata freshness had measurable impact on cold-start performance for new uploads and new creators. Category and tag coverage remains inconsistent across languages, affecting semantic retrieval features."@en ;
    docs:chunk_title "Model and data signals (metadata and language)"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 05 has title Model and data signals (metadata and language)."@en,
        "Personalization Performance Review Q3 2025 Chunk 05 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_06 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 06"@en ;
    docs:chunk_index 6 ;
    docs:chunk_text "Concentration risk: personalization reinforces already-large channels; mitigate with exploration controls and fairness-aware re-ranking. Drift risk: August calibration issues suggest instability in timestamp-derived features; mitigate with feature sanity checks and freshness SLAs. Trust risk: rising not interested feedback indicates relevance mismatch; mitigate with cohort-specific tuning and better negative-signal modeling."@en ;
    docs:chunk_title "Risks and mitigations"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 06 has title Risks and mitigations."@en,
        "Personalization Performance Review Q3 2025 Chunk 06 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_07 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 07"@en ;
    docs:chunk_index 7 ;
    docs:chunk_text "Enforce a strict SLA for Video Metadata Freshness and validate timestamp monotonicity. Add monitoring for embedding refresh delays and backpressure in the feature pipeline. Run an experiment to reduce channel concentration without reducing watch time. Improve multilingual tag normalization as a data product enhancement rather than a model-side patch."@en ;
    docs:chunk_title "Recommendations for Q4"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 07 has title Recommendations for Q4."@en,
        "Personalization Performance Review Q3 2025 Chunk 07 is an instance of Document Chunk."@en .

docs:Personalization_Performance_Review_Q3_2025_Chunk_08 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Personalization Performance Review Q3 2025 Chunk 08"@en ;
    docs:chunk_index 8 ;
    docs:chunk_text "Approve prioritization of metadata freshness work (pipeline plus catalog validation) over new model architecture changes for the first half of Q4."@en ;
    docs:chunk_title "Decisions requested"@en ;
    dp:embedding_note "Personalization Performance Review Q3 2025 Chunk 08 has title Decisions requested."@en,
        "Personalization Performance Review Q3 2025 Chunk 08 is an instance of Document Chunk."@en .

