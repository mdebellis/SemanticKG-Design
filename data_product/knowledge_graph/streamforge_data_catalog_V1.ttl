    rdfs:label "elements/1.1/type"@en ;
    dp:embedding_label "has type"@en ;
    dp:embedding_note "elements/1.1/type has label elements/1.1/type."@en .

dctm:contributor a owl:AnnotationProperty ;
    rdfs:label "terms/contributor"@en ;
    dp:embedding_label "has contributor"@en ;
    dp:embedding_note "terms/contributor has label terms/contributor."@en .

dctm:created a owl:AnnotationProperty ;
    rdfs:label "terms/created"@en ;
    dp:embedding_note "terms/created has label terms/created."@en .

dctm:creator a owl:AnnotationProperty ;
    rdfs:label "terms/creator"@en ;
    dp:embedding_label "has creator"@en ;
    dp:embedding_note "terms/creator has label terms/creator."@en .

dctm:description a owl:AnnotationProperty ;
    rdfs:label "terms/description"@en ;
    dp:embedding_label "has description"@en ;
    dp:embedding_note "terms/description has label terms/description."@en .

dctm:format a owl:AnnotationProperty ;
    rdfs:label "terms/format"@en ;
    dp:embedding_label "has format"@en ;
    dp:embedding_note "terms/format has label terms/format."@en .

dctm:hasPart a owl:AnnotationProperty ;
    rdfs:label "terms/haspart"@en ;
    dp:embedding_note "terms/haspart has label terms/haspart."@en .

dctm:license a owl:AnnotationProperty ;
    dp:embedding_label "has license"@en .

dctm:publisher a owl:AnnotationProperty ;
    rdfs:label "publisher"@en ;
    skos:definition "An entity responsible for making the resource available."@en ;
    skos:scopeNote "Use dcterms:publisher (commonly used with DCAT) to identify the organization (or agent) that publishes the dataset/service in the catalog."@en ;
    dp:embedding_label "has publisher"@en ;
    dp:embedding_note """publisher has label publisher.
publisher has definition An entity responsible for making the resource available.
publisher has scope note Use dcterms:publisher (commonly used with DCAT) to identify the organization (or agent) that publishes the dataset/service in the catalog."""@en .

dctm:source a owl:AnnotationProperty ;
    rdfs:label "terms/source"@en ;
    dp:embedding_label "has source"@en ;
    dp:embedding_note "terms/source has label terms/source."@en .

dctm:title a owl:AnnotationProperty ;
    rdfs:label "terms/title"@en ;
    dp:embedding_note "terms/title has label terms/title."@en .

<http://purl.org/ontology/bibo/editor> a owl:AnnotationProperty ;
    dp:embedding_label "has editor"@en .

<http://purl.org/ontology/bibo/translator> a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

<http://schema.org/rangeIncludes> a owl:AnnotationProperty .

<http://www.w3.org/1999/xhtml/vocab#first> a owl:ObjectProperty .

<http://www.w3.org/1999/xhtml/vocab#last> a owl:ObjectProperty .

<http://www.w3.org/1999/xhtml/vocab#prev> a owl:ObjectProperty .

xsd:date a rdfs:Datatype .

owl:cardinality a owl:AnnotationProperty .

skos:altLabel a owl:AnnotationProperty ;
    rdfs:subPropertyOf rdfs:label .

skos:changeNote a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:note .

skos:definition a owl:AnnotationProperty ;
    rdfs:label "definition"@en ;
    rdfs:subPropertyOf skos:note ;
    dp:embedding_label "has definition"@en ;
    dp:embedding_note "definition has label definition."@en .

skos:editorialNote a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:note ;
    dp:embedding_label "has editorial note"@en .

skos:example a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:note ;
    dp:embedding_label "has example"@en .

skos:hiddenLabel a owl:AnnotationProperty ;
    rdfs:subPropertyOf rdfs:label .

skos:historyNote a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:note .

skos:inScheme a owl:AnnotationProperty .

skos:prefLabel a owl:AnnotationProperty ;
    rdfs:subPropertyOf rdfs:label .

skos:scopeNote a owl:AnnotationProperty ;
    dp:embedding_label "has scope note"@en .

<http://www.w3.org/ns/adms#versionNotes> a owl:AnnotationProperty .

dcat:accessService a owl:AnnotationProperty ;
    rdfs:label "access service"@en ;
    skos:definition "A data service that gives access to the distribution of the dataset."@en ;
    skos:scopeNote "Use dcat:accessService when a distribution is accessed through a service (API gateway, SPARQL endpoint, download service). This complements dcat:accessURL/downloadURL."@en ;
    dp:embedding_note """access service has label access service.
access service has definition A data service that gives access to the distribution of the dataset.
access service has scope note Use dcat:accessService when a distribution is accessed through a service (API gateway, SPARQL endpoint, download service). This complements dcat:accessURL/downloadURL."""@en .

dcat:accessURL a owl:AnnotationProperty ;
    rdfs:label "access URL"@en ;
    skos:definition "A URL of the resource that gives access to a distribution of the dataset."@en ;
    skos:scopeNote "Use dcat:accessURL for a landing/access endpoint (e.g., an API base URL, a download page, a query endpoint). If the URL is a direct file download, consider dcat:downloadURL instead."@en ;
    dp:embedding_label "has access URL"@en ;
    dp:embedding_note """access URL has label access URL.
access URL has definition A URL of the resource that gives access to a distribution of the dataset.
access URL has scope note Use dcat:accessURL for a landing/access endpoint (e.g., an API base URL, a download page, a query endpoint). If the URL is a direct file download, consider dcat:downloadURL instead."""@en .

dcat:catalog a owl:ObjectProperty ;
    rdfs:label "catalog"@en ;
    rdfs:domain dcat:Catalog ;
    rdfs:range dcat:Catalog ;
    rdfs:subPropertyOf dcat:resource ;
    skos:definition "A catalog that is listed in the catalog."@en ;
    skos:scopeNote "Use dcat:catalog when the member being listed is itself another dcat:Catalog (e.g., a subcatalog)."@en ;
    dp:embedding_label "has sub-catalog"@en ;
    dp:embedding_note """catalog has label catalog.
catalog has definition A catalog that is listed in the catalog.
catalog has scope note Use dcat:catalog when the member being listed is itself another dcat:Catalog (e.g., a subcatalog)."""@en .

dcat:contactPoint a owl:AnnotationProperty ;
    rdfs:label "contact point"@en ;
    skos:definition "Relevant contact information for the resource."@en ;
    skos:scopeNote "Use dcat:contactPoint to link a resource to a contact (often modeled as a vCard Individual). In lightweight models, you can still attach a contact node with label/email fields."@en ;
    dp:embedding_note """contact point has label contact point.
contact point has definition Relevant contact information for the resource.
contact point has scope note Use dcat:contactPoint to link a resource to a contact (often modeled as a vCard Individual). In lightweight models, you can still attach a contact node with label/email fields."""@en .

dcat:dataset a owl:ObjectProperty ;
    rdfs:domain dcat:Catalog ;
    rdfs:subPropertyOf dcat:resource ;
    dp:embedding_label "serves dataset" .

dcat:distribution a owl:AnnotationProperty ;
    rdfs:label "distribution"@en ;
    skos:definition "An available distribution of the dataset."@en ;
    skos:scopeNote "Use dcat:distribution to link a dataset to concrete representations (files, dumps, endpoints) modeled as dcat:Distribution. Put format and access info on the Distribution."@en ;
    dp:embedding_label "has distribution"@en ;
    dp:embedding_note """distribution has label distribution.
distribution has definition An available distribution of the dataset.
distribution has scope note Use dcat:distribution to link a dataset to concrete representations (files, dumps, endpoints) modeled as dcat:Distribution. Put format and access info on the Distribution."""@en .

dcat:downloadURL a owl:AnnotationProperty ;
    rdfs:label "download URL"@en ;
    skos:definition "A URL of the resource that gives direct access to a distribution of the dataset."@en ;
    skos:scopeNote "Use dcat:downloadURL for a direct-download link (file/object). If the URL is not a direct download (e.g., requires interaction), use dcat:accessURL."@en ;
    dp:embedding_note """download URL has label download URL.
download URL has definition A URL of the resource that gives direct access to a distribution of the dataset.
download URL has scope note Use dcat:downloadURL for a direct-download link (file/object). If the URL is not a direct download (e.g., requires interaction), use dcat:accessURL."""@en .

dcat:endpointURL a owl:AnnotationProperty ;
    dp:embedding_label "has enpoint URL"@en .

dcat:hadRole a owl:ObjectProperty ;
    rdfs:domain prov:Attribution ;
    rdfs:range dcat:Role ;
    dp:embedding_label "has role"@en .

dcat:inSeries a owl:AnnotationProperty ;
    dp:embedding_label "in series"@en .

dcat:keyword a owl:AnnotationProperty ;
    rdfs:label "keyword"@en ;
    skos:definition "A keyword or tag describing the resource."@en ;
    skos:scopeNote "Use dcat:keyword for free-text tags. For controlled vocabulary topics, prefer dcat:theme (typically pointing to SKOS concepts)."@en ;
    dp:embedding_label "has keyword"@en ;
    dp:embedding_note """keyword has label keyword.
keyword has definition A keyword or tag describing the resource.
keyword has scope note Use dcat:keyword for free-text tags. For controlled vocabulary topics, prefer dcat:theme (typically pointing to SKOS concepts)."""@en .

dcat:landingPage a owl:AnnotationProperty ;
    rdfs:label "landing page"@en ;
    skos:definition "A web page that provides access to the dataset, its distributions and/or additional information."@en ;
    skos:scopeNote "Use dcat:landingPage when you have a human-friendly web page for the dataset or distribution (docs, catalog UI page)."@en ;
    dp:embedding_note """landing page has label landing page.
landing page has definition A web page that provides access to the dataset, its distributions and/or additional information.
landing page has scope note Use dcat:landingPage when you have a human-friendly web page for the dataset or distribution (docs, catalog UI page)."""@en .

dcat:primaryTopic a owl:AnnotationProperty ;
    dp:embedding_label "has primary topic"@en .

dcat:record a owl:ObjectProperty ;
    rdfs:label "record"@en ;
    rdfs:domain dcat:Catalog ;
    rdfs:range dcat:CatalogRecord ;
    skos:definition "A record describing the registration of a single resource (e.g., a dataset, a data service) that is part of the catalog."@en ;
    skos:scopeNote "Use dcat:record when you represent catalog entries explicitly as dcat:CatalogRecord resources."@en ;
    dp:embedding_label "has catalog record"@en ;
    dp:embedding_note """record has label record.
record has definition A record describing the registration of a single resource (e.g., a dataset, a data service) that is part of the catalog.
record has scope note Use dcat:record when you represent catalog entries explicitly as dcat:CatalogRecord resources."""@en .

dcat:servesDataset a owl:AnnotationProperty ;
    rdfs:label "serves dataset"@en ;
    skos:definition "A collection of data that this data service can distribute."@en ;
    skos:scopeNote "Use dcat:servesDataset to link a dcat:DataService (API/service) to the datasets it provides access to."@en ;
    dp:embedding_label "serves dataset" ;
    dp:embedding_note """serves dataset has label serves dataset.
serves dataset has definition A collection of data that this data service can distribute.
serves dataset has scope note Use dcat:servesDataset to link a dcat:DataService (API/service) to the datasets it provides access to."""@en .

dcat:service a owl:ObjectProperty ;
    rdfs:label "service"@en ;
    rdfs:domain dcat:Catalog ;
    rdfs:range dcat:DataService ;
    rdfs:subPropertyOf dcat:resource ;
    skos:definition "A service that is listed in the catalog."@en ;
    skos:scopeNote "Use dcat:service when the listed resource is specifically a dcat:DataService. This is more precise than dcat:resource."@en ;
    dp:embedding_label "has service"@en ;
    dp:embedding_note """service has label service.
service has definition A service that is listed in the catalog.
service has scope note Use dcat:service when the listed resource is specifically a dcat:DataService. This is more precise than dcat:resource."""@en .

dcat:theme a owl:AnnotationProperty ;
    rdfs:label "theme"@en ;
    skos:definition "A main category of the resource. A resource can have multiple themes."@en ;
    skos:scopeNote "Use dcat:theme to point to controlled concepts (SKOS) that categorize datasets/services. This is better for navigation and governance than free-text tags alone."@en ;
    dp:embedding_note """theme has label theme.
theme has definition A main category of the resource. A resource can have multiple themes.
theme has scope note Use dcat:theme to point to controlled concepts (SKOS) that categorize datasets/services. This is better for navigation and governance than free-text tags alone."""@en .

odrl:Privacy a owl:Class ;
    rdfs:label "Privacy Policy"@en ;
    rdfs:subClassOf odrl:Policy ;
    skos:definition "A Policy that grants the assignee a Rule over an Asset from an assigner." ;
    skos:note "A Privacy Policy  MUST contain a target Asset, a Party with Assigner  is, a Party with Assignee function, and at least one of a Permission or Prohibition rule that MUST include a Duty. The target Asset SHOULD contain or relate to personal information about the Assignee. The Duty MUST describe obligations on the Assigner about managing the Asset. The Assignee is being granted the terms of the Privacy policy from the Assigner." ;
    dp:embedding_note """Privacy Policy is a kind of Policy.
Privacy Policy has label Privacy Policy.
Privacy Policy has definition A Policy that grants the assignee a Rule over an Asset from an assigner."""@en .

odrl:action a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( odrl:Policy odrl:Rule ) ] ;
    rdfs:range odrl:Action .

odrl:assignee a owl:ObjectProperty ;
    rdfs:label "Assignee"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( odrl:Policy odrl:Rule ) ] ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Party ;
    rdfs:subPropertyOf odrl:function ;
    skos:definition "The Party is the recipient of the Rule."@en ;
    dp:embedding_label "has assignee"@en ;
    dp:embedding_note """Assignee has label Assignee.
Assignee has definition The Party is the recipient of the Rule."""@en .

odrl:assigneeOf a owl:ObjectProperty ;
    rdfs:label "Assignee Of"@en ;
    rdfs:domain odrl:Party ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Policy ;
    skos:definition "Identifies an ODRL Policy for which the identified Party undertakes the assignee functional role."@en ;
    skos:note "When assigneeOf has been asserted between a metadata expression and an ODRL Policy, the Party being identified MUST be inferred to undertake the assignee functional role of all the Rules of that Policy."@en ;
    dp:embedding_note """Assignee Of has label Assignee Of.
Assignee Of has definition Identifies an ODRL Policy for which the identified Party undertakes the assignee functional role."""@en .

odrl:assigner a owl:ObjectProperty ;
    rdfs:label "Assigner"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( odrl:Policy odrl:Rule ) ] ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Party ;
    rdfs:subPropertyOf odrl:function ;
    skos:definition "The Party is the issuer of the Rule."@en ;
    dp:embedding_label "has assigner"@en ;
    dp:embedding_note """Assigner has label Assigner.
Assigner has definition The Party is the issuer of the Rule."""@en .

odrl:assignerOf a owl:ObjectProperty ;
    rdfs:label "Assigner Of"@en ;
    rdfs:domain odrl:Party ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Policy ;
    skos:definition "Identifies an ODRL Policy for which the identified Party undertakes the assigner functional role."@en ;
    skos:note "When assignerOf has been asserted between a metadata expression and an ODRL Policy, the Party being identified MUST be inferred to undertake the assigner functional role of all the Rules of that Policy."@en ;
    dp:embedding_note """Assigner Of has label Assigner Of.
Assigner Of has definition Identifies an ODRL Policy for which the identified Party undertakes the assigner functional role."""@en .

odrl:hasPermission a owl:ObjectProperty ;
    rdfs:label "Has Permission"@en ;
    rdfs:domain odrl:Policy ;
    rdfs:range odrl:Permission ;
    skos:definition "Relates an individual Permission to a Policy." ;
    dp:embedding_label "has permission"@en ;
    dp:embedding_note """Has Permission has label Has Permission.
Has Permission has definition Relates an individual Permission to a Policy."""@en .

odrl:prohibition a owl:ObjectProperty ;
    rdfs:label "Has Prohibition"@en ;
    rdfs:domain odrl:Policy ;
    rdfs:range odrl:Prohibition ;
    skos:definition "Relates an individual Prohibition to a Policy."@en ;
    dp:embedding_label "has prohibition"@en ;
    dp:embedding_note """Has Prohibition has label Has Prohibition.
Has Prohibition has definition Relates an individual Prohibition to a Policy."""@en .

odrl:target a owl:ObjectProperty ;
    rdfs:label "Target"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( odrl:Policy odrl:Rule ) ] ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Asset ;
    rdfs:subPropertyOf odrl:relation ;
    skos:definition "The target property indicates the Asset that is the primary subject to which the Rule action directly applies."@en ;
    dp:embedding_label "has target"@en ;
    dp:embedding_note """Target has label Target.
Target has definition The target property indicates the Asset that is the primary subject to which the Rule action directly applies."""@en .

org:memberOf a owl:AnnotationProperty .

prov:agent a owl:ObjectProperty ;
    rdfs:domain prov:Attribution ;
    rdfs:range prov:Agent ;
    dp:embedding_label "has agent"@en .

prov:endedAtTime a owl:AnnotationProperty .

prov:generated a owl:ObjectProperty ;
    rdfs:label "generated"@en ;
    dp:embedding_note "generated has label generated."@en .

prov:generatedAtTime a owl:DatatypeProperty ;
    rdfs:label "generated at time"@en ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:dateTime ;
    dp:embedding_note "generated at time has label generated at time."@en .

prov:hadPrimarySource a owl:ObjectProperty ;
    rdfs:label "had primary source"@en ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Entity ;
    dp:embedding_note "had primary source has label had primary source."@en .

prov:qualifiedAttribution a owl:ObjectProperty ;
    rdfs:label "qualified attribution"@en ;
    rdfs:domain dcat:Resource ;
    rdfs:range prov:Attribution ;
    dp:embedding_note "qualified attribution has label qualified attribution."@en .

prov:startedAtTime a owl:AnnotationProperty .

prov:used a owl:ObjectProperty ;
    rdfs:label "used"@en ;
    rdfs:subPropertyOf dp:is_downstream_of ;
    owl:inverseOf dp:is_used_by ;
    skos:definition "A relation between an Activity and an Entity, where the Entity is used by the Activity."@en ;
    skos:scopeNote "Use prov:used to connect an activity to any entity it consumed, processed, referenced, or otherwise relied on. Use prov:qualifiedUsage when you need additional details (e.g., role, time, or specific parameters)."@en ;
    dp:embedding_note """used has label used.
used has definition A relation between an Activity and an Entity, where the Entity is used by the Activity.
used has scope note Use prov:used to connect an activity to any entity it consumed, processed, referenced, or otherwise relied on. Use prov:qualifiedUsage when you need additional details (e.g., role, time, or specific parameters)."""@en .

prov:wasAssociatedWith a owl:ObjectProperty ;
    rdfs:label "was associated with"@en ;
    skos:definition "An association between an Activity and an Agent that had some responsibility for the Activity."@en ;
    skos:scopeNote "Use prov:wasAssociatedWith to connect an activity to the agent(s) responsible for it (person, organization, software agent, pipeline). Use prov:qualifiedAssociation when you want to attach a role, plan, or other details."@en ;
    dp:embedding_note """was associated with has label was associated with.
was associated with has definition An association between an Activity and an Agent that had some responsibility for the Activity.
was associated with has scope note Use prov:wasAssociatedWith to connect an activity to the agent(s) responsible for it (person, organization, software agent, pipeline). Use prov:qualifiedAssociation when you want to attach a role, plan, or other details."""@en .

prov:wasAttributedTo a owl:ObjectProperty ;
    rdfs:label "was attributed to"@en ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Agent ;
