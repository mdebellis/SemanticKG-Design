    rdfs:range dp:Bounded_Context ;
    skos:definition "Relates a Context Map Relationship to the bounded context that acts as the target or downstream context in an inter-context relationship. This context depends on, integrates with, or adapts information originating from another context."@en .

dp:has_version a owl:ObjectProperty ;
