    <owl:Class rdf:about="https://michaeldebellis.com/people/Child">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://michaeldebellis.com/people/Person"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://michaeldebellis.com/people/has_age"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</xsd:maxExclusive>
                                    </rdf:Description>
