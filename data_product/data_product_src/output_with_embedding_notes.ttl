    rdfs:label "about domain concept"@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range skos:Concept ;
    dp:embedding_label "is about domain concept"@en .

dp:access_mode a owl:AnnotationProperty ;
    rdfs:label "access mode"@en .

