@prefix : <https://www.michaeldebellis.com/dp/> .
@prefix ex: <https://www.michaeldebellis.com/dp/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <https://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://www.michaeldebellis.com/dp/> .

<https://www.michaeldebellis.com/dp/> rdf:type owl:Ontology ;
                                       owl:imports <https://www.w3.org/2004/02/skos/core> ,
                                                   <https://www.w3.org/ns/prov-o#> ;
                                       dcterms:created "2024-11-01"^^xsd:date ;
                                       dcterms:creator "Michael DeBellis"@en ;
                                       dcterms:description "An OWL module for modeling Data Products, their contracts, interfaces, datasets, pipelines, SLOs, and governance, aligned with PROV-O, DCT, and SKOS."@en ;
                                       dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                       dcterms:modified "2025-10-15T19:15:00-07:00"^^xsd:dateTime ,
                                                        "2025-10-15T19:30:00-07:00"^^xsd:dateTime ;
                                       dcterms:title "Data Product Ontology"@en ;
                                       owl:versionInfo "0.6.0" ,
                                                       "1.0.0" ;
                                       skos:changeNote """
  • Removed legacy Dublin Core Elements (dc:*) annotation properties and standardized on dcterms:*; retained dc:date only as the super-property that groups date subproperties per DCMI practice.
  • Declared dcterms:Agent equivalent to prov:Agent; deprecated dcterms:Agent for new use (prov:Agent is canonical).
  • Kept SHACL validation to flag any accidental dc:* usage in data.
  """@en ,
                                                       "Refined namespace normalization; deprecated dcterms:Agent; standardized on dcterms:*."@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/dcam/domainIncludes
<http://purl.org/dc/dcam/domainIncludes> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/dcam/rangeIncludes
<http://purl.org/dc/dcam/rangeIncludes> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
dcterms:abstract rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:description .


###  http://purl.org/dc/terms/accessRights
dcterms:accessRights rdf:type owl:AnnotationProperty ;
                     rdfs:subPropertyOf dcterms:rights .


###  http://purl.org/dc/terms/accrualMethod
dcterms:accrualMethod rdf:type owl:AnnotationProperty ;
                      rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/accrualPeriodicity
dcterms:accrualPeriodicity rdf:type owl:AnnotationProperty ;
                           rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/accrualPolicy
dcterms:accrualPolicy rdf:type owl:AnnotationProperty ;
                      rdfs:domain <http://purl.org/dc/dcmitype/Collection> .


###  http://purl.org/dc/terms/alternative
dcterms:alternative rdf:type owl:AnnotationProperty ;
                    rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/audience
dcterms:audience rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/available
dcterms:available rdf:type owl:AnnotationProperty ;
                  rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                  rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty ;
                              rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/conformsTo
dcterms:conformsTo rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/coverage
dcterms:coverage rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf dcterms:contributor .


###  http://purl.org/dc/terms/date
dcterms:date rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
             rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/dateAccepted
dcterms:dateAccepted rdf:type owl:AnnotationProperty ;
                     rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                     rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/dateCopyrighted
dcterms:dateCopyrighted rdf:type owl:AnnotationProperty ;
                        rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                        rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/dateSubmitted
dcterms:dateSubmitted rdf:type owl:AnnotationProperty ;
                      rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                      rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/educationLevel
dcterms:educationLevel rdf:type owl:AnnotationProperty ;
                       rdfs:subPropertyOf dcterms:audience .


###  http://purl.org/dc/terms/extent
dcterms:extent rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf dcterms:format .


###  http://purl.org/dc/terms/format
dcterms:format rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/hasFormat
dcterms:hasFormat rdf:type owl:AnnotationProperty ;
                  rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/hasPart
dcterms:hasPart rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/hasVersion
dcterms:hasVersion rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:AnnotationProperty ;
                   rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/isFormatOf
dcterms:isFormatOf rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/isPartOf
dcterms:isPartOf rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/isReferencedBy
dcterms:isReferencedBy rdf:type owl:AnnotationProperty ;
                       rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/isReplacedBy
dcterms:isReplacedBy rdf:type owl:AnnotationProperty ;
                     rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/isRequiredBy
dcterms:isRequiredBy rdf:type owl:AnnotationProperty ;
                     rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/isVersionOf
dcterms:isVersionOf rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
               rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/language
dcterms:language rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf dcterms:rights .


###  http://purl.org/dc/terms/mediator
dcterms:mediator rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:audience .


###  http://purl.org/dc/terms/medium
dcterms:medium rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf dcterms:format .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
                 rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/references
dcterms:references rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/relation
dcterms:relation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/replaces
dcterms:replaces rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/requires
dcterms:requires rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/rights
dcterms:rights rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf dcterms:relation .


###  http://purl.org/dc/terms/spatial
dcterms:spatial rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf dcterms:coverage .


###  http://purl.org/dc/terms/subject
dcterms:subject rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/tableOfContents
dcterms:tableOfContents rdf:type owl:AnnotationProperty ;
                        rdfs:subPropertyOf dcterms:description .


###  http://purl.org/dc/terms/temporal
dcterms:temporal rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf dcterms:coverage .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty ;
              rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/type
dcterms:type rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/valid
dcterms:valid rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf <http://purl.org/dc/elements/1.1/date> ;
              rdfs:range rdfs:Literal .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://purl.org/dc/terms/Box
dcterms:Box rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/ISO3166
dcterms:ISO3166 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/ISO639-2
dcterms:ISO639-2 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/ISO639-3
dcterms:ISO639-3 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/Period
dcterms:Period rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/Point
dcterms:Point rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/RFC1766
dcterms:RFC1766 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/RFC3066
dcterms:RFC3066 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/RFC4646
dcterms:RFC4646 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/RFC5646
dcterms:RFC5646 rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/URI
dcterms:URI rdf:type rdfs:Datatype .


###  http://purl.org/dc/terms/W3CDTF
dcterms:W3CDTF rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/ns/prov#wasAttributedTo
<http://www.w3.org/ns/prov#wasAttributedTo> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty .


###  https://www.michaeldebellis.com/dp/data_product_owner
ex:data_product_owner rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAttributedTo> ;
                      rdfs:domain ex:Data_Product ;
                      rdfs:range <http://www.w3.org/ns/prov#Agent> ;
                      skos:definition "The accountable owner (person/team) attributed to the product."@en ;
                      skos:prefLabel "data product owner"@en .


###  https://www.michaeldebellis.com/dp/data_product_steward
ex:data_product_steward rdf:type owl:ObjectProperty ;
                        rdfs:domain ex:Data_Product ;
                        rdfs:range <http://www.w3.org/ns/prov#Agent> ;
                        skos:definition "The steward responsible for day-to-day governance."@en ;
                        skos:prefLabel "data product steward"@en .


###  https://www.michaeldebellis.com/dp/exposes_interface
ex:exposes_interface rdf:type owl:ObjectProperty ;
                     rdfs:domain ex:Data_Product ;
                     rdfs:range ex:Data_Interface ;
                     skos:definition "Declares an access interface exposed by the data product."@en ;
                     skos:prefLabel "exposes interface"@en .


###  https://www.michaeldebellis.com/dp/has_access_mode
ex:has_access_mode rdf:type owl:ObjectProperty ;
                   rdfs:domain ex:Data_Interface ;
                   rdfs:range ex:Access_Mode ;
                   skos:definition "Indicates the interaction style for a specific interface."@en ;
                   skos:prefLabel "has access mode"@en .


###  https://www.michaeldebellis.com/dp/has_access_policy
ex:has_access_policy rdf:type owl:ObjectProperty ;
                     rdfs:domain ex:Data_Product ;
                     rdfs:range ex:Access_Policy ;
                     skos:definition "Links to the policy governing usage and authorization."@en ;
                     skos:prefLabel "has access policy"@en .


###  https://www.michaeldebellis.com/dp/has_contract
ex:has_contract rdf:type owl:ObjectProperty ;
                rdfs:domain ex:Data_Product ;
                rdfs:range ex:Data_Contract ;
                skos:definition "Links a data product to its data contract."@en ;
                skos:prefLabel "has contract"@en .


###  https://www.michaeldebellis.com/dp/has_domain
ex:has_domain rdf:type owl:ObjectProperty ;
              rdfs:domain ex:Data_Product ;
              rdfs:range ex:Data_Domain ;
              skos:definition "Associates a data product to its owning data domain."@en ;
              skos:prefLabel "has domain"@en .


###  https://www.michaeldebellis.com/dp/has_lifecycle_state
ex:has_lifecycle_state rdf:type owl:ObjectProperty ;
                       rdfs:domain ex:Data_Product ;
                       rdfs:range ex:Lifecycle_State ;
                       skos:definition "States the current lifecycle stage of the product."@en ;
                       skos:prefLabel "has lifecycle state"@en .


###  https://www.michaeldebellis.com/dp/has_product_type
ex:has_product_type rdf:type owl:ObjectProperty ;
                    rdfs:domain ex:Data_Product ;
                    rdfs:range ex:Data_Product_Type ;
                    skos:definition "Indicates the category of the data product."@en ;
                    skos:prefLabel "has product type"@en .


###  https://www.michaeldebellis.com/dp/has_quality_slo
ex:has_quality_slo rdf:type owl:ObjectProperty ;
                   rdfs:domain ex:Data_Product ;
                   rdfs:range ex:Data_Quality_SLO ;
                   skos:definition "Associates SLO thresholds with a data product."@en ;
                   skos:prefLabel "has quality SLO"@en .


###  https://www.michaeldebellis.com/dp/has_semantic_model
ex:has_semantic_model rdf:type owl:ObjectProperty ;
                      rdfs:domain ex:Data_Product ;
                      rdfs:range ex:Semantic_Model ;
                      skos:definition "Associates a data product with the governing ontology/shape."@en ;
                      skos:prefLabel "has semantic model"@en .


###  https://www.michaeldebellis.com/dp/has_sensitivity_level
ex:has_sensitivity_level rdf:type owl:ObjectProperty ;
                         rdfs:domain ex:Data_Product ;
                         rdfs:range ex:Sensitivity_Level ;
                         skos:definition "Classifies the exposure/compliance level."@en ;
                         skos:prefLabel "has sensitivity level"@en .


###  https://www.michaeldebellis.com/dp/includes_asset
ex:includes_asset rdf:type owl:ObjectProperty ;
                  rdfs:domain ex:Data_Product ;
                  rdfs:range ex:Dataset ;
                  skos:definition "Declares datasets or snapshots that constitute the product."@en ;
                  skos:prefLabel "includes asset"@en .


###  https://www.michaeldebellis.com/dp/produced_by_pipeline
ex:produced_by_pipeline rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasGeneratedBy> ;
                        rdfs:domain ex:Dataset ;
                        rdfs:range ex:Data_Pipeline ;
                        skos:definition "Indicates the pipeline activity that generated a dataset."@en ;
                        skos:prefLabel "produced by pipeline"@en .


###  https://www.michaeldebellis.com/dp/serves_use_case
ex:serves_use_case rdf:type owl:ObjectProperty ;
                   rdfs:domain ex:Data_Product ;
                   rdfs:range ex:Use_Case ;
                   skos:definition "Indicates the business purpose the product supports."@en ;
                   skos:prefLabel "serves use case"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/dc/dcam/VocabularyEncodingScheme
<http://purl.org/dc/dcam/VocabularyEncodingScheme> rdf:type owl:Class .


###  http://purl.org/dc/terms/Agent
dcterms:Agent rdf:type owl:Class ;
              owl:equivalentClass <http://www.w3.org/ns/prov#Agent> .


###  http://purl.org/dc/terms/AgentClass
dcterms:AgentClass rdf:type owl:Class ;
                   rdfs:subClassOf rdfs:Class .


###  http://purl.org/dc/terms/BibliographicResource
dcterms:BibliographicResource rdf:type owl:Class .


###  http://purl.org/dc/terms/FileFormat
dcterms:FileFormat rdf:type owl:Class ;
                   rdfs:subClassOf dcterms:MediaType .


###  http://purl.org/dc/terms/Frequency
dcterms:Frequency rdf:type owl:Class .


###  http://purl.org/dc/terms/Jurisdiction
dcterms:Jurisdiction rdf:type owl:Class ;
                     rdfs:subClassOf dcterms:LocationPeriodOrJurisdiction .


###  http://purl.org/dc/terms/LicenseDocument
dcterms:LicenseDocument rdf:type owl:Class ;
                        rdfs:subClassOf dcterms:RightsStatement .


###  http://purl.org/dc/terms/LinguisticSystem
dcterms:LinguisticSystem rdf:type owl:Class .


###  http://purl.org/dc/terms/Location
dcterms:Location rdf:type owl:Class ;
                 rdfs:subClassOf dcterms:LocationPeriodOrJurisdiction .


###  http://purl.org/dc/terms/LocationPeriodOrJurisdiction
dcterms:LocationPeriodOrJurisdiction rdf:type owl:Class .


###  http://purl.org/dc/terms/MediaType
dcterms:MediaType rdf:type owl:Class ;
                  rdfs:subClassOf dcterms:MediaTypeOrExtent .


###  http://purl.org/dc/terms/MediaTypeOrExtent
dcterms:MediaTypeOrExtent rdf:type owl:Class .


###  http://purl.org/dc/terms/MethodOfAccrual
dcterms:MethodOfAccrual rdf:type owl:Class .


###  http://purl.org/dc/terms/MethodOfInstruction
dcterms:MethodOfInstruction rdf:type owl:Class .


###  http://purl.org/dc/terms/PeriodOfTime
dcterms:PeriodOfTime rdf:type owl:Class ;
                     rdfs:subClassOf dcterms:LocationPeriodOrJurisdiction .


###  http://purl.org/dc/terms/PhysicalMedium
dcterms:PhysicalMedium rdf:type owl:Class ;
                       rdfs:subClassOf dcterms:MediaType .


###  http://purl.org/dc/terms/PhysicalResource
dcterms:PhysicalResource rdf:type owl:Class .


###  http://purl.org/dc/terms/Policy
dcterms:Policy rdf:type owl:Class .


###  http://purl.org/dc/terms/ProvenanceStatement
dcterms:ProvenanceStatement rdf:type owl:Class .


###  http://purl.org/dc/terms/RightsStatement
dcterms:RightsStatement rdf:type owl:Class .


###  http://purl.org/dc/terms/SizeOrDuration
dcterms:SizeOrDuration rdf:type owl:Class ;
                       rdfs:subClassOf dcterms:MediaTypeOrExtent .


###  http://purl.org/dc/terms/Standard
dcterms:Standard rdf:type owl:Class .


###  http://www.w3.org/2000/01/rdf-schema#Class
rdfs:Class rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  https://www.michaeldebellis.com/dp/Access_Mode
ex:Access_Mode rdf:type owl:Class ;
               skos:definition "The interaction style for an interface: batch, stream, or query-on-demand."@en ;
               skos:prefLabel "Access Mode"@en .


###  https://www.michaeldebellis.com/dp/Access_Policy
ex:Access_Policy rdf:type owl:Class ;
                 skos:definition "A policy governing authorization and acceptable use (e.g., RBAC/ABAC) for a data product."@en ;
                 skos:prefLabel "Access Policy"@en .


###  https://www.michaeldebellis.com/dp/Active
ex:Active rdf:type owl:Class ;
          rdfs:subClassOf ex:Lifecycle_State .


###  https://www.michaeldebellis.com/dp/Analytical_Product
ex:Analytical_Product rdf:type owl:Class ;
                      rdfs:subClassOf ex:Data_Product_Type .


###  https://www.michaeldebellis.com/dp/Batch_Access
ex:Batch_Access rdf:type owl:Class ;
                rdfs:subClassOf ex:Access_Mode .


###  https://www.michaeldebellis.com/dp/Data_Contract
ex:Data_Contract rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                 skos:definition "Consumer-facing guarantees: schema/shape, cadence, quality, and change policy for a data product."@en ;
                 skos:prefLabel "Data Contract"@en .


###  https://www.michaeldebellis.com/dp/Data_Domain
ex:Data_Domain rdf:type owl:Class ;
               skos:definition "A business domain or bounded context that owns and stewards data products."@en ;
               skos:prefLabel "Data Domain"@en .


###  https://www.michaeldebellis.com/dp/Data_Interface
ex:Data_Interface rdf:type owl:Class ;
                  skos:definition "A concrete access endpoint or mechanism exposed by a data product (e.g., API, SPARQL, file drop)."@en ;
                  skos:prefLabel "Data Interface"@en .


###  https://www.michaeldebellis.com/dp/Data_Pipeline
ex:Data_Pipeline rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                 skos:definition "An activity that generates, updates, or transforms datasets for a data product."@en ;
                 skos:prefLabel "Data Pipeline"@en .


###  https://www.michaeldebellis.com/dp/Data_Product
ex:Data_Product rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                skos:definition "A curated, governed, consumer-facing data artifact with a contract, interfaces, semantic model, and SLOs."@en ;
                skos:prefLabel "Data Product"@en .


###  https://www.michaeldebellis.com/dp/Data_Product_Type
ex:Data_Product_Type rdf:type owl:Class ;
                     skos:definition "A category indicating the general purpose or usage pattern of the product."@en ;
                     skos:prefLabel "Data Product Type"@en .


###  https://www.michaeldebellis.com/dp/Data_Quality_SLO
ex:Data_Quality_SLO rdf:type owl:Class ;
                    skos:definition "A set of service level objectives (availability, freshness, latency) for a data product or interface."@en ;
                    skos:prefLabel "Data Quality SLO"@en .


###  https://www.michaeldebellis.com/dp/Dataset
ex:Dataset rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
           skos:definition "A materialized collection of records or graph snapshot belonging to or produced by a data product."@en ;
           skos:prefLabel "Dataset"@en .


###  https://www.michaeldebellis.com/dp/Deprecated
ex:Deprecated rdf:type owl:Class ;
              rdfs:subClassOf ex:Lifecycle_State ;
              skos:prefLabel "Deprecated"@en .


###  https://www.michaeldebellis.com/dp/Event_Stream_Product
ex:Event_Stream_Product rdf:type owl:Class ;
                        rdfs:subClassOf ex:Data_Product_Type ;
                        skos:prefLabel "Event Stream Product"@en .


###  https://www.michaeldebellis.com/dp/Internal
ex:Internal rdf:type owl:Class ;
            rdfs:subClassOf ex:Sensitivity_Level ;
            skos:prefLabel "Internal"@en .


###  https://www.michaeldebellis.com/dp/Lifecycle_State
ex:Lifecycle_State rdf:type owl:Class ;
                   skos:definition "The product lifecycle stage (e.g., Proposed, Active, Deprecated, Retired)."@en ;
                   skos:prefLabel "Lifecycle State"@en .


###  https://www.michaeldebellis.com/dp/MDM_Reference_Product
ex:MDM_Reference_Product rdf:type owl:Class ;
                         rdfs:subClassOf ex:Data_Product_Type ;
                         skos:prefLabel "MDM / Reference Product"@en .


###  https://www.michaeldebellis.com/dp/Operational_Product
ex:Operational_Product rdf:type owl:Class ;
                       rdfs:subClassOf ex:Data_Product_Type ;
                       skos:prefLabel "Operational Product"@en .


###  https://www.michaeldebellis.com/dp/Proposed
ex:Proposed rdf:type owl:Class ;
            rdfs:subClassOf ex:Lifecycle_State ;
            skos:prefLabel "Proposed"@en .


###  https://www.michaeldebellis.com/dp/Public
ex:Public rdf:type owl:Class ;
          rdfs:subClassOf ex:Sensitivity_Level ;
          skos:prefLabel "Public"@en .


###  https://www.michaeldebellis.com/dp/Query_Access
ex:Query_Access rdf:type owl:Class ;
                rdfs:subClassOf ex:Access_Mode .


###  https://www.michaeldebellis.com/dp/Restricted
ex:Restricted rdf:type owl:Class ;
              rdfs:subClassOf ex:Sensitivity_Level .


###  https://www.michaeldebellis.com/dp/Retired
ex:Retired rdf:type owl:Class ;
           rdfs:subClassOf ex:Lifecycle_State ;
           skos:prefLabel "Retired"@en .


###  https://www.michaeldebellis.com/dp/Semantic_Model
ex:Semantic_Model rdf:type owl:Class ;
                  skos:definition "The ontology/shape definitions (e.g., OWL, SHACL, JSON-LD context) governing a data product."@en ;
                  skos:prefLabel "Semantic Model"@en .


###  https://www.michaeldebellis.com/dp/Sensitivity_Level
ex:Sensitivity_Level rdf:type owl:Class ;
                     skos:definition "A coarse-grained classification for exposure risk and compliance constraints."@en ;
                     skos:prefLabel "Sensitivity Level"@en .


###  https://www.michaeldebellis.com/dp/Stream_Access
ex:Stream_Access rdf:type owl:Class ;
                 rdfs:subClassOf ex:Access_Mode ;
                 skos:prefLabel "Stream Access"@en .


###  https://www.michaeldebellis.com/dp/Use_Case
ex:Use_Case rdf:type owl:Class ;
            skos:definition "A business or analytical objective served by a data product."@en ;
            skos:prefLabel "Use Case"@en .


