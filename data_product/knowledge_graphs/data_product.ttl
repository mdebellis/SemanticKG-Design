<http://www.w3.org/ns/dcat#hasCurrentVersion> rdfs:comment "Este recurso es más específico y versionado con contenido equivalente [PAV]."@es ,
                                                           "Per questa risorsa esiste una risorsa più specifica e versionata, ma con lo stesso contenuto."@it ,
                                                           "This resource has a more specific, versioned resource with equivalent content [PAV]."@en ;
                                              rdfs:isDefinedBy <https://www.w3.org/TR/vocab-dcat-3/> ;
                                              rdfs:label "ha versione attuale"@it ,
                                                         "has current version"@en ,
                                                         "tiene versión actual"@es ;
                                              skos:changeNote "New property added in DCAT 3."@en ,
                                                              "Nová vlastnost přidaná ve verzi DCAT 3."@cs ,
