    rdfs:label "elements/1.1/relation"@en ;
    dp:embedding_label "has relation"@en ;
    dp:embedding_note "elements/1.1/relation has label elements/1.1/relation."@en .

dc:rights a owl:AnnotationProperty ;
    rdfs:label "elements/1.1/rights"@en ;
    dp:embedding_note "elements/1.1/rights has label elements/1.1/rights."@en .

dc:source a owl:AnnotationProperty ;
    rdfs:label "elements/1.1/source"@en ;
    dp:embedding_label "ha source"@en ;
    dp:embedding_note "elements/1.1/source has label elements/1.1/source."@en .

dc:subject a owl:AnnotationProperty ;
    rdfs:label "elements/1.1/subject"@en ;
    dp:embedding_label "has subject"@en ;
    dp:embedding_note "elements/1.1/subject has label elements/1.1/subject."@en .

