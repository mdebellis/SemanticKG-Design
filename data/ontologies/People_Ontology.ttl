@prefix : <http://michaeldebellis.com/people/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@base <http://michaeldebellis.com/people/> .

<http://michaeldebellis.com/people> rdf:type owl:Ontology ;
                                     dct:creator """Michael DeBellis
Orcid ID: 0000-0002-8824-9577""" ;
                                     dct:license <https://creativecommons.org/licenses/by/4.0/legalcode> ;
                                     skos:definition "A simple example ontology of People, Organizations, Places, and Animals to illustrate basic Semantic Web concepts from RDF, RDFS, OWL, SPARQL and SHACL" .

#################################################################
#    Annotation properties
#################################################################

###  http://michaeldebellis.com/people/canonical_unit
:canonical_unit rdf:type owl:AnnotationProperty ;
                dct:contributor "Michael DeBellis" ;
                dct:created "2025-10-13T20:18:59Z"^^xsd:dateTime ;
                rdfs:range :Unit .


###  http://michaeldebellis.com/people/wikidata
:wikidata rdf:type owl:AnnotationProperty ;
          rdfs:range xsd:anyURI .


###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty ;
             rdfs:label "abstract" ;
             skos:definition "A summary of the resource." .


###  http://purl.org/dc/terms/contributor
dct:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dct:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty ;
            rdfs:comment "Recommended practice is to identify the creator with a URI. If this is not possible or feasible, a literal value that identifies the creator may be provided." ;
            rdfs:label "creator" ;
            skos:definition "An entity responsible for making the resource." .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/subject
dct:subject rdf:type owl:AnnotationProperty ;
            rdfs:comment "Recommended practice is to refer to the subject with a URI. If this is not possible or feasible, a literal value that identifies the subject may be provided. Both should preferably refer to a subject in a controlled vocabulary." ;
            rdfs:label "subject" ;
            skos:definition "A topic of the resource." .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty ;
          rdfs:label "title" ;
          skos:definition "A name given to the resource." .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
swrla:isRuleEnabled rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
              rdfs:label "alternative label"@en ;
              skos:definition "An alternative lexical label for a resource." ;
              skos:example "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)." ;
              rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty ;
                rdfs:label "change note"@en ;
                skos:definition "A note about a modification to a concept." ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:label "definition"@en ;
                skos:definition "A statement or formal explanation of the meaning of a concept." ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:label "example"@en ;
             skos:definition "An example of the use of a concept." ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
          rdfs:label "note"@en ;
          skos:definition "A general note, for any purpose."@en .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:comment "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.	The range of skos:prefLabel is the class of RDF plain literals. A resource has no more than one value of skos:prefLabel per language tag." ;
               rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
               rdfs:label "preferred label"@en ;
               skos:definition "The preferred lexical label for a resource, in a given language." ;
               rdfs:subPropertyOf rdfs:label .


#################################################################
#    Object Properties
#################################################################

###  http://michaeldebellis.com/people/contains
:contains rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :contains_transitive ;
          owl:inverseOf :is_contained_in ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:label "contains" .


###  http://michaeldebellis.com/people/contains_transitive
:contains_transitive rdf:type owl:ObjectProperty ;
                     owl:inverseOf :is_contained_in_transitive ;
                     rdf:type owl:TransitiveProperty ;
                     rdfs:domain :Place ;
                     rdfs:range :Place ;
                     rdfs:label "contains transitive" .


###  http://michaeldebellis.com/people/eats
:eats rdf:type owl:ObjectProperty ;
      rdfs:domain :Animal ;
      rdfs:range :Living_Thing ;
      rdfs:label "eats" .


###  http://michaeldebellis.com/people/equal_to
:equal_to rdf:type owl:ObjectProperty ;
          rdfs:domain :Measurement ;
          rdfs:range :Measurement ;
          dct:contributor "Michael DeBellis" ;
          dct:created "2025-10-03T04:58:19Z"^^xsd:dateTime ;
          rdfs:label "equal to" .


###  http://michaeldebellis.com/people/greater_than
:greater_than rdf:type owl:ObjectProperty ;
              owl:inverseOf :less_than ;
              rdf:type owl:TransitiveProperty ;
              rdfs:domain :Measurement ;
              rdfs:range :Measurement ;
              dct:contributor "Michael DeBellis" ;
              dct:created "2025-10-03T04:58:19Z"^^xsd:dateTime ;
              rdfs:label "greater than" .


###  http://michaeldebellis.com/people/has_Address
:has_Address rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Location ;
             owl:inverseOf :is_Address_For ;
             rdfs:domain :Agent ;
             rdfs:range :Address ;
             rdfs:label "has address" .


###  http://michaeldebellis.com/people/has_Aunt
:has_Aunt rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_family_relationship ;
          owl:inverseOf :is_Aunt_Of ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:label "has aunt" .


###  http://michaeldebellis.com/people/has_Colleague
:has_Colleague rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :has_Social_Relationship ;
               rdf:type owl:SymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:label "has colleague" .


###  http://michaeldebellis.com/people/has_Daughter
:has_Daughter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :has_child ;
              rdf:type owl:IrreflexiveProperty ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( :Girl
                                         :Woman
                                       )
                         ] ;
              rdfs:label "has daughter" .


###  http://michaeldebellis.com/people/has_Father
:has_Father rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Parent ;
            rdf:type owl:IrreflexiveProperty ;
            rdfs:range :Man ;
            :wikidata <https://www.wikidata.org/wiki/Q7565> ;
            rdfs:label "has father" .


###  http://michaeldebellis.com/people/has_Friend
:has_Friend rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Social_Relationship ;
            rdf:type owl:SymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:label "has friend" .


###  http://michaeldebellis.com/people/has_Gender
:has_Gender rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Animal ;
            rdfs:range :Gender ;
            rdfs:label "has gender" .


###  http://michaeldebellis.com/people/has_Husband
:has_Husband rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_Spouse ;
             rdf:type owl:IrreflexiveProperty ;
             rdfs:range :Man ;
             rdfs:label "has husband" .


###  http://michaeldebellis.com/people/has_Location
:has_Location rdf:type owl:ObjectProperty ;
              rdfs:range :Place ;
              rdfs:label "has location" .


###  http://michaeldebellis.com/people/has_Member
:has_Member rdf:type owl:ObjectProperty ;
            owl:inverseOf :is_Member_Of ;
            rdfs:domain :Organization ;
            rdfs:range :Agent ;
            rdfs:label "has member" .


###  http://michaeldebellis.com/people/has_Mother
:has_Mother rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Parent ;
            rdf:type owl:IrreflexiveProperty ;
            rdfs:range :Woman ;
            :wikidata <https://www.wikidata.org/wiki/Q7560> ;
            rdfs:label "has mother" .


###  http://michaeldebellis.com/people/has_Parent
:has_Parent rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_family_relationship ;
            owl:inverseOf :has_child ;
            rdf:type owl:IrreflexiveProperty ;
            rdfs:label "has parent" .


###  http://michaeldebellis.com/people/has_Pet
:has_Pet rdf:type owl:ObjectProperty ;
         owl:inverseOf :is_Pet_Of ;
         rdfs:label "has pet" .


###  http://michaeldebellis.com/people/has_Sibling
:has_Sibling rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_family_relationship ;
             rdf:type owl:SymmetricProperty ,
                      owl:IrreflexiveProperty ;
             rdfs:label "has sibling" .


###  http://michaeldebellis.com/people/has_Social_Relationship
:has_Social_Relationship rdf:type owl:ObjectProperty ,
                                  owl:SymmetricProperty ,
                                  owl:IrreflexiveProperty ;
                         rdfs:domain :Person ;
                         rdfs:range :Person ;
                         rdfs:label "has social relationship" .


###  http://michaeldebellis.com/people/has_Son
:has_Son rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :has_child ;
         rdf:type owl:IrreflexiveProperty ;
         rdfs:range [ rdf:type owl:Class ;
                      owl:unionOf ( :Boy
                                    :Man
                                  )
                    ] ;
         rdfs:label "has son" .


###  http://michaeldebellis.com/people/has_Spouse
:has_Spouse rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_family_relationship ;
            rdf:type owl:SymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain :Adult ;
            rdfs:range :Adult ;
            rdfs:label "has spouse" .


###  http://michaeldebellis.com/people/has_State
:has_State rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :has_Location ;
           rdfs:domain :Address ;
           rdfs:range :State ;
           rdfs:label "has state" .


###  http://michaeldebellis.com/people/has_Subsidiary
:has_Subsidiary rdf:type owl:ObjectProperty ;
                owl:inverseOf :is_subsidiary_of ;
                rdfs:domain :Organization ;
                rdfs:range :Orgonization_Component ;
                rdfs:label "has subsidiary" .


###  http://michaeldebellis.com/people/has_Uncle
:has_Uncle rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :has_family_relationship ;
