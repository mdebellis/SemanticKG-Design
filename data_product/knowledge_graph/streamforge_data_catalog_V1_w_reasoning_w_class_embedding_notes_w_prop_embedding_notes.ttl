        dp:Contract,
        dp:Service_Level_Agreement ;
    rdfs:label "SF Metadata SLA"@en ;
    dctm:description "Availability target: 99.9% monthly for metadata query service. Freshness target: new uploads reflected within 15 minutes at P95."@en ;
    rdfs:comment "Support: 24x7. Incident response: P1 acknowledged within 15 minutes; mitigation within 2 hours."@en ;
    dp:embedding_note """SF Metadata SLA is an instance of Contract.
SF Metadata SLA is an instance of Service Level Agreement.
