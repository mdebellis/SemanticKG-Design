sf:Search_Relevance_Experiment_Report_Q4_2025 a owl:NamedIndividual ;
    rdfs:label "Search Relevance Experiment Report Q4 2025"@en ;
    dcterms:created "2025-12-08"^^xsd:date ;
    dcterms:creator "Search & Discovery"@en ;
    dcterms:publisher "StreamForge Data Science"@en ;
    dcterms:title "Search Relevance Experiment Report (Q4 2025)"@en ;
    docs:uses_data_product sf:SF_Search_Queries_Data_Product ;
    docs:uses_dataset sf:SF_Search_Queries_Dataset ;
    dp:embedding_note "Search Relevance Experiment Report Q4 2025 uses data product: SF Search Queries Data Product."@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_01 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 01"@en ;
    docs:chunk_index 1 ;
    docs:chunk_text "We evaluated ranking changes using event-level query and click data. The primary objective was to reduce query reformulation and increase successful clicks on the first results page."@en ;
    docs:chunk_title "Executive summary"@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_02 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 02"@en ;
    docs:chunk_index 2 ;
    docs:chunk_text "All analyses used the StreamForge Search Queries data product backed by BigQuery tables in streamforge_warehouse.search.query_events. Analysts accessed the data via SQL and maintained an audit trail of query versions."@en ;
    docs:chunk_title "Datasets and access"@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_03 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 03"@en ;
    docs:chunk_index 3 ;
    docs:chunk_text "Primary metrics were successful click-through on first-page results, time-to-first-click, and query reformulation rate. We also tracked long-click rate as a proxy for satisfaction."@en ;
    docs:chunk_title "Metrics"@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_04 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 04"@en ;
    docs:chunk_index 4 ;
    docs:chunk_text "We ran a two-week A/B test on 10% of logged-in traffic. Treatment adjusted the weighting of freshness and creator authority signals for ambiguous queries."@en ;
    docs:chunk_title "Experiment design"@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_05 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 05"@en ;
    docs:chunk_index 5 ;
    docs:chunk_text "Treatment reduced query reformulation by 4.2% relative and improved successful clicks by 1.8% relative. Gains were largest for navigation queries and trending topics."@en ;
    docs:chunk_title "Findings"@en .

sf:Search_Relevance_Experiment_Report_Q4_2025_Chunk_06 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Search Relevance Experiment Report Q4 2025 Chunk 06"@en ;
    docs:chunk_index 6 ;
    docs:chunk_text "Promote the treatment model to 50% traffic and monitor regressions in rare-query performance. For governance, publish a stable 'search_experiments' view so metrics are reproducible across teams."@en ;
    docs:chunk_title "Recommendations"@en .

