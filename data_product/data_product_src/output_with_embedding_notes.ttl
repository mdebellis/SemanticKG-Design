dp:has_bounded_context a owl:ObjectProperty ;
    rdfs:label "has bounded context"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2025-12-12T04:27:40+00:00"^^xsd:dateTime,
        "2026-01-19T19:31:18+00:00"^^xsd:dateTime ;
    rdfs:comment "Data Product usage: Associates a Data Product with the bounded context that defines its semantic scope."@en,
        "Relates a Data Product to the bounded context whose model and language it implements."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:subPropertyOf dp:in_bounded_context ;
    owl:inverseOf dp:is_context_for ;
    skos:definition "Relates a Data Product to the bounded context that defines its domain model, ubiquitous language, and ownership. This property makes explicit which bounded context is responsible for the meaning and governance of a Data Product." ;
    dp:embedding_note "has bounded context has contributor Michael DeBellis."@en .

dp:implemented_by_activity a owl:ObjectProperty ;
    rdfs:label "implemented by activity"@en ;
    rdfs:comment "Data Product usage: Links a Data Product to the activity or process that implements or generates it."@en,
        "Relates a Data Product Version to the PROV activity (e.g., pipeline, job, process) that produces or maintains it."@en .

dp:in_bounded_context a owl:ObjectProperty ;
    rdfs:label "in bounded context"@en ;
    rdfs:range dp:Bounded_Context ;
    skos:definition "Relates an entity to the bounded context within which its meaning, model, and assumptions apply. This property provides a general notion of contextual containment and may be used for assets, artifacts, or concepts that are scoped to a particular bounded context."@en .

dp:is_account_of a owl:ObjectProperty ;
    rdfs:label "is account of"@en ;
    rdfs:domain dp:Account ;
    rdfs:range prov:Person .

dp:is_context_for a owl:ObjectProperty ;
    rdfs:label "is context for"@en ;
    skos:definition "Inverse of has_bounded_context. Relates a bounded context to the Data Products whose meaning, ownership, and governance it defines."@en .

