    <owl:Ontology rdf:about="https://michaeldebellis.com/people">
        <terms:creator>Michael DeBellis
Orcid ID: 0000-0002-8824-9577</terms:creator>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/legalcode"/>
        <skos:definition>A simple example ontology of People, Organizations, Places, and Animals to illustrate basic Semantic Web concepts from RDF, RDFS, OWL, SPARQL and SHACL</skos:definition>
    </owl:Ontology>
    


