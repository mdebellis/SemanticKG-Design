###  http://michaeldebellis.com/people/has_Sister
:has_Sister rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :has_Sibling ;
            rdfs:range [ rdf:type owl:Restriction ;
                         owl:onProperty :has_Gender ;
                         owl:hasValue :Female
                       ] ;
            rdfs:label "has sister" .


###  http://michaeldebellis.com/people/has_Social_Relationship
:has_Social_Relationship rdf:type owl:ObjectProperty ,
