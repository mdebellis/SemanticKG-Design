                                               skos:definition "An aggregation activity that consolidates creator engagement data into a curated analytics dataset."@en ;
                                               <http://www.w3.org/ns/prov#endedAtTime> "2026-02-08T07:25:00-08:00"^^xsd:dateTime ;
                                               <http://www.w3.org/ns/prov#startedAtTime> "2026-02-08T07:10:00-08:00"^^xsd:dateTime .


