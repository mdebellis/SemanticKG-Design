    rdfs:label "Python"@en ;
    dp:embedding_note "Python is an instance of Programming language."@en .

dp:SF_Creator_Insights_Contract a owl:NamedIndividual ;
    rdfs:label "SF Creator Insights Contract"@en ;
    dctm:description "Defines measures and dimensions for creator analytics: views, watch time, subscribers, revenue proxies. Consumers: dashboards and internal analytics."@en ;
    rdfs:comment "Definitions: watch_time_minutes = total minutes watched across all plays. unique_viewers = approximate distinct viewers per day. Grain: creator_id by day."@en,
        "Story: As a creator success analyst, I need daily aggregates by creator_id so I can explain growth trends without reconstructing metrics from raw events."@en .

dp:SF_Creator_Insights_Key a owl:NamedIndividual ;
    rdfs:label "SF Creator Insights Key"@en ;
    dctm:description "Business key identifying the creator insights product."@en .

dp:SF_Creator_Insights_Quality a owl:NamedIndividual ;
    rdfs:label "SF Creator Insights Quality"@en ;
    dctm:description "Accuracy and coverage metrics for aggregated creator analytics."@en ;
    rdfs:comment "Coverage: >= 99% of active creators have daily rows. Accuracy: revenue proxy within +/- 3% of monthly finance reconciliation (where applicable)."@en .

dp:SF_Creator_Insights_SLA a owl:NamedIndividual,
        dp:Service_Level_Agreement ;
    rdfs:label "SF Creator Insights SLA"@en ;
    dctm:description "Freshness target: daily aggregates available by 06:00 UTC. Availability: 99.5% monthly for the analytics dataset."@en ;
    rdfs:comment "Backfill policy: late events corrected for prior 7 days; beyond 7 days by request."@en ;
    dp:embedding_note "SF Creator Insights SLA is an instance of Service Level Agreement."@en .

dp:SF_Creator_Insights_V1 a owl:NamedIndividual ;
    rdfs:label "SF Creator Insights V1"@en ;
    dctm:description "Daily aggregates by creator_id for core measures."@en ;
    dp:embedding_note "SF Creator Insights V1 version identifier v1."@en ;
    dp:version_identifier "v1" .

dp:SF_Metadata_Contract a owl:NamedIndividual ;
    rdfs:label "SF Metadata Contract"@en ;
    dctm:description "Defines the semantics, ownership, and expected quality for video metadata. Intended users: ingestion pipeline, discovery services, analytics consumers."@en ;
    rdfs:comment "Key entities: Video, Channel, Creator, Tag, Category. Required fields: video_id, creator_id, upload_timestamp, duration_seconds. Recommended: language, topic_tags. Change policy: breaking changes only on major version increments."@en,
        "Story: As a discovery engineer, I need consistent video_id, creator_id, upload time, and duration so search and ranking can join metadata reliably without brittle ad-hoc mappings."@en .

dp:SF_Metadata_Quality a owl:NamedIndividual ;
    rdfs:label "SF Metadata Quality"@en ;
    dctm:description "Completeness, consistency, and timeliness metrics for core video metadata fields."@en ;
    rdfs:comment "Completeness: required fields present for >= 99.5% of records daily. Consistency: video_id↔creator_id alignment >= 99.9%. Timeliness: ingest-to-availability median < 5 min, P95 < 15 min."@en .

dp:SF_Metadata_SLA a owl:NamedIndividual,
        dp:Service_Level_Agreement ;
    rdfs:label "SF Metadata SLA"@en ;
    dctm:description "Availability target: 99.9% monthly for metadata query service. Freshness target: new uploads reflected within 15 minutes at P95."@en ;
    rdfs:comment "Support: 24x7. Incident response: P1 acknowledged within 15 minutes; mitigation within 2 hours."@en ;
    dp:embedding_note "SF Metadata SLA is an instance of Service Level Agreement."@en .

dp:SF_Recommendations_Features_Key a owl:NamedIndividual ;
    rdfs:label "SF Recommendations Features Key"@en ;
    dctm:description "Business key identifying the recommendation features product."@en .

dp:SF_Recs_Features_Contract a owl:NamedIndividual ;
    rdfs:label "SF Recs Features Contract"@en ;
    dctm:description "Defines the features used by ranking/recommendation models, their refresh cycles, and intended uses."@en ;
    rdfs:comment "Feature sets: creator_popularity_score, video_engagement_score, topic_affinity_vector (opaque). Refresh: hourly for engagement, daily for topic affinity."@en,
        "Story: As a personalization engineer, I need stable feature definitions so models can be retrained and served without silent meaning changes that degrade ranking quality."@en .

dp:SF_Recs_Features_Quality a owl:NamedIndividual ;
    rdfs:label "SF Recs Features Quality"@en ;
    dctm:description "Stability and timeliness metrics for feature production."@en ;
    rdfs:comment "Timeliness: hourly refresh success >= 99% daily. Drift: alert if engagement_score shifts > 2σ vs prior 7-day baseline."@en .

dp:SF_Recs_Features_SLA a owl:NamedIndividual,
        dp:Service_Level_Agreement ;
    rdfs:label "SF Recs Features SLA"@en ;
    dctm:description "Freshness target: hourly refresh completes within 20 minutes of the hour. Availability: 99.9% monthly for the online feature service endpoint."@en ;
    rdfs:comment "Fallback: if endpoint degrades, serve cached features up to 6 hours old."@en ;
    dp:embedding_note "SF Recs Features SLA is an instance of Service Level Agreement."@en .

dp:SF_Recs_Features_Service a owl:NamedIndividual ;
    rdfs:label "SF Recs Features Service"@en ;
    dctm:description "Low-latency endpoint serving recommendation features for online ranking."@en ;
    dcat:endpointURL "https://api.streamforge.example/features/v1"^^xsd:anyURI ;
    dp:embedding_note "SF Recs Features Service dcat:endpointURL https://api.streamforge.example/features/v1."@en .

