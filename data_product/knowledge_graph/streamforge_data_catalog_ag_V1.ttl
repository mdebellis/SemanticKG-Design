sf:Discover_Data_Products_SPARQL_Implementation_Using_CONSTRUCT a owl:NamedIndividual,
        prov:Entity,
        dp:Catalog_Asset,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using CONSTRUCT"@en ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using CONSTRUCT is an instance of Catalog Asset."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT is an instance of Port Implementation."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT uses technology SPARQL."@en ;
    dp:has_sparql_query_text """PREFIX dp:   <https://www.michaeldebellis.com/dp/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
CONSTRUCT {
  ?bc  dp:has_data_product ?dp .
  ?dp  dp:has_port ?port .
  ?port dp:has_access_type ?access .}
WHERE {
  ?dp rdf:type dp:Data_Product .
  OPTIONAL { ?dp dp:has_bounded_context ?bc . }
  OPTIONAL { ?dp dp:has_port ?port . }
  OPTIONAL { ?port dp:has_access_type ?access . }
  # Keep the graph tight: only show products that actually have at least one port.
  FILTER(BOUND(?port))}""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

sf:Discover_Data_Products_SPARQL_Implementation_Using_CONSTRUCT_Catalog_Slice a owl:NamedIndividual,
        prov:Entity,
        dp:Catalog_Asset,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-02-05T01:36:18+00:00"^^xsd:dateTime ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice is an instance of Catalog Asset."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice is an instance of Port Implementation."@en,
        "Discover Data Products SPARQL Implementation Using CONSTRUCT Catalog Slice uses technology SPARQL."@en ;
    dp:has_sparql_query_text """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dp:   <https://www.michaeldebellis.com/dp/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
  ?catalog rdf:type dcat:Catalog .
  ?catalog dp:has_port ?catalog_port .

  ?catalog_port rdf:type dp:Data_Product_Port .
  ?catalog_port dp:discovers_data_product ?dp .   
  
  ?dp rdf:type dp:Data_Product .
  ?dp dp:has_port ?port .

  ?port rdf:type dp:Data_Product_Port .
  ?port dp:has_access_type ?access_type .

  ?access_type rdf:type dp:Access_Type .
}
WHERE {
  VALUES ?catalog { dp:StreamForge_Catalog }      # adjust IRI

  OPTIONAL { ?catalog dp:has_port ?catalog_port . }
  OPTIONAL { ?catalog_port dp:discovers_data_product ?dp . }

  OPTIONAL { ?dp dp:has_port ?port . }
  OPTIONAL { ?port dp:has_access_type ?access_type . }
}""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

sf:Discover_Data_Products_SPARQL_Implementation_Using_SELECT a owl:NamedIndividual,
        prov:Entity,
        dp:Catalog_Asset,
        dp:Port_Implementation ;
    rdfs:label "Discover Data Products SPARQL Implementation Using SELECT"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-02-04T23:07:15+00:00"^^xsd:dateTime ;
    dp:embedding_note "Discover Data Products SPARQL Implementation Using SELECT is an instance of Catalog Asset."@en,
        "Discover Data Products SPARQL Implementation Using SELECT is an instance of Port Implementation."@en,
        "Discover Data Products SPARQL Implementation Using SELECT uses technology SPARQL."@en ;
    dp:has_sparql_query_text """# Query 2B — Interactive SELECT (good for a “Data Catalog Port” UI)
# This returns the key facts a reader expects when “discovering” a product: 
PREFIX dp:    <https://www.michaeldebellis.com/dp/>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX terms: <http://purl.org/dc/terms/>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT ?dp ?dpLabel ?bc ?bcLabel ?port ?portLabel ?access ?accessLabel
WHERE {
  ?dp rdf:type dp:Data_Product .
  OPTIONAL { ?dp rdfs:label ?dpLabel . }
  OPTIONAL {
    ?dp dp:has_bounded_context ?bc .
    OPTIONAL { ?bc rdfs:label ?bcLabel . }}
  OPTIONAL {
    ?dp dp:has_port ?port .
    OPTIONAL { ?port rdfs:label ?portLabel . }
    OPTIONAL {
      ?port dp:has_access_type ?access .
      OPTIONAL { ?access rdfs:label ?accessLabel . }}}}
ORDER BY ?dpLabel ?portLabel""" ;
    dp:is_implementation_for sf:Discover_Data_Products ;
    dp:uses_technology dp:SPARQL .

