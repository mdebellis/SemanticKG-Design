@prefix : <https://michaeldebellis.com/pattern_examples/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://michaeldebellis.com/pattern_examples> a owl:Ontology .

:Acme a owl:NamedIndividual,
        :Organization ;
    rdfs:label "Acme"@en ;
    :has_Subsidiary :Acme_Widgets .

:Africa a owl:NamedIndividual,
        :Continent ;
    rdfs:label "Africa"@en ;
    :contains :South_Africa .

:Antarctica a owl:NamedIndividual,
        :Continent ;
    rdfs:label "Antarctica"@en .

:Asia a owl:NamedIndividual,
        :Continent ;
    rdfs:label "Asia"@en .

:Australia a owl:NamedIndividual,
        :Continent ;
    rdfs:label "Australia"@en .

:County a owl:Class ;
    rdfs:label "County"@en ;
    rdfs:subClassOf :Place .

:District a owl:Class ;
    rdfs:label "District"@en ;
    rdfs:subClassOf :Place .

:Europe a owl:NamedIndividual,
        :Continent ;
    rdfs:label "Europe"@en .

:King_Sabata_Dalindyebo_Local_Municipality a owl:NamedIndividual,
        :Municipality ;
    rdfs:label "King Sabata Dalindyebo Local Municipality"@en .

:Nelson_Mandela a owl:NamedIndividual,
        :Person ;
    rdfs:label "Nelson Mandela"@en ;
    :birth_Place :Mthatha .

:North_America a owl:NamedIndividual,
        :Continent ;
    rdfs:label "North America"@en ;
    :contains :Canada,
        :United_States .

:South_America a owl:NamedIndividual,
        :Continent ;
    rdfs:label "South America"@en .

:Town a owl:Class ;
    rdfs:label "Town"@en ;
    rdfs:subClassOf :Place .

:Village a owl:Class ;
    rdfs:label "Village"@en ;
    rdfs:subClassOf :Place .

:birth_Place a owl:ObjectProperty ;
    rdfs:label "birth place"@en ;
    rdfs:domain :Person ;
    rdfs:range :Place .

:contains a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains"@en ;
    rdfs:domain :Place ;
    rdfs:range :Place ;
    owl:inverseOf :is_Contained_In .

:email a owl:DatatypeProperty ;
    rdfs:label "email"@en ;
    rdfs:domain :Agent .

:first_Name a owl:DatatypeProperty ;
    rdfs:label "first name"@en ;
    rdfs:domain :Person .

:has_Address a owl:ObjectProperty ;
    rdfs:label "has address"@en ;
    rdfs:domain :Agent ;
    rdfs:range :Address ;
    owl:inverseOf :is_Address_For .

:has_City a owl:ObjectProperty ;
    rdfs:label "has city"@en ;
    rdfs:domain :Address ;
    rdfs:range :City .

:has_Location a owl:ObjectProperty ;
    rdfs:label "has location"@en ;
    rdfs:range :Place .

:has_State a owl:ObjectProperty ;
    rdfs:label "has state"@en ;
    rdfs:domain :Address ;
    rdfs:range :State .

:last_Name a owl:DatatypeProperty ;
    rdfs:label "last name"@en ;
    rdfs:domain :Person .

:phone_Number a owl:DatatypeProperty ;
    rdfs:label "phone number"@en ;
    rdfs:domain :Agent .

:street a owl:DatatypeProperty ;
    rdfs:label "street"@en ;
    rdfs:domain :Address .

:zip_Code a owl:DatatypeProperty ;
    rdfs:label "zip code"@en ;
    rdfs:domain :Address .

:Acme_American_Widgets a owl:NamedIndividual,
        :Region ;
    rdfs:label "Acme American Widgets"@en ;
    :has_Subsidiary :Acme_Widgets_NY_Sales .

:Acme_Widgets a owl:NamedIndividual,
        :Operating_Unit ;
    rdfs:label "Acme Widgets"@en ;
    :has_Subsidiary :Acme_American_Widgets .

:Acme_Widgets_NY_Sales a owl:NamedIndividual,
        :Sales_Office ;
    rdfs:label "Acme Widgets NY Sales"@en ;
    :has_Location :New_York_City .

:British_Columbia a owl:NamedIndividual,
        :Province ;
    rdfs:label "British Columbia"@en ;
    :contains :Vancouver .

:California a owl:NamedIndividual,
        :State ;
    rdfs:label "California"@en ;
    :contains :Los_Angeles,
        :San_Francisco .

:Canada a owl:NamedIndividual,
        :Nation ;
    rdfs:label "Canada"@en ;
    :contains :British_Columbia .

:Division a owl:Class ;
    rdfs:label "Division"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Region ;
            owl:onProperty :has_Parent ],
        :Organization .

:Eastern_Cape a owl:NamedIndividual,
        :Province ;
    rdfs:label "Eastern Cape"@en ;
    :contains :Mthatha .

:Los_Angeles a owl:NamedIndividual,
        :City ;
    rdfs:label "Los Angeles"@en .

:Municipality a owl:Class ;
    rdfs:label "Municipality"@en ;
    rdfs:subClassOf :Place .

:New_York_City a owl:NamedIndividual,
        :City ;
    rdfs:label "New York City"@en .

:New_York_State a owl:NamedIndividual,
        :State ;
    rdfs:label "New York State"@en .

:Sales_Office a owl:Class ;
    rdfs:label "Sales Office"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Division ;
            owl:onProperty :has_Parent ],
        :Organization .

:San_Francisco a owl:NamedIndividual,
        :City ;
    rdfs:label "San Francisco"@en .

:South_Africa a owl:NamedIndividual,
        :Nation ;
    rdfs:label "South Africa"@en ;
    :contains :Eastern_Cape .

:United_States a owl:NamedIndividual,
        :Nation ;
    rdfs:label "United States"@en ;
    :contains :California,
        :New_York_State .

:Vancouver a owl:NamedIndividual,
        :City ;
    rdfs:label "Vancouver"@en .

:has_Subsidiary a owl:ObjectProperty ;
    rdfs:label "has subsidiary"@en .

:is_Address_For a owl:ObjectProperty ;
    rdfs:label "is address for"@en .

:is_Contained_In a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is contained in"@en .

:Mthatha a owl:NamedIndividual,
        :City ;
    rdfs:label "Mthatha"@en .

:Operating_Unit a owl:Class ;
    rdfs:label "Operating Unit"@en ;
    rdfs:subClassOf :Organization .

:Province a owl:Class ;
    rdfs:label "Province"@en ;
    rdfs:subClassOf :Place .

:Region a owl:Class ;
    rdfs:label "Region"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Operating_Unit ;
            owl:onProperty :has_Parent ],
        :Organization .

:Nation a owl:Class ;
    rdfs:label "Nation"@en ;
    rdfs:subClassOf :Place .

:State a owl:Class ;
    rdfs:label "State"@en ;
    rdfs:subClassOf :Place .

:has_Parent a owl:ObjectProperty ;
    rdfs:label "has parent"@en ;
    rdfs:domain :Organization ;
    rdfs:range :Organization ;
    owl:inverseOf :has_Subsidiary .

:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:subClassOf :Agent .

:Address a owl:Class ;
    rdfs:label "Address"@en ;
    rdfs:subClassOf :Place .

:Agent a owl:Class ;
    rdfs:label "Agent"@en .

:City a owl:Class ;
    rdfs:label "City"@en ;
    rdfs:subClassOf :Place .

:Continent a owl:Class ;
    rdfs:label "Continent"@en ;
    rdfs:subClassOf :Place .

:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    rdfs:subClassOf :Agent .

:Place a owl:Class ;
    rdfs:label "Place"@en .

