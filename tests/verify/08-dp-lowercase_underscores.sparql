# 08-dp-lowercase_underscores.sparql
# Ensures data property names follow lowercase_with_underscores pattern

PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?p ?local
WHERE {
  ?p a owl:DatatypeProperty .
  BIND(STRAFTER(STR(?p), "https://www.michaeldebellis.com/") AS ?tail)
  BIND(REPLACE(?tail, "^.*/", "") AS ?local)
  FILTER(!REGEX(?local, "^[a-z0-9_]+$"))
}
# message: Data property local name is not lowercase_with_underscores
