    rdfs:domain dp:Bounded_Context ;
    rdfs:range dp:Bounded_Context ;
    skos:definition "A simplified, readable dependency edge between bounded contexts, typically derived from Context Map Relationships for visualization." .

dp:depends_on_port a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "depends on port"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-21T19:29:23+00:00"^^xsd:dateTime ;
    rdfs:domain dp:Data_Product_Port ;
    rdfs:range dp:Data_Product_Port ;
    dp:embedding_note "depends on port has contributor Michael DeBellis."@en .

dp:discovers_data_product a owl:ObjectProperty ;
    rdfs:label "discovers data product"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-02-05T00:57:02+00:00"^^xsd:dateTime ;
    rdfs:range dp:Data_Product ;
    rdfs:subPropertyOf dp:discovers_resource ;
    dp:embedding_note "discovers data product has contributor Michael DeBellis."@en .

dp:email a owl:DatatypeProperty ;
    rdfs:label "email"@en ;
    rdfs:domain prov:Agent ;
    rdfs:range xsd:string .

dp:embedding_label a owl:AnnotationProperty ;
    rdfs:label "embedding label"@en ;
    skos:definition "This property is used to define an additional label to be used when generating text strings for dp:embedding_note. It is for cases (e.g., dcat:catalog) where the defined label won't yield an understandable string. E.g., for dcat:catalog we want a string like \"Catalog1 has sub-catalog Catalog1_Sub\" but the defined label would give: \"Catalog1 catalog Catalog1_Sub\" so we define the string: \"has sub-catalog\" for dp:embedding_label on dcat:catalog."@en .

dp:embedding_note a owl:AnnotationProperty ;
    rdfs:label "embedding note"@en .

dp:exposes_service a owl:ObjectProperty ;
    rdfs:label "exposes service"@en ;
    rdfs:comment "Data Product usage: Links a Data Product to a service through which it is accessed."@en,
        "Relates a Data Product Version to a data service that exposes its data via an API or endpoint."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Service .

dp:first_name a owl:DatatypeProperty ;
    rdfs:label "first name"@en ;
    rdfs:domain prov:Person ;
    rdfs:range xsd:string .

dp:geo_contains_direct a owl:ObjectProperty ;
    rdfs:label "geo contains direct"@en ;
    rdfs:domain dp:Place ;
    rdfs:range dp:Place ;
    rdfs:subPropertyOf dp:geo_contains ;
    owl:inverseOf dp:geo_is_contained_in_direct ;
    dp:embedding_label "contains"@en .

dp:has_access_type a owl:ObjectProperty ;
    rdfs:label "has access type"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-23T19:54:08+00:00"^^xsd:dateTime ;
    rdfs:domain dp:Interface ;
    rdfs:range dp:Access_Type ;
    dp:embedding_note "has access type has contributor Michael DeBellis."@en .

dp:has_account a owl:ObjectProperty ;
    rdfs:label "has account"@en ;
    rdfs:domain prov:Person ;
    rdfs:range dp:Account ;
    owl:inverseOf dp:is_account_of .

dp:has_analytic_port a owl:ObjectProperty ;
    rdfs:label "has analytic port"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-21T01:30:07+00:00"^^xsd:dateTime ;
    rdfs:range dp:Analytic_Data_Port ;
    rdfs:subPropertyOf dp:has_port ;
    dp:embedding_note "has analytic port has contributor Michael DeBellis."@en .

dp:has_api_type a owl:ObjectProperty ;
    rdfs:label "has api type"@en ;
    rdfs:comment "Data Product usage: Indicates the API style used to expose a Data Product."@en,
        "Relates a data service to the type of API or interface that it provides (e.g., REST, GraphQL, SPARQL)."@en .

dp:has_catalog_policy a owl:ObjectProperty ;
    rdfs:label "has catalog policy"@en ;
    rdfs:comment "Links a catalog asset (e.g., a Data Product or Port) to an ODRL policy expressing governance intent."@en ;
    rdfs:range odrl:Policy .

dp:has_context_map_relationship a owl:ObjectProperty ;
    rdfs:label "has context map relationship"@en ;
    rdfs:domain dp:Context_Map ;
    rdfs:range dp:Context_Map_Relationship ;
    skos:definition "Links a Context Map artifact to the Context Map Relationships it records."@en .

dp:has_data_contract a owl:ObjectProperty ;
    rdfs:label "has data contract"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with a governing contract."@en,
        "Relates a Data Product to a contract describing its expected behavior and constraints."@en ;
    rdfs:range dp:Data_Contract ;
    owl:inverseOf dp:is_data_contract_for .

dp:has_data_product a owl:ObjectProperty ;
    rdfs:label "has data product"@en ;
    rdfs:domain dp:Container ;
    rdfs:range dp:Data_Product ;
    owl:inverseOf dp:is_data_product_for .

dp:has_data_quality_level a owl:ObjectProperty ;
    rdfs:label "has data quality level"@en ;
    rdfs:range skos:Concept ;
    skos:definition "Associates a Data Product (or Distribution/Port) with a SKOS concept that denotes the current data quality/validation level."@en .

dp:has_domain a owl:ObjectProperty ;
    rdfs:label "has domain"@en ;
    rdfs:comment "Data Product usage: Links a Data Product to the organizational domain in which it is defined."@en,
        "Relates a Data Product to the domain that owns and governs it."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Domain .

dp:has_from_context a owl:ObjectProperty ;
    rdfs:label "has from context"@en ;
    rdfs:domain dp:Context_Map_Relationship ;
    rdfs:range dp:Bounded_Context ;
    owl:inverseOf dp:is_from_context_for ;
    skos:definition "Relates a Context Map Relationship to the bounded context that acts as the source or upstream context in an inter-context relationship. This context provides information, services, or models that are consumed or interpreted by another context."@en .

dp:has_implementation a owl:ObjectProperty ;
    rdfs:label "has implementation"@en ;
    rdfs:comment "Links a port to one or more concrete implementations."@en ;
    rdfs:domain dp:Data_Product_Port ;
    rdfs:range dp:Port_Implementation ;
    owl:inverseOf dp:is_implementation_for .

dp:has_implementation_artifact_uri a owl:DatatypeProperty ;
    rdfs:label "has implementation artifact uri"@en ;
    rdfs:comment "This property is used to point to concrete implementation resources (for example, GitHub URLs, file paths, or documentation images) without overloading bibliographic provenance properties such as dct:source. The URI identifies the artifact itself, not the person or publication from which it originated." ;
    rdfs:domain dp:Port_Implementation ;
    rdfs:range xsd:anyURI ;
    skos:definition "Associates a port implementation with a URI that identifies an implementation artifact, such as a source code file, schema definition, script, or image."@en .

dp:has_interface a owl:ObjectProperty ;
    rdfs:label "has interface"@en ;
    rdfs:domain dp:Data_Product_Port ;
    rdfs:range dp:Interface ;
    owl:inverseOf dp:is_interface_for .

dp:has_internal_customer a owl:ObjectProperty ;
    rdfs:label "has internal customer"@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range prov:Agent ;
    skos:definition "Relates a data product to an internal consumer (typically a team, department, or business unit) that relies on the product and can provide feedback on its usefulness and quality."@en .

dp:has_location a owl:ObjectProperty ;
    rdfs:label "has location"@en ;
    rdfs:range dp:Place .

dp:has_operational_port a owl:ObjectProperty ;
    rdfs:label "has operational port"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-21T01:30:07+00:00"^^xsd:dateTime ;
    rdfs:range dp:Operational_Data_Port ;
    rdfs:subPropertyOf dp:has_port ;
    dp:embedding_note "has operational port has contributor Michael DeBellis."@en .

dp:has_output_port a owl:ObjectProperty ;
    rdfs:label "has output port"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-02-07T19:34:29+00:00"^^xsd:dateTime ;
    rdfs:range dp:Output_Port ;
    rdfs:subPropertyOf dp:has_port ;
    dp:embedding_note "has output port has contributor Michael DeBellis."@en .

dp:has_platform a owl:ObjectProperty ;
    rdfs:label "has platform"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-16T01:22:40+00:00"^^xsd:dateTime ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Platform ;
    dp:embedding_note "has platform has contributor Michael DeBellis."@en .

dp:has_platform_port a owl:ObjectProperty ;
    rdfs:label "has platform port"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2026-01-21T01:30:07+00:00"^^xsd:dateTime ;
    rdfs:range dp:Platform_Port ;
    rdfs:subPropertyOf dp:has_port ;
    dp:embedding_note "has platform port has contributor Michael DeBellis."@en .

dp:has_product_key a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has product key"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with its stable product key."@en,
        "Relates a Data Product to a controlled Product Key individual used as its canonical identifier instead of a free-text string."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Product_Key .

dp:has_product_type a owl:ObjectProperty ;
    rdfs:label "has product type"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with its classification type."@en,
        "Relates a Data Product to a classification of its type (e.g., source-aligned, aggregate, feature-store)."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Data_Product_Type .

dp:has_quality_metric a owl:ObjectProperty ;
    rdfs:label "has quality metric"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with one or more quality metrics."@en,
        "Relates a Data Product Version to a quality metric describing some property of its data."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Quality_Metric .

dp:has_relationship_type a owl:ObjectProperty ;
    rdfs:label "has relationship type"@en ;
    rdfs:domain dp:Context_Map_Relationship ;
    rdfs:range dp:Context_Map_Relationship_Type .

dp:has_sidecar a owl:ObjectProperty ;
    rdfs:label "has sidecar"@en ;
    rdfs:domain dp:Catalog_Asset ;
    rdfs:range dp:Sidecar ;
    owl:inverseOf dp:is_sidecar_for .

dp:has_sla a owl:ObjectProperty ;
    rdfs:label "has sla"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with an SLA defining its service expectations."@en,
        "Relates a Data Product Version (or in some cases the abstract Data Product) to an associated service level agreement."@en .

dp:has_source_text a owl:DatatypeProperty ;
    rdfs:label "has source text"@en ;
    rdfs:domain dp:Implementation_Artifact ;
    rdfs:range xsd:string .

dp:has_sparql_query_text a owl:DatatypeProperty ;
    rdfs:label "has sparql query text"@en ;
    rdfs:comment "Use this when a port’s behavior is defined primarily by a SPARQL query (e.g., a catalog search port or an output port implemented as a parameterized query)." ;
    rdfs:domain dp:Port_Implementation ;
    rdfs:range xsd:string ;
    skos:definition "A SPARQL query string that a data port executes, exposes, or uses as part of its implementation."@en .

dp:has_supported_access_type a owl:ObjectProperty ;
    rdfs:label "has supported access type"@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Access_Type .

dp:has_to_context a owl:ObjectProperty ;
    rdfs:label "has to context"@en ;
    rdfs:domain dp:Context_Map_Relationship ;
    rdfs:range dp:Bounded_Context ;
    skos:definition "Relates a Context Map Relationship to the bounded context that acts as the target or downstream context in an inter-context relationship. This context depends on, integrates with, or adapts information originating from another context."@en .

dp:has_version a owl:ObjectProperty ;
    rdfs:label "has version"@en ;
    rdfs:comment "Links a Data Product to one of its released versions."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Data_Product_Version ;
    owl:inverseOf dp:is_version_of .

dp:implemented_by_service a owl:ObjectProperty ;
    rdfs:label "implemented by service"@en ;
    rdfs:domain dp:Interface ;
    rdfs:range dp:Service ;
    rdfs:subPropertyOf dp:implemented_by_activity .

dp:intended_use a owl:AnnotationProperty ;
    rdfs:label "intended use"@en ;
    dp:embedding_label "has intended use"@en .

dp:is_billed_to a owl:ObjectProperty ;
    rdfs:label "is billed to"@en ;
    rdfs:domain dp:Account ;
    rdfs:range prov:Agent .

dp:last_name a owl:DatatypeProperty ;
    rdfs:label "last name"@en ;
    rdfs:domain prov:Person ;
    rdfs:range xsd:string .

dp:lifecycle_stage a owl:AnnotationProperty ;
    rdfs:label "lifecycle stage"@en ;
    dp:embedding_label "has lifecycle stage"@en .

dp:metric_higher_is_better a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "metric higher is better"@en ;
    rdfs:domain dp:Quality_Metric ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether higher numeric values represent better outcomes for this metric."@en .

dp:metric_max_value a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "metric maximum value"@en ;
    rdfs:domain dp:Quality_Metric ;
    rdfs:range xsd:decimal ;
    skos:definition "The maximum possible value for this quality metric."@en .

dp:metric_min_value a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "metric minimum value"@en ;
    rdfs:domain dp:Quality_Metric ;
    rdfs:range xsd:decimal ;
    skos:definition "The minimum possible value for this quality metric."@en .

dp:metric_recorded_at a owl:DatatypeProperty ;
    rdfs:label "metric recorded at"@en ;
    rdfs:domain dp:Quality_Metric ;
    rdfs:range xsd:dateTime ;
    skos:definition "The timestamp indicating when a quality metric value was recorded or computed."@en .

dp:metric_value a owl:DatatypeProperty ;
    rdfs:label "metric value"@en ;
    rdfs:domain dp:Quality_Metric ;
    rdfs:range xsd:decimal ;
    skos:definition "A numeric value for a quality metric (for example, an average satisfaction rating)."@en ;
    dp:embedding_label "has metric value"@en .

dp:owned_by a owl:ObjectProperty ;
    rdfs:label "owned by"@en ;
    rdfs:comment "Data Product usage: Associates a Data Product with the team or organization that owns and is accountable for it."@en,
        "Relates a Data Product to the team that owns and operates it."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dp:Data_Product_Team .

dp:phone a owl:DatatypeProperty ;
    rdfs:label "phone"@en ;
    rdfs:domain prov:Agent ;
    rdfs:range xsd:string .

dp:postal_address a owl:DatatypeProperty ;
    rdfs:label "postal address"@en ;
    rdfs:domain prov:Agent ;
    rdfs:range xsd:string .

dp:preferred_language a owl:DatatypeProperty ;
    rdfs:label "preferred language"@en ;
    rdfs:domain prov:Person ;
    rdfs:range xsd:language .

dp:previous_version a owl:ObjectProperty ;
    rdfs:label "previous version"@en ;
    rdfs:comment "Links a version to the immediately prior version in its lineage."@en .

dp:produces_dataset a owl:ObjectProperty ;
    rdfs:label "produces dataset"@en ;
    rdfs:comment "Data Product usage: Indicates that a Data Product produces one or more datasets as outputs."@en,
        "Relates a Data Product Version to a dataset that it publishes as part of its output."@en ;
    rdfs:domain dp:Data_Product ;
    rdfs:range dcat:Dataset .

dp:upstream_of a owl:ObjectProperty ;
    rdfs:label "upstream of"@en ;
    dctm:contributor "Michael DeBellis" ;
    dctm:created "2025-12-12T04:30:40+00:00"^^xsd:dateTime ;
    rdfs:comment "Data Product usage: Indicates an upstream dependency relationship between Data Products."@en,
        "Indicates that one bounded context provides data or behavior that another depends on."@en ;
    dp:embedding_note "upstream of has contributor Michael DeBellis."@en .

dp:uses_data_product a owl:ObjectProperty ;
    rdfs:label "uses data product"@en ;
    dctm:description "Indicates that the document references, depends on, or was produced using a specific data product."@en ;
    rdfs:range dp:Data_Product .

dp:uses_dataset a owl:ObjectProperty ;
    rdfs:label "uses dataset"@en ;
    dctm:description "Indicates that the document references, depends on, or was produced using a specific dataset (typically from the catalog)."@en ;
    rdfs:range dcat:Dataset .

dp:uses_technology a owl:ObjectProperty ;
    rdfs:label "uses technology"@en ;
    rdfs:comment "Technologies used by a given port implementation."@en ;
    rdfs:domain dp:Port_Implementation ;
    rdfs:range dp:Implementation_Technology .

dp:validation_rank a owl:DatatypeProperty ;
    rdfs:label "validation rank"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range xsd:integer ;
    skos:definition "An integer used for ordering data quality levels from least validated (lower) to most validated (higher)."@en ;
    dp:embedding_label "has validation rank"@en .

dp:version_identifier a owl:DatatypeProperty ;
    rdfs:label "version identifier"@en ;
    rdfs:comment "Human-readable version id such as v1, v2.0, 2025-01-15, etc."@en ;
    rdfs:range xsd:string .

<https://www.michaeldebellis.com/streamforge> a owl:Ontology ;
    rdfs:label "Ontology for StreamForge Data Product Catalog example."@en ;
    dctm:created "2025-12-01T00:00:00+00:00"^^xsd:dateTime ;
    dctm:creator """Michael DeBellis
https://www.michaeldebellis.com"""@en ;
    dctm:description "This ontology alse leverages some entities from the ODRL ontology for definitions of security and governance entities such as the classes Rule and Policy"@en,
        "This ontology defines the core concepts used in the StreamForge Data Product Catalog, including Data Products, bounded contexts, ports, ownership, and associated documentation. It is intended to support analytics, operational use cases, governance, and decision-making across the StreamForge organization."@en,
        """This ontology reuses terms from several W3C vocabularies for metadata, provenance, and cataloging. 
In particular, it incorporates the Data Catalog Vocabulary (DCAT) for describing data products and 
catalog entries. DCAT itself builds upon other widely used vocabularies, including the PROV-O 
(Provenance Ontology) for representing provenance relationships, SKOS for controlled vocabularies 
and classification schemes, and Dublin Core (DC Terms) for general-purpose metadata such as titles, 
descriptions, and identifiers. Definitions for reused terms are taken from these vocabularies when 
available."""@en ;
    dctm:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Copyright (c) 2026 Michael DeBellis. Licensed under CC BY 4.0."@en,
        "This ontology is licensed under the Creative Commons Attribution 4.0 International License (CC BY 4.0)."@en ;
    skos:definition "The StreamForge Data Catalog provides a unified view of Data Products, metadata, governance information, and documentation used across the StreamForge platform. It enables discovery, understanding, and responsible use of enterprise data assets by making their structure, purpose, ownership, and relationships explicit."@en ;
    dp:embedding_note """Ontology for StreamForge Data Product Catalog example. has creator Michael DeBellis
https://www.michaeldebellis.com."""@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025 a owl:NamedIndividual,
        docs:Document ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025"@en ;
    dctm:created "2025-11-20"^^xsd:date ;
    dctm:creator "Monetization"@en ;
    dctm:publisher "StreamForge Finance Engineering"@en ;
    dctm:title "Ads Revenue Reconciliation Notes (Nov 2025)"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 has creator Monetization."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 has publisher StreamForge Finance Engineering."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 is an instance of Document."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 uses data product SF Ads Performance Data Product."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 uses dataset SF Ads Performance Dataset."@en ;
    dp:uses_data_product sf:SF_Ads_Performance_Data_Product ;
    dp:uses_dataset sf:SF_Ads_Performance_Dataset .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_01 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01"@en ;
    docs:chunk_index 1 ;
    docs:chunk_text "This note documents how daily ad revenue is reconciled between delivery logs and finance reporting. The goal is consistent numbers across dashboards and the general ledger."@en ;
    docs:chunk_title "Context"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01 has title Context."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 01 is an instance of Document Chunk."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_02 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02"@en ;
    docs:chunk_index 2 ;
    docs:chunk_text "We used the StreamForge Ads Performance data product. It provides daily aggregates by video and channel, sourced from ad server logs and summarized into BigQuery tables."@en ;
    docs:chunk_title "Data sources"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02 has title Data sources."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 02 is an instance of Document Chunk."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_03 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03"@en ;
    docs:chunk_index 3 ;
    docs:chunk_text "Late-arriving events and currency conversion updates can shift revenue totals. A 'finalized_date' convention is recommended so stakeholders know when a day’s revenue is stable."@en ;
    docs:chunk_title "Known pitfalls"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03 has title Known pitfalls."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 03 is an instance of Document Chunk."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_04 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04"@en ;
    docs:chunk_index 4 ;
    docs:chunk_text "The dataset is at daily grain. Video_id and channel_id are stable join keys. Avoid joining to event-level engagement without first aggregating engagement to daily grain."@en ;
    docs:chunk_title "Join keys and grain"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04 has title Join keys and grain."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 04 is an instance of Document Chunk."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_05 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05"@en ;
    docs:chunk_index 5 ;
    docs:chunk_text "We validate that delivered impressions reconcile to billed impressions within 0.5%. Outliers are investigated by country, device, and ad format."@en ;
    docs:chunk_title "Validation checks"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05 has title Validation checks."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 05 is an instance of Document Chunk."@en .

sf:Ads_Revenue_Reconciliation_Notes_Nov_2025_Chunk_06 a owl:NamedIndividual,
        docs:Document_Chunk ;
    rdfs:label "Ads Revenue Reconciliation Notes Nov 2025 Chunk 06"@en ;
    docs:chunk_index 6 ;
    docs:chunk_text "Publish a documented 'ads_revenue_daily' view as the canonical table for reporting. Deprecate ad-hoc spreadsheets and require dashboard owners to reference the canonical view."@en ;
    docs:chunk_title "Governance recommendation"@en ;
    dp:embedding_note "Ads Revenue Reconciliation Notes Nov 2025 Chunk 06 has title Governance recommendation."@en,
        "Ads Revenue Reconciliation Notes Nov 2025 Chunk 06 is an instance of Document Chunk."@en .

